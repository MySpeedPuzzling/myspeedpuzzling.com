<div class="mb-3 mb-md-4 col-md-6">
    <div class="card shadow position-relative">
        {% if is_granted('COMPETITION_EDIT', event.id) or is_granted(constant('SpeedPuzzling\\Web\\Security\\CompetitionDeleteVoter::COMPETITION_DELETE'), event.id) %}
            <div class="d-flex gap-1" style="position: absolute; top: 8px; right: 8px; z-index: 1;">
                {% if is_granted('COMPETITION_EDIT', event.id) %}
                    <a href="{{ path('edit_competition', {'competitionId': event.id, return: path('events'), return_title: 'events.title'|trans}) }}" class="btn btn-sm btn-outline-primary px-2 py-1">
                        <i class="bi bi-pencil"></i>
                    </a>
                {% endif %}
                {% if is_granted(constant('SpeedPuzzling\\Web\\Security\\CompetitionDeleteVoter::COMPETITION_DELETE'), event.id) %}
                    <button type="button" class="btn btn-sm btn-outline-danger px-2 py-1" data-bs-toggle="modal" data-bs-target="#deleteCompetitionModal-{{ event.id }}" title="{{ 'competition.delete.button'|trans }}">
                        <i class="bi bi-trash"></i>
                    </button>
                {% endif %}
            </div>
            {% if is_granted(constant('SpeedPuzzling\\Web\\Security\\CompetitionDeleteVoter::COMPETITION_DELETE'), event.id) %}
                {{ include('_competition_delete_modal.html.twig', {id: event.id, name: event.name}) }}
            {% endif %}
        {% endif %}
        <div class="card-body d-flex w-100 p-3">
            <div class="flex-fill">
                <h3 class="h5 mb-2">
                    {% if event.slug %}
                        <a class="text-decoration-underline" href="{{ path('event_detail', {'slug': event.slug, return: path('events'), return_title: 'events.title'|trans}) }}">
                            {{ event.name }}
                        </a>
                    {% else %}
                        {{ event.name }}
                    {% endif %}
                    {% if event.isOnline %}
                        <span class="badge bg-info text-dark ms-1">{{ 'competition.online'|trans }}</span>
                    {% endif %}
                </h3>

                <div class="row">
                    <div class="col-sm-6">
                        {% if event.locationCountryCode %}
                            <span class="shadow-custom fi fi-{{ event.locationCountryCode.name }} me-2"></span>
                        {% endif %}

                        {{ event.location }}

                        {% if event.dateFrom %}
                            <div class="mt-1">
                                <i class="ci-calendar me-2 ps-1"></i>
                                {% if event.dateTo and event.dateFrom != event.dateTo %}
                                    {{ event.dateFrom|date('d.') }}-{{ event.dateTo|date('d.m.') }}
                                {% else %}
                                    {{ event.dateFrom|date('d.m.') }}
                                {% endif %}
                                <small class="text-muted ps-1">({{ event.dateFrom|ago }})</small>
                            </div>
                        {% endif %}
                    </div>

                    {% if event.link or event.registrationLink or event.resultsLink %}
                        <div class="col-sm-6 mt-2 mt-sm-0">
                            {% if event.link %}
                                <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ event.link }}">
                                    <i class="bi bi-info-circle me-1"></i>{{ 'events.website_link'|trans }}
                                </a>
                            {% endif %}

                            {% if event.registrationLink %}
                                <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ event.registrationLink }}">
                                    <i class="bi bi-person-plus me-1"></i>{{ 'events.registration_link'|trans }}
                                </a>
                            {% endif %}

                            {% if event.resultsLink %}
                                <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ event.resultsLink }}">
                                    <i class="bi bi-trophy me-1"></i>{{ 'events.results_link'|trans }}
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="ms-3 flex-shrink-0 event-image">
                {% if event.logo %}
                    <img style="max-height: 84px;" src="{{ event.logo|thumbnail('puzzle_small') }}" alt="{{ event.name }} logo" class="img-fluid">
                {% endif %}
            </div>
        </div>
    </div>
</div>
