{# Quick-edit button that opens the edit-time form in the global turbo-frame modal.
   Inputs:
     - timeId (string, required)
     - context (string, required) — one of EditTimeReturnContext values:
         'profile' (redirects back to the owner's profile)
         'puzzle-detail' (redirects back to the puzzle detail page of the edited time)
#}
<a href="{{ path('edit_time', {timeId: timeId, context: context}) }}"
   data-turbo-frame="modal-frame"
   class="btn btn-sm btn-outline-dark p-1 border-0 ms-1"
   title="{{ 'forms.edit'|trans }}"
   aria-label="{{ 'forms.edit'|trans }}">
    <i class="ci-edit"></i>
</a>
