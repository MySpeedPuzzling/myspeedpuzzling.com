<turbo-frame id="modal-frame">
    <div class="modal-header">
        <h5 class="modal-title">{{ 'feedback.title'|trans }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>
    <div class="modal-body">
        {{ form_start(feedback_form, {
            action: path('feedback'),
            attr: {'data-turbo-frame': 'modal-frame'}
        }) }}
            {{ form_row(feedback_form.message) }}

            <p class="mt-3 mb-0">
                <input type="submit" name="submit" value="{{ 'forms.send_feedback'|trans }}" class="btn btn-primary" />
            </p>
        {{ form_end(feedback_form) }}
    </div>
</turbo-frame>
