{# Editions system section of a series page. Expects: series, upcoming_editions, past_editions #}
    {% if upcoming_editions|length > 0 %}
        <h2 class="h5 mt-4 mb-3">{{ 'series.upcoming_editions'|trans }}</h2>
        <div class="row">
            {% for edition in upcoming_editions %}
                <div class="mb-3 mb-md-4 col-md-6">
                    <div class="card shadow h-100">
                        <div class="card-body p-3">
                            <h3 class="h5 mb-2">
                                <a href="{{ path('edition_detail', {'seriesSlug': series.slug, 'editionSlug': edition.editionSlug}) }}" class="text-decoration-underline">
                                    {{ edition.name }}
                                </a>
                            </h3>

                            {% if edition.startsAt %}
                                <div class="mt-1">
                                    <i class="ci-calendar me-2 ps-1"></i>
                                    {{ edition.startsAt|date('d.m.Y H:i') }}
                                    <small class="text-muted ps-1">({{ edition.startsAt|ago }})</small>
                                </div>
                            {% endif %}

                            <div class="d-flex flex-wrap gap-3 mt-2 text-muted small">
                                {% if edition.minutesLimit and edition.roundCount <= 1 %}
                                    <span><i class="bi bi-clock me-1"></i>{{ edition.minutesLimit }} min</span>
                                {% endif %}
                                {% if edition.roundCount > 1 %}
                                    <span><i class="bi bi-list-ol me-1"></i>{{ edition.roundCount }} {{ 'competition.rounds_count'|trans }}</span>
                                {% endif %}
                                <span><i class="bi bi-puzzle me-1"></i>{{ edition.puzzleCount }}</span>
                                <span><i class="bi bi-people me-1"></i>{{ edition.participantCount }}</span>
                            </div>

                            {% if edition.registrationLink %}
                                <div class="mt-2">
                                    <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ edition.registrationLink }}">
                                        <i class="bi bi-person-plus me-1"></i>{{ 'events.registration_link'|trans }}
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {% if past_editions|length > 0 %}
        <h2 class="h5 mt-4 mb-3">{{ 'series.past_editions'|trans }}</h2>
        <div class="row">
            {% for edition in past_editions %}
                <div class="mb-3 mb-md-4 col-md-6">
                    <div class="card shadow h-100">
                        <div class="card-body p-3">
                            <h3 class="h5 mb-2">
                                <a href="{{ path('edition_detail', {'seriesSlug': series.slug, 'editionSlug': edition.editionSlug}) }}" class="text-decoration-underline">
                                    {{ edition.name }}
                                </a>
                            </h3>

                            {% if edition.startsAt %}
                                <div class="mt-1">
                                    <i class="ci-calendar me-2 ps-1"></i>
                                    {{ edition.startsAt|date('d.m.Y H:i') }}
                                    <small class="text-muted ps-1">({{ edition.startsAt|ago }})</small>
                                </div>
                            {% endif %}

                            <div class="d-flex flex-wrap gap-3 mt-2 text-muted small">
                                {% if edition.minutesLimit and edition.roundCount <= 1 %}
                                    <span><i class="bi bi-clock me-1"></i>{{ edition.minutesLimit }} min</span>
                                {% endif %}
                                {% if edition.roundCount > 1 %}
                                    <span><i class="bi bi-list-ol me-1"></i>{{ edition.roundCount }} {{ 'competition.rounds_count'|trans }}</span>
                                {% endif %}
                                <span><i class="bi bi-puzzle me-1"></i>{{ edition.puzzleCount }}</span>
                                <span><i class="bi bi-people me-1"></i>{{ edition.participantCount }}</span>
                            </div>

                            {% if edition.resultsLink %}
                                <div class="mt-2">
                                    <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ edition.resultsLink }}">
                                        <i class="bi bi-trophy me-1"></i>{{ 'events.results_link'|trans }}
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

