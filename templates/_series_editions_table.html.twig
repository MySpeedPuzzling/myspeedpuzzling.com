<div class="row g-3">
    {% for edition in editions %}
        <div class="col-12 col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="fw-semibold">{{ edition.name }}</span>
                        <div class="d-flex gap-1">
                            <a href="{{ path('edit_competition', {'competitionId': edition.competitionId, return: path('manage_competition_series', {seriesId: series.id}), return_title: 'series.manage'|trans}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'edition.edit'|trans }}">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </div>
                    </div>

                    <div class="small text-body-secondary mb-3">
                        {% if edition.startsAt %}
                            <i class="bi bi-calendar-event me-1"></i>{{ edition.startsAt|date('d.m.Y H:i') }}
                            <span class="mx-1">&middot;</span>
                        {% endif %}
                        {% if edition.minutesLimit and edition.roundCount <= 1 %}
                            <i class="bi bi-stopwatch me-1"></i>{{ edition.minutesLimit }} min
                            <span class="mx-1">&middot;</span>
                        {% endif %}
                        <i class="bi bi-list-ol me-1"></i>{{ edition.roundCount }} {{ 'competition.rounds_count'|trans }}
                        <span class="mx-1">&middot;</span>
                        <i class="bi bi-puzzle me-1"></i>{{ edition.puzzleCount }}
                        <span class="mx-1">&middot;</span>
                        <i class="bi bi-people me-1"></i>{{ edition.participantCount }}
                    </div>

                    <div class="d-flex flex-wrap gap-1">
                        <a href="{{ path('manage_competition_rounds', {'competitionId': edition.competitionId, return: path('manage_competition_series', {seriesId: series.id}), return_title: 'series.manage'|trans}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-list-ol me-1"></i>{{ 'competition.manage_rounds'|trans }}
                        </a>
                        <a href="{{ path('manage_competition_participants', {'competitionId': edition.competitionId, return: path('manage_competition_series', {seriesId: series.id}), return_title: 'series.manage'|trans}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-people me-1"></i>{{ 'competition.manage_participants'|trans }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}
</div>
