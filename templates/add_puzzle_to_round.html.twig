{% extends 'base.html.twig' %}

{% block title %}{{ 'competition.add_puzzle'|trans }} - {{ round.name }}{% endblock %}

{% block content %}
    {{ include('_breadcrumb.html.twig', {items: [
        {label: 'events.title'|trans, url: path('events')},
        {label: competition.name, url: path('edit_competition', {competitionId: competition.id})},
        {label: 'competition.manage_rounds'|trans, url: path('manage_competition_rounds', {competitionId: competition.id})},
        {label: round.name, url: path('manage_round_puzzles', {roundId: round.id})},
        {label: 'competition.add_puzzle'|trans},
    ]}) }}
    {{ include('_return_back_button.html.twig', {fallbackUrl: path('manage_round_puzzles', {roundId: round.id}), fallbackTitle: 'competition.manage_puzzles'|trans}) }}

    <div class="pb-4">
        <div class="row gy-3 pb-3">
            <div class="col-lg-8">
                <h1 class="h2">{{ 'competition.add_puzzle'|trans }}</h1>
                <p class="text-muted">{{ competition.name }} - {{ round.name }}</p>

                <div class="card shadow my-4">
                    <div class="card-body"
                         data-controller="time-form-autocomplete"
                         data-time-form-autocomplete-add-new-brand-message-value="{{ 'forms.add_new_brand'|trans }}"
                         data-time-form-autocomplete-add-new-puzzle-message-value="{{ 'forms.add_new_puzzle'|trans }}">
                        {{ form_start(form) }}
                            {{ form_row(form.brand, {'attr': {'data-time-form-autocomplete-target': 'brand'}}) }}
                            {{ form_row(form.puzzle, {'attr': {'data-time-form-autocomplete-target': 'puzzle'}}) }}

                            <div data-time-form-autocomplete-target="newPuzzle" class="d-none">
                                <p>
                                    <small class="text-muted">{{ 'puzzle_add.need_approve_info'|trans }}</small>
                                </p>
                                {{ form_row(form.piecesCount) }}
                                {{ form_row(form.puzzlePhoto) }}
                                {{ form_row(form.puzzleEan) }}
                                {{ form_row(form.puzzleIdentificationNumber) }}
                            </div>

                            <div class="mb-3">
                                {{ form_row(form.hideUntilRoundStarts, {
                                    'attr': {'data-action': 'change->time-form-autocomplete#toggleHideOptions'},
                                    'help': 'competition.round_puzzle.form.hide_help'|trans({'%date%': round.startsAt|date('j. n. Y H:i')}),
                                }) }}

                                <div data-time-form-autocomplete-target="hideOptions" class="d-none ms-4 mt-2">
                                    {% for child in form.hideMode %}
                                        <div class="form-check mb-2">
                                            {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                                            {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                            {% if child.vars.value == 'image_only' %}
                                                <div class="form-text">{{ 'competition.round_puzzle.form.hide_mode_image_only_help'|trans }}</div>
                                            {% elseif child.vars.value == 'entirely' %}
                                                <div class="form-text">{{ 'competition.round_puzzle.form.hide_mode_entirely_help'|trans }}</div>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary mt-3">
                                {{ 'competition.add_puzzle'|trans }}
                            </button>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
