{% extends 'base.html.twig' %}

{% block title %}{{ 'added_time_recap.meta.title'|trans }}{% endblock %}

{% block content %}
    <h1 class="h2">{{ 'added_time_recap.title'|trans }}</h1>

    <div class="my-4">
        <div class="btn-group btn-group-sm">
            <a rel="nofollow" href="{{ path('puzzle_add') }}" class="btn btn-outline-primary pe-2"><i class="ci-add"></i> {{ 'added_time_recap.add_time'|trans }}</a>
            <button type="button" class="btn btn-outline-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="visually-hidden">Toggle Dropdown</span>
            </button>
            <ul class="dropdown-menu shadow-custom">
                <li><a class="dropdown-item" rel="nofollow" href="{{ path('puzzle_add', {puzzleId: solved_puzzle.puzzleId}) }}">{{ 'added_time_recap.the_same_puzzle'|trans }}</a></li>
            </ul>
        </div>

        <a href="{{ path('puzzle_detail', {'puzzleId': solved_puzzle.puzzleId}) }}" class="btn btn-sm btn-outline-primary">{{ 'added_time_recap.puzzle_detail'|trans }}</a>
    </div>

    <div class="row">
        <div class="col-md-7 col-lg-8 order-2 order-md-1">
            {% if is_solo and solved_puzzle.time is not null %}
                {{ include('added_time_recap/_performance_summary.html.twig') }}

                {% if not player.rankingOptedOut %}
                    {{ include('added_time_recap/_ranking.html.twig') }}
                {% endif %}

                {{ include('added_time_recap/_history.html.twig') }}

                {% if not player.rankingOptedOut %}
                    {{ include('added_time_recap/_overall_progress.html.twig') }}
                {% endif %}
            {% endif %}
        </div>

        <div class="col-md-5 col-lg-4 order-1 order-md-2 mb-3 mb-md-0 text-center">
            <div class="time-result-recap d-inline-block">
                <div class="button-wrapper">
                    <button
                        data-controller="share-image"
                        data-share-image-title-value="{{ solved_puzzle.puzzleName }}"
                        data-share-image-image-url-value="{{ path('result_image', {'timeId': solved_puzzle.timeId}) }}"
                        data-action="click->share-image#shareImageAsset"
                        class="btn btn-primary shadow-lg opacity-80"
                    >
                        <i class="ci-share"></i> {{ 'share'|trans }}
                    </button>
                </div>

                <img style="max-width: 320px; width: 100%;" src="{{ path('result_image', {'timeId': solved_puzzle.timeId}) }}">
            </div>
        </div>
    </div>

{% endblock %}
