<div class="card shadow-sm mb-3 border-0">
    <div class="card-body">
        <h6 class="card-title mb-3">
            <i class="bi bi-clock-history me-1"></i>
            {{ 'added_time_recap.history.title'|trans }}
        </h6>

        {% if logged_user.profile is not null and logged_user.profile.activeMembership %}
            {% set timed_history = puzzle_history|filter(r => r.time is not null) %}

            {% if timed_history|length <= 1 %}
                <p class="text-muted mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    {{ 'added_time_recap.history.first_time'|trans }}
                </p>
            {% else %}
                {% set best_time = null %}
                {% for result in timed_history %}
                    {% if best_time is null or result.time < best_time %}
                        {% set best_time = result.time %}
                    {% endif %}
                {% endfor %}

                {% set is_new_pb = (solved_puzzle.time == best_time) %}

                {% if is_new_pb %}
                    <div class="alert alert-success d-flex align-items-center py-2 mb-3">
                        <i class="bi bi-star-fill fs-5 me-2"></i>
                        {{ 'added_time_recap.history.new_personal_best'|trans }}
                    </div>
                {% else %}
                    <div class="text-muted small mb-3">
                        <i class="bi bi-arrow-up-circle me-1"></i>
                        {{ 'added_time_recap.history.distance_from_best'|trans({'%time%': (solved_puzzle.time - best_time)|puzzlingTime}) }}
                    </div>
                {% endif %}

                {% set prev_times = {} %}
                {% set prev = null %}
                {% for result in timed_history %}
                    {% set prev_times = prev_times|merge({(result.timeId): prev}) %}
                    {% set prev = result.time %}
                {% endfor %}

                <div class="attempts-history-list">
                    {% for result in timed_history|reverse %}
                        {% set is_current = (result.timeId == solved_puzzle.timeId) %}
                        {% set is_best = (result.time == best_time) %}
                        {% set previous_time = prev_times[result.timeId] %}
                        {% set showPrevDelta = previous_time is not null %}
                        {% set showBestDelta = not is_best %}

                        <div class="attempts-history-entry fs-sm {% if not loop.first %}border-top pt-2 mt-2{% endif %}{% if is_current %} fw-medium{% endif %}">
                            <div class="d-flex justify-content-between align-items-center">
                                <span>
                                    <i class="bi bi-calendar3 text-muted me-1"></i>
                                    <span class="font-monospace">{{ (result.finishedAt ?? result.trackedAt)|date('d.m.Y') }}</span>
                                    {% if is_current %}
                                        <span class="badge bg-primary ms-1">{{ 'added_time_recap.history.current_solve'|trans }}</span>
                                    {% endif %}
                                </span>
                                <span>
                                    {% if is_best %}
                                        <i class="bi bi-star-fill text-warning me-1" style="font-size: 0.75rem;"></i>
                                    {% endif %}
                                    <i class="bi bi-stopwatch text-muted me-1"></i>
                                    <span class="font-monospace">{{ result.time|puzzlingTime }}</span>
                                </span>
                            </div>

                            {% if showPrevDelta or showBestDelta %}
                                <div class="fs-xs text-end mt-1">
                                    {% if showPrevDelta %}
                                        {% set delta = result.time - previous_time %}
                                        <div>
                                            <i class="bi bi-arrow-return-left text-muted me-1"></i>
                                            {% if delta < 0 %}
                                                <span class="text-success font-monospace">-{{ (delta|abs)|puzzlingTime }}</span>
                                            {% elseif delta > 0 %}
                                                <span class="text-warning font-monospace">+{{ delta|puzzlingTime }}</span>
                                            {% else %}
                                                <span class="text-muted font-monospace">+00:00:00</span>
                                            {% endif %}
                                        </div>
                                    {% endif %}

                                    {% if showBestDelta %}
                                        {% set delta_best = result.time - best_time %}
                                        <div>
                                            <i class="bi bi-star-fill text-warning me-1" style="font-size: 0.7rem;"></i>
                                            <span class="text-warning font-monospace">+{{ delta_best|puzzlingTime }}</span>
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>

                {% if timed_history|length > 1 %}
                    <div class="mt-3">
                        <twig:Chart:PlayerPuzzleTimesChart :results="timed_history" />
                    </div>
                {% endif %}
            {% endif %}
        {% else %}
            <div class="position-relative">
                <div style="filter: blur(5px); user-select: none;" aria-hidden="true">
                    <div class="attempts-history-list">
                        <div class="attempts-history-entry fs-sm fw-medium">
                            <div class="d-flex justify-content-between align-items-center">
                                <span>
                                    <i class="bi bi-calendar3 text-muted me-1"></i>
                                    <span class="font-monospace">31.03.2026</span>
                                </span>
                                <span>
                                    <i class="bi bi-stopwatch text-muted me-1"></i>
                                    <span class="font-monospace">01:02:15</span>
                                </span>
                            </div>
                            <div class="fs-xs text-end mt-1">
                                <div>
                                    <i class="bi bi-arrow-return-left text-muted me-1"></i>
                                    <span class="text-success font-monospace">-00:03:22</span>
                                </div>
                                <div>
                                    <i class="bi bi-star-fill text-warning me-1" style="font-size: 0.7rem;"></i>
                                    <span class="text-warning font-monospace">+00:01:44</span>
                                </div>
                            </div>
                        </div>
                        <div class="attempts-history-entry fs-sm border-top pt-2 mt-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <span>
                                    <i class="bi bi-calendar3 text-muted me-1"></i>
                                    <span class="font-monospace">28.03.2026</span>
                                </span>
                                <span>
                                    <i class="bi bi-stopwatch text-muted me-1"></i>
                                    <span class="font-monospace">01:05:37</span>
                                </span>
                            </div>
                            <div class="fs-xs text-end mt-1">
                                <div>
                                    <i class="bi bi-arrow-return-left text-muted me-1"></i>
                                    <span class="text-warning font-monospace">+00:05:10</span>
                                </div>
                                <div>
                                    <i class="bi bi-star-fill text-warning me-1" style="font-size: 0.7rem;"></i>
                                    <span class="text-warning font-monospace">+00:05:06</span>
                                </div>
                            </div>
                        </div>
                        <div class="attempts-history-entry fs-sm border-top pt-2 mt-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <span>
                                    <i class="bi bi-calendar3 text-muted me-1"></i>
                                    <span class="font-monospace">25.03.2026</span>
                                </span>
                                <span>
                                    <i class="bi bi-star-fill text-warning me-1" style="font-size: 0.75rem;"></i>
                                    <i class="bi bi-stopwatch text-muted me-1"></i>
                                    <span class="font-monospace">01:00:27</span>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                    <button
                        class="btn btn-outline-secondary bg-white btn-sm px-3 fs-sm shadow-custom"
                        data-bs-toggle="modal"
                        data-bs-target="#membersExclusiveModal"
                    >
                        <i class="ci-locked me-1"></i>
                        {{ 'membership.members_exclusive_button'|trans }}
                    </button>
                </div>
            </div>
        {% endif %}
    </div>
</div>
