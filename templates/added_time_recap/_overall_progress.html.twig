{% from 'puzzle_intelligence/_macros.html.twig' import skill_badge %}

<div class="card shadow-sm mb-3 border-0">
    <div class="card-body">
        <h6 class="card-title mb-3">
            <i class="bi bi-graph-up-arrow me-1"></i>
            {{ 'added_time_recap.progress.title'|trans({'%pieces%': solved_puzzle.piecesCount}) }}
        </h6>

        {% if logged_user.profile is not null and logged_user.profile.activeMembership %}
            <div class="row g-3">
                {# Skill Tier #}
                <div class="col-12 col-md-6">
                    <div class="fw-bold mb-1">{{ 'added_time_recap.progress.skill_tier'|trans }}</div>
                    {% if player_skill is not null %}
                        {% set tier_name = player_skill.skillTier.name|lower %}
                        {{ skill_badge(tier_name) }}
                        <div class="mt-1">
                            <small class="text-muted">
                                {{ 'added_time_recap.progress.skill_percentile'|trans({'%percent%': (100 - player_skill.skillPercentile)|round}) }}
                            </small>
                        </div>
                    {% else %}
                        <p class="text-muted small mb-0">
                            <i class="bi bi-lock me-1"></i>
                            {{ 'added_time_recap.progress.skill_tier_unavailable'|trans({
                                '%count%': max(20 - (player_skill is not null ? player_skill.qualifyingPuzzlesCount : 0), 0),
                                '%pieces%': solved_puzzle.piecesCount
                            }) }}
                        </p>
                    {% endif %}
                </div>

                {# MSP-ELO #}
                <div class="col-12 col-md-6">
                    <div class="fw-bold mb-1">{{ 'added_time_recap.progress.elo_title'|trans }}</div>
                    {% if elo_data[solved_puzzle.piecesCount] is defined %}
                        {% set elo = elo_data[solved_puzzle.piecesCount] %}
                        <span class="fw-bold fs-5">{{ (elo.elo_rating * 1000)|round }}</span>
                        <small class="text-muted ms-1">#{{ elo.rank }} / {{ elo.total }}</small>
                    {% elseif elo_progress is not null %}
                        <div class="small">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">{{ 'added_time_recap.progress.elo_first_attempts'|trans }}</span>
                                <span class="fw-medium">{{ elo_progress.first_attempts }}/{{ constant('SpeedPuzzling\\Web\\Services\\PuzzleIntelligence\\MspEloCalculator::MINIMUM_FIRST_ATTEMPTS') }}</span>
                            </div>
                            <div class="progress mb-2" style="height: 4px;">
                                <div class="progress-bar bg-primary" style="width: {{ min((elo_progress.first_attempts / constant('SpeedPuzzling\\Web\\Services\\PuzzleIntelligence\\MspEloCalculator::MINIMUM_FIRST_ATTEMPTS')) * 100, 100) }}%;"></div>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">{{ 'added_time_recap.progress.elo_total_solves'|trans }}</span>
                                <span class="fw-medium">{{ elo_progress.total_solves }}/{{ constant('SpeedPuzzling\\Web\\Services\\PuzzleIntelligence\\MspEloCalculator::MINIMUM_TOTAL_SOLVES') }}</span>
                            </div>
                            <div class="progress" style="height: 4px;">
                                <div class="progress-bar bg-primary" style="width: {{ min((elo_progress.total_solves / constant('SpeedPuzzling\\Web\\Services\\PuzzleIntelligence\\MspEloCalculator::MINIMUM_TOTAL_SOLVES')) * 100, 100) }}%;"></div>
                            </div>
                        </div>
                    {% else %}
                        <p class="text-muted small mb-0">
                            <i class="bi bi-lock me-1"></i>
                            {{ 'added_time_recap.progress.elo_unavailable'|trans({'%pieces%': solved_puzzle.piecesCount}) }}
                        </p>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="position-relative">
                <div style="filter: blur(5px); user-select: none; padding: 0 0.25rem 0.5rem;" aria-hidden="true">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="fw-bold mb-1">Skill Tier</div>
                            <span class="badge bg-success d-inline-flex align-items-center gap-1 px-2 py-1">Advanced</span>
                            <div class="mt-1"><small class="text-muted">Top 18% of players</small></div>
                        </div>
                        <div class="col-6">
                            <div class="fw-bold mb-1">MSP-ELO Rating</div>
                            <span class="fw-bold fs-5">847</span>
                            <small class="text-muted ms-1">#124 / 582</small>
                        </div>
                    </div>
                </div>
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                    <button
                        class="btn btn-outline-secondary bg-white btn-sm px-3 fs-sm shadow-custom"
                        data-bs-toggle="modal"
                        data-bs-target="#membersExclusiveModal"
                    >
                        <i class="ci-locked me-1"></i>
                        {{ 'membership.members_exclusive_button'|trans }}
                    </button>
                </div>
            </div>
        {% endif %}
    </div>
</div>
