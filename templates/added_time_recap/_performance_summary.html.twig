{% if logged_user.profile is not null and logged_user.profile.activeMembership %}
    {% if player.timePredictionsOptedOut %}
        <div class="card shadow-sm mb-3 border-0">
            <div class="card-body py-2 px-3">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <i class="bi bi-eye-slash text-muted" style="font-size: 1.2rem;"></i>
                    <small class="fw-medium">{{ 'puzzle_intelligence.prediction.title'|trans }}</small>
                </div>
                <small class="text-muted">
                    {{ 'puzzle_intelligence.prediction.time_predictions_opted_out'|trans }}
                    <a href="{{ path('edit_profile') }}">{{ 'statistics.change_in_settings'|trans }}</a>
                </small>
            </div>
        </div>
    {% elseif time_prediction is not null and time_prediction.predictedSeconds > 0 %}
        {% set actual_seconds = solved_puzzle.time %}
        {% set predicted = time_prediction.predictedSeconds %}
        {% set diff_percent = (((predicted - actual_seconds) / predicted) * 100)|round %}

        <div class="card shadow-sm mb-3 border-0">
            <div class="card-body text-center">
                {% if diff_percent > 5 %}
                    <div class="alert alert-success d-flex align-items-center justify-content-center py-2 mb-0">
                        <i class="bi bi-lightning-fill fs-4 me-2"></i>
                        <strong>{{ 'added_time_recap.performance.faster_than_predicted'|trans({'%percent%': diff_percent|abs}) }}</strong>
                    </div>
                {% elseif diff_percent < -5 %}
                    <div class="alert alert-info d-flex align-items-center justify-content-center py-2 mb-0">
                        <i class="bi bi-clock-history fs-4 me-2"></i>
                        <strong>{{ 'added_time_recap.performance.slower_than_predicted'|trans({'%percent%': diff_percent|abs}) }}</strong>
                    </div>
                {% else %}
                    <div class="alert alert-secondary d-flex align-items-center justify-content-center py-2 mb-0">
                        <i class="bi bi-bullseye fs-4 me-2"></i>
                        <strong>{{ 'added_time_recap.performance.on_target'|trans }}</strong>
                    </div>
                {% endif %}

                <div class="text-muted small mt-2">
                    {{ 'added_time_recap.insights.predicted_range'|trans }}:
                    {{ (time_prediction.rangeLowSeconds / 60)|round }}&ndash;{{ (time_prediction.rangeHighSeconds / 60)|round }} min
                    {% if time_prediction.isPersonalized and time_prediction.predictedAttemptNumber is not null %}
                        <br>{{ 'puzzle_intelligence.prediction.personal_attempt_explanation'|trans({'%attempt%': time_prediction.predictedAttemptNumber, '%count%': time_prediction.personalSolveCount}) }}
                    {% elseif time_prediction.isPersonalized %}
                        <br>{{ 'puzzle_intelligence.prediction.personal_explanation'|trans({'%count%': time_prediction.personalSolveCount}) }}
                    {% endif %}
                </div>
            </div>
        </div>
    {% else %}
        <div class="card shadow-sm mb-3 border-0">
            <div class="card-body">
                <div class="text-muted small">
                    <i class="bi bi-info-circle me-1"></i>
                    {% if puzzle_difficulty is null or puzzle_difficulty.difficultyScore is null %}
                        {{ 'added_time_recap.performance.prediction_unavailable_difficulty'|trans }}
                    {% else %}
                        {{ 'added_time_recap.performance.prediction_unavailable_baseline'|trans({'%pieces%': solved_puzzle.piecesCount}) }}
                    {% endif %}
                </div>
            </div>
        </div>
    {% endif %}
{% else %}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h6 class="card-title mb-3">
                <i class="bi bi-lightning me-1"></i>
                {{ 'added_time_recap.insights.predicted_range'|trans }}
            </h6>
            <div class="position-relative">
                <div style="filter: blur(5px); user-select: none;" aria-hidden="true">
                    <div class="alert alert-success d-flex align-items-center justify-content-center py-2 mb-0">
                        <i class="bi bi-lightning-fill fs-4 me-2"></i>
                        <strong>12% faster than predicted!</strong>
                    </div>
                    <div class="text-muted small mt-2 text-center">Predicted range: 45–62 min</div>
                </div>
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                    <button
                        class="btn btn-outline-secondary bg-white btn-sm px-3 fs-sm shadow-custom"
                        data-bs-toggle="modal"
                        data-bs-target="#membersExclusiveModal"
                    >
                        <i class="ci-locked me-1"></i>
                        {{ 'membership.members_exclusive_button'|trans }}
                    </button>
                </div>
            </div>
        </div>
    </div>
{% endif %}
