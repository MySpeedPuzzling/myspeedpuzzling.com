{# Solve Analysis - shown after logging a time (members only) #}
{# Variables: puzzle_difficulty, time_prediction, solved_puzzle #}

{% if logged_user.profile is not null and logged_user.profile.activeMembership and puzzle_difficulty is not null and puzzle_difficulty.difficultyScore is not null %}
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <h6 class="card-title mb-2">
                <i class="bi bi-graph-up me-1"></i>
                {{ 'puzzle_intelligence.solve_analysis.title'|trans }}
            </h6>

            <div class="row g-2 fs-sm">
                <div class="col-6">
                    <span class="text-muted">{{ 'puzzle_intelligence.solve_analysis.puzzle_difficulty'|trans }}:</span>
                    {% set tier_name = puzzle_difficulty.difficultyTier.name|lower %}
                    <span class="fw-medium">{{ ('puzzle_intelligence.difficulty.tiers.' ~ tier_name)|trans }}</span>
                    <small class="text-muted">({{ puzzle_difficulty.difficultyScore|number_format(2) }})</small>
                </div>

                {% if solved_puzzle.time is not null and time_prediction is not null %}
                    <div class="col-6">
                        <span class="text-muted">{{ 'puzzle_intelligence.solve_analysis.predicted_range'|trans }}:</span>
                        <span class="fw-medium">
                            {{ (time_prediction.rangeLowSeconds / 60)|round }}-{{ (time_prediction.rangeHighSeconds / 60)|round }}min
                        </span>
                    </div>

                    <div class="col-12">
                        {% set actual_seconds = solved_puzzle.time %}
                        {% set predicted = time_prediction.predictedSeconds %}
                        {% if predicted > 0 %}
                            {% set diff_percent = (((predicted - actual_seconds) / predicted) * 100)|round %}
                            {% if diff_percent > 5 %}
                                <div class="alert alert-success py-1 px-2 mb-0 fs-sm">
                                    <i class="bi bi-lightning me-1"></i>
                                    {{ 'puzzle_intelligence.solve_analysis.result_faster'|trans({'%percent%': diff_percent|abs}) }}
                                </div>
                            {% elseif diff_percent < -5 %}
                                <div class="alert alert-info py-1 px-2 mb-0 fs-sm">
                                    {{ 'puzzle_intelligence.solve_analysis.result_slower'|trans({'%percent%': diff_percent|abs}) }}
                                </div>
                            {% else %}
                                <div class="alert alert-secondary py-1 px-2 mb-0 fs-sm">
                                    <i class="bi bi-bullseye me-1"></i>
                                    {{ 'puzzle_intelligence.solve_analysis.result_on_target'|trans }}
                                </div>
                            {% endif %}
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endif %}
