{% from 'puzzle_intelligence/_macros.html.twig' import human_difficulty, tier_color %}

{% if logged_user.profile is not null and logged_user.profile.activeMembership and puzzle_difficulty is not null and puzzle_difficulty.difficultyScore is not null %}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h6 class="card-title mb-3">
                <i class="bi bi-graph-up me-1"></i>
                {{ 'puzzle_intelligence.solve_analysis.title'|trans }}
            </h6>

            {# Hero result — how did you do vs prediction #}
            {% if solved_puzzle.time is not null and time_prediction is not null and time_prediction.predictedSeconds > 0 %}
                {% set actual_seconds = solved_puzzle.time %}
                {% set predicted = time_prediction.predictedSeconds %}
                {% set diff_percent = (((predicted - actual_seconds) / predicted) * 100)|round %}

                {% if diff_percent > 5 %}
                    <div class="alert alert-success d-flex align-items-center py-2 mb-3">
                        <i class="bi bi-lightning-fill fs-4 me-2"></i>
                        <div>
                            <strong class="fs-5">{{ 'puzzle_intelligence.solve_analysis.result_faster'|trans({'%percent%': diff_percent|abs}) }}</strong>
                        </div>
                    </div>
                {% elseif diff_percent < -5 %}
                    <div class="alert alert-info d-flex align-items-center py-2 mb-3">
                        <i class="bi bi-clock-history fs-4 me-2"></i>
                        <div>
                            <strong>{{ 'puzzle_intelligence.solve_analysis.result_slower'|trans({'%percent%': diff_percent|abs}) }}</strong>
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-secondary d-flex align-items-center py-2 mb-3">
                        <i class="bi bi-bullseye fs-4 me-2"></i>
                        <div>
                            <strong>{{ 'puzzle_intelligence.solve_analysis.result_on_target'|trans }}</strong>
                        </div>
                    </div>
                {% endif %}
            {% endif %}

            {# Details grid #}
            <div class="row g-2 fs-sm">
                <div class="col-6">
                    <div class="text-muted mb-1">{{ 'puzzle_intelligence.solve_analysis.puzzle_difficulty'|trans }}</div>
                    {% set tier_name = puzzle_difficulty.difficultyTier.name|lower %}
                    <span class="badge bg-{{ tier_color(tier_name) }}">
                        {{ ('puzzle_intelligence.difficulty.tiers.' ~ tier_name)|trans }}
                    </span>
                    <small class="text-muted">{{ human_difficulty(puzzle_difficulty.difficultyScore) }}</small>
                </div>

                {% if time_prediction is not null %}
                    <div class="col-6">
                        <div class="text-muted mb-1">{{ 'puzzle_intelligence.solve_analysis.predicted_range'|trans }}</div>
                        <span class="fw-medium">
                            {{ (time_prediction.rangeLowSeconds / 60)|round }}-{{ (time_prediction.rangeHighSeconds / 60)|round }}min
                        </span>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endif %}
