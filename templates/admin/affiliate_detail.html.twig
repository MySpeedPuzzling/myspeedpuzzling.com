{% extends 'base.html.twig' %}

{% block title %}Affiliate: {{ affiliate.playerName ?? affiliate.code }}{% endblock %}

{% block content %}
    <div class="mb-3">
        <a href="{{ path('admin_affiliates', {tab: affiliate.status.value}) }}" class="btn btn-sm btn-outline-secondary">
            <i class="ci-arrow-left me-1"></i> Back to affiliates
        </a>
    </div>

    <div class="row gy-3">
        <div class="col-lg-8">
            {# Affiliate info card #}
            <div class="card shadow mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <h2 class="h4 mb-1">
                                <a href="{{ path('player_profile', {playerId: affiliate.playerId}) }}">
                                    {{ affiliate.playerName ?? 'Unknown' }}
                                </a>
                            </h2>
                            <p class="text-muted mb-0">
                                Code: <code class="fs-5">{{ affiliate.code }}</code>
                                &bull; Joined {{ affiliate.createdAt|ago }}
                            </p>
                        </div>
                        <div>
                            {% if affiliate.status.value == 'pending' %}
                                <span class="badge bg-warning fs-sm">Pending</span>
                            {% elseif affiliate.status.value == 'active' %}
                                <span class="badge bg-success fs-sm">Active</span>
                            {% else %}
                                <span class="badge bg-danger fs-sm">Suspended</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            {# Stats #}
            <div class="row gy-3 mb-3">
                <div class="col-sm-4">
                    <div class="card shadow text-center">
                        <div class="card-body py-3">
                            <div class="fs-4 fw-bold">{{ affiliate.supporterCount }}</div>
                            <small class="text-muted">Supporters</small>
                        </div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="card shadow text-center">
                        <div class="card-body py-3">
                            <div class="fs-4 fw-bold text-success">{{ (affiliate.totalEarnedCents / 100)|number_format(2) }}</div>
                            <small class="text-muted">Total Earned</small>
                        </div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="card shadow text-center">
                        <div class="card-body py-3">
                            <div class="fs-4 fw-bold text-warning">{{ (affiliate.pendingPayoutCents / 100)|number_format(2) }}</div>
                            <small class="text-muted">Pending Payout</small>
                        </div>
                    </div>
                </div>
            </div>

            {# Referrals #}
            <div class="card shadow mb-3">
                <div class="card-header">
                    <h3 class="h5 mb-0">Referrals ({{ referrals|length }})</h3>
                </div>
                {% if referrals is empty %}
                    <div class="card-body text-muted">No referrals yet.</div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Subscriber</th>
                                    <th>Source</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for tribute in referrals %}
                                    <tr>
                                        <td>
                                            <a href="{{ path('player_profile', {playerId: referral.subscriberId}) }}">
                                                {{ referral.subscriberName ?? 'Unknown' }}
                                            </a>
                                        </td>
                                        <td>
                                            {% if referral.source.value == 'link' %}
                                                <span class="badge bg-info">Link</span>
                                            {% elseif referral.source.value == 'code' %}
                                                <span class="badge bg-primary">Code</span>
                                            {% else %}
                                                <span class="badge bg-secondary">Manual</span>
                                            {% endif %}
                                        </td>
                                        <td>{{ referral.createdAt|ago }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>

            {# Payouts #}
            <div class="card shadow">
                <div class="card-header">
                    <h3 class="h5 mb-0">Payouts ({{ payouts|length }})</h3>
                </div>
                {% if payouts is empty %}
                    <div class="card-body text-muted">No payouts yet.</div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Subscriber</th>
                                    <th>Payment</th>
                                    <th>Payout (10%)</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for payout in payouts %}
                                    <tr>
                                        <td>
                                            <a href="{{ path('player_profile', {playerId: payout.subscriberId}) }}">
                                                {{ payout.subscriberName ?? 'Unknown' }}
                                            </a>
                                        </td>
                                        <td>{{ (payout.paymentAmountCents / 100)|number_format(2) }} {{ payout.currency }}</td>
                                        <td class="fw-bold">{{ (payout.payoutAmountCents / 100)|number_format(2) }} {{ payout.currency }}</td>
                                        <td>
                                            {% if payout.status.value == 'pending' %}
                                                <span class="badge bg-warning">Pending</span>
                                            {% else %}
                                                <span class="badge bg-success">Paid</span>
                                                {% if payout.paidAt %}
                                                    <br><small class="text-muted">{{ payout.paidAt|ago }}</small>
                                                {% endif %}
                                            {% endif %}
                                        </td>
                                        <td>{{ payout.createdAt|ago }}</td>
                                        <td>
                                            {% if payout.status.value == 'pending' %}
                                                <form method="post" action="{{ path('admin_mark_payout_paid', {payoutId: payout.payoutId, affiliateId: affiliate.affiliateId}) }}">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('mark_payout_paid') }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-success"
                                                            onclick="return confirm('Mark this payout as paid?')">
                                                        Mark paid
                                                    </button>
                                                </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>

        {# Actions sidebar #}
        <div class="col-lg-4">
            <div class="card shadow">
                <div class="card-body">
                    <h4 class="h5 mb-3">Actions</h4>

                    {% if affiliate.status.value == 'pending' %}
                        <form method="post" action="{{ path('admin_approve_affiliate', {affiliateId: affiliate.affiliateId}) }}" class="mb-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('approve_affiliate') }}">
                            <button type="submit" class="btn btn-success w-100">
                                <i class="ci-check-circle me-1"></i> Approve
                            </button>
                        </form>
                        <form method="post" action="{{ path('admin_suspend_affiliate', {affiliateId: affiliate.affiliateId}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('suspend_affiliate') }}">
                            <button type="submit" class="btn btn-outline-danger w-100"
                                    onclick="return confirm('Suspend this affiliate?')">
                                <i class="ci-close-circle me-1"></i> Reject
                            </button>
                        </form>
                    {% elseif affiliate.status.value == 'active' %}
                        <form method="post" action="{{ path('admin_suspend_affiliate', {affiliateId: affiliate.affiliateId}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('suspend_affiliate') }}">
                            <button type="submit" class="btn btn-outline-danger w-100"
                                    onclick="return confirm('Suspend this affiliate?')">
                                <i class="ci-close-circle me-1"></i> Suspend
                            </button>
                        </form>
                    {% elseif affiliate.status.value == 'suspended' %}
                        <form method="post" action="{{ path('admin_reactivate_affiliate', {affiliateId: affiliate.affiliateId}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('reactivate_affiliate') }}">
                            <button type="submit" class="btn btn-success w-100">
                                <i class="ci-check-circle me-1"></i> Reactivate
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
