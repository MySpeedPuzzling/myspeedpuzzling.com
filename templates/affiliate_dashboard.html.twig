{% extends 'base.html.twig' %}

{% block title %}{{ 'referral.dashboard.meta_title'|trans }}{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig') }}

    <h1 class="h2 mb-4">{{ 'referral.dashboard.title'|trans }}</h1>

    {% if logged_user.profile.referralProgramJoinedAt is null %}
        <div class="row">
            <div class="col-lg-7">
                <div class="card shadow">
                    <div class="card-body text-center py-5">
                        <i class="ci-heart fs-1 text-primary mb-3 d-block"></i>
                        <h2 class="h4 mb-3">{{ 'referral.dashboard.join_title'|trans }}</h2>
                        <p class="text-muted mb-4">
                            {{ 'referral.dashboard.join_description'|trans }}
                        </p>
                        {% if logged_user.profile.activeMembership %}
                            <form method="post" action="{{ path('affiliate_dashboard') }}">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="ci-heart me-1"></i> {{ 'referral.dashboard.join_button'|trans }}
                                </button>
                            </form>
                        {% else %}
                            <p class="text-muted small mb-3">{{ 'referral.dashboard.members_only'|trans }}</p>
                            <a href="{{ path('membership') }}" class="btn btn-outline-primary">
                                {{ 'referral.dashboard.become_member'|trans }}
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    {% elseif logged_user.profile.referralProgramSuspended %}
        <div class="row">
            <div class="col-lg-7">
                <div class="alert alert-warning d-flex align-items-start gap-3">
                    <i class="ci-close-circle fs-3 flex-shrink-0"></i>
                    <div>
                        <strong>{{ 'referral.dashboard.suspended_title'|trans }}</strong>
                        <p class="mb-0 mt-1">{{ 'referral.dashboard.suspended_description'|trans }}</p>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="row gy-3">
            <div class="col-lg-7">
                {# Referral link card #}
                <div class="card shadow mb-3">
                    <div class="card-body">
                        <h3 class="h5 mb-3">{{ 'referral.dashboard.your_referral_link'|trans }}</h3>

                        <div data-controller="clipboard">
                            <div class="input-group">
                                <input
                                    {{ stimulus_target('clipboard', 'input') }}
                                    value="{{ referralUrl }}"
                                    class="form-control"
                                    type="text"
                                    readonly
                                    data-action="click->clipboard#selectInputContent focus->clipboard#selectInputContent"
                                >
                                <button {{ stimulus_action('clipboard', 'copyToClipboard', 'click') }}
                                        class="btn btn-primary"
                                        type="button">
                                    <i {{ stimulus_target('clipboard', 'buttonIcon') }} class="ci-share"></i>
                                    {{ 'referral.dashboard.copy_link'|trans }}
                                </button>
                            </div>
                        </div>

                        <div class="mt-3 p-3 bg-light rounded">
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-muted small">{{ 'referral.dashboard.your_code'|trans }}:</span>
                                <code class="fs-5 fw-bold">{{ logged_user.profile.code }}</code>
                            </div>
                        </div>

                        <div class="alert alert-info small mt-3 mb-0 d-flex align-items-start gap-2">
                            <i class="bi bi-info-circle flex-shrink-0 mt-1"></i>
                            <span>{{ 'referral.dashboard.code_change_warning'|trans }}</span>
                        </div>
                    </div>
                </div>

                {# Stats cards #}
                <div class="row gy-3 mb-3">
                    <div class="col-sm-4">
                        <div class="card shadow text-center">
                            <div class="card-body py-3">
                                <div class="fs-3 fw-bold text-primary">{{ supporters.total_count }}</div>
                                <small class="text-muted">{{ 'referral.dashboard.supporters'|trans }}</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="card shadow text-center">
                            <div class="card-body py-3">
                                <div class="fs-3 fw-bold text-success">{{ (supporters.total_earned_cents / 100)|number_format(2) }}</div>
                                <small class="text-muted">{{ 'referral.dashboard.total_earned'|trans }}</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="card shadow text-center">
                            <div class="card-body py-3">
                                <div class="fs-3 fw-bold text-warning">{{ (supporters.pending_payout_cents / 100)|number_format(2) }}</div>
                                <small class="text-muted">{{ 'referral.dashboard.pending_payout'|trans }}</small>
                            </div>
                        </div>
                    </div>
                </div>

                {# Supporters list #}
                {% if supporters.total_count > 0 %}
                    <div class="card shadow">
                        <div class="card-body">
                            <h3 class="h5 mb-3">
                                {{ 'referral.dashboard.your_supporters'|trans }}
                                <span class="badge bg-primary ms-1">{{ supporters.total_count }}</span>
                            </h3>

                            {% if supporters.public_supporters|length < supporters.total_count %}
                                <p class="text-muted small mb-2">
                                    {{ 'referral.dashboard.supporters_privacy_note'|trans({'%total%': supporters.total_count, '%shown%': supporters.public_supporters|length}) }}
                                </p>
                            {% endif %}

                            <div class="list-group list-group-flush">
                                {% for supporter in supporters.public_supporters %}
                                    <a href="{{ path('player_profile', {playerId: supporter.player_id}) }}"
                                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 px-0">
                                        {% if supporter.player_avatar %}
                                            <img src="{{ supporter.player_avatar|thumbnail('avatar_small') }}"
                                                 class="rounded-circle"
                                                 width="32" height="32"
                                                 alt="">
                                        {% else %}
                                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                                <i class="ci-user text-muted"></i>
                                            </div>
                                        {% endif %}
                                        <div class="flex-grow-1">
                                            <span class="fw-medium">{{ supporter.player_name ?? 'Secret Puzzler' }}</span>
                                        </div>
                                        <small class="text-muted">{{ supporter.created_at|date('Y-m-d')|ago }}</small>
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>

            <div class="col-lg-4 offset-lg-1">
                <div class="card border-0 bg-light">
                    <div class="card-body">
                        <h4 class="h6 mb-3">{{ 'referral.dashboard.how_it_works_title'|trans }}</h4>
                        <ul class="list-unstyled mb-0">
                            <li class="d-flex gap-2 mb-2">
                                <span class="badge bg-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 24px; height: 24px;">1</span>
                                <small>{{ 'referral.dashboard.how_it_works_step1'|trans }}</small>
                            </li>
                            <li class="d-flex gap-2 mb-2">
                                <span class="badge bg-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 24px; height: 24px;">2</span>
                                <small>{{ 'referral.dashboard.how_it_works_step2'|trans }}</small>
                            </li>
                            <li class="d-flex gap-2">
                                <span class="badge bg-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 24px; height: 24px;">3</span>
                                <small>{{ 'referral.dashboard.how_it_works_step3'|trans }}</small>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
