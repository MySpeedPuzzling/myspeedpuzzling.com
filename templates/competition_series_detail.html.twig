{% extends 'base.html.twig' %}

{% block title %}{{ series.name }}{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig', {fallbackUrl: path('events'), fallbackTitle: 'events.title'|trans}) }}

    <div class="d-flex">
        <div class="flex-fill">
            <h1 class="h4 mb-2">
                {{ series.name }}
            </h1>

            <div class="row">
                <div class="col-sm-6">
                    {% if series.isOnline %}
                        <span class="badge bg-info text-dark">{{ 'competition.online'|trans }}</span>
                    {% else %}
                        {% if series.locationCountryCode %}
                            <span class="shadow-custom fi fi-{{ series.locationCountryCode.name }} me-2"></span>
                        {% endif %}
                        {{ series.location }}
                    {% endif %}
                    <span class="badge bg-secondary ms-1">{{ 'competition.recurring'|trans }}</span>
                </div>

                {% if series.link %}
                    <div class="col-sm-6 mt-2 mt-sm-0">
                        <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ series.link }}">
                            <i class="bi bi-info-circle me-1"></i>{{ 'events.website_link'|trans }}
                        </a>
                    </div>
                {% endif %}
            </div>

            {% if series.description %}
                <p class="mt-3">{{ series.description }}</p>
            {% endif %}
        </div>

        <div class="ms-3 flex-shrink-0 event-image">
            {% if series.logo %}
                <img style="max-height: 84px;" src="{{ series.logo|thumbnail('puzzle_small') }}" alt="{{ series.name }} logo" class="img-fluid">
            {% endif %}
        </div>
    </div>

    {% if upcoming_editions|length > 0 %}
        <h2 class="h5 mt-4 mb-3">{{ 'series.upcoming_editions'|trans }}</h2>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>{{ 'competition.round.name'|trans }}</th>
                        <th>{{ 'events.edition_date'|trans }}</th>
                        <th>{{ 'competition.round.minutes_limit'|trans }}</th>
                        <th>{{ 'competition.round.puzzles'|trans }}</th>
                        <th>{{ 'competition.manage_participants'|trans }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for edition in upcoming_editions %}
                        <tr>
                            <td>
                                <a href="{{ path('edition_detail', {'competitionId': edition.competitionId}) }}" class="text-decoration-underline">
                                    {{ edition.name }}
                                </a>
                            </td>
                            <td>{{ edition.startsAt|date('d.m.Y H:i') }}</td>
                            <td>{{ edition.minutesLimit }} min</td>
                            <td>{{ edition.puzzleCount }}</td>
                            <td>{{ edition.participantCount }}</td>
                            <td>
                                {% if edition.registrationLink %}
                                    <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ edition.registrationLink }}">
                                        <i class="bi bi-person-plus me-1"></i>{{ 'events.registration_link'|trans }}
                                    </a>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if past_editions|length > 0 %}
        <h2 class="h5 mt-4 mb-3">{{ 'series.past_editions'|trans }}</h2>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>{{ 'competition.round.name'|trans }}</th>
                        <th>{{ 'events.edition_date'|trans }}</th>
                        <th>{{ 'competition.round.minutes_limit'|trans }}</th>
                        <th>{{ 'competition.round.puzzles'|trans }}</th>
                        <th>{{ 'competition.manage_participants'|trans }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for edition in past_editions %}
                        <tr>
                            <td>
                                <a href="{{ path('edition_detail', {'competitionId': edition.competitionId}) }}" class="text-decoration-underline">
                                    {{ edition.name }}
                                </a>
                            </td>
                            <td>{{ edition.startsAt|date('d.m.Y H:i') }}</td>
                            <td>{{ edition.minutesLimit }} min</td>
                            <td>{{ edition.puzzleCount }}</td>
                            <td>{{ edition.participantCount }}</td>
                            <td>
                                {% if edition.resultsLink %}
                                    <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ edition.resultsLink }}">
                                        <i class="bi bi-trophy me-1"></i>{{ 'events.results_link'|trans }}
                                    </a>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if upcoming_editions|length == 0 and past_editions|length == 0 %}
        <p class="text-muted mt-4">{{ 'series.no_editions'|trans }}</p>
    {% endif %}
{% endblock %}
