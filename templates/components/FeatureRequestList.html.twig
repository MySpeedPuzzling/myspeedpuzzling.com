<div {{ attributes }}>
    {# Filter & Sort Bar #}
    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
        {# Status filter tabs #}
        <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'feature_requests.filter.all_statuses'|trans }}" style="font-size: 0.75rem;">
            <input type="radio" class="btn-check" name="status-filter" id="status-filter-all" value="" data-model="status" {{ this.status == '' ? 'checked' }}>
            <label class="btn btn-outline-secondary text-nowrap" for="status-filter-all">{{ 'feature_requests.filter.all_statuses'|trans }}</label>

            <input type="radio" class="btn-check" name="status-filter" id="status-filter-open" value="open" data-model="status" {{ this.status == 'open' ? 'checked' }}>
            <label class="btn btn-outline-secondary text-nowrap" for="status-filter-open">{{ 'feature_requests.status.open'|trans }}</label>

            <input type="radio" class="btn-check" name="status-filter" id="status-filter-completed" value="completed" data-model="status" {{ this.status == 'completed' ? 'checked' }}>
            <label class="btn btn-outline-secondary text-nowrap" for="status-filter-completed">{{ 'feature_requests.status.completed'|trans }}</label>

            <input type="radio" class="btn-check" name="status-filter" id="status-filter-declined" value="declined" data-model="status" {{ this.status == 'declined' ? 'checked' }}>
            <label class="btn btn-outline-secondary text-nowrap" for="status-filter-declined">{{ 'feature_requests.status.declined'|trans }}</label>
        </div>

        {# My Requests toggle #}
        {% if logged_user.profile is not null and logged_user.profile.activeMembership %}
            <div class="form-check mb-0">
                <input
                    type="checkbox"
                    data-model="my"
                    class="form-check-input"
                    id="myRequestsFilter"
                    {{ this.my ? 'checked' }}
                >
                <label class="form-check-label small" for="myRequestsFilter">
                    <i class="bi bi-person me-1"></i>{{ 'feature_requests.filter.my_requests'|trans }}
                </label>
            </div>
        {% endif %}

        {# Sort dropdown #}
        <div class="ms-auto">
            <select data-model="sort" class="form-select form-select-sm" style="width: auto;">
                <option value="most_votes" {{ this.sort == 'most_votes' ? 'selected' }}>{{ 'feature_requests.sort.most_votes'|trans }}</option>
                <option value="least_votes" {{ this.sort == 'least_votes' ? 'selected' }}>{{ 'feature_requests.sort.least_votes'|trans }}</option>
                <option value="newest" {{ this.sort == 'newest' ? 'selected' }}>{{ 'feature_requests.sort.newest'|trans }}</option>
                <option value="oldest" {{ this.sort == 'oldest' ? 'selected' }}>{{ 'feature_requests.sort.oldest'|trans }}</option>
            </select>
        </div>
    </div>

    {# Feature Requests List #}
    {% set items = this.items %}
    {% if items is empty %}
        <div class="text-center text-muted py-5">
            <i class="bi bi-lightbulb" style="font-size: 3rem;"></i>
            <p class="mt-3">{{ 'feature_requests.no_requests_yet'|trans }}</p>
        </div>
    {% else %}
        <div class="d-flex flex-column gap-3">
            {% for fr in items %}
                {% set is_mine = logged_user.profile is not null and logged_user.profile.playerId == fr.authorId %}
                {% set is_open = fr.status.value == 'open' %}
                <div class="card shadow-sm {% if is_mine and is_open %}border-primary border-opacity-50{% elseif fr.status.value == 'completed' %}border-success border-opacity-50{% elseif fr.status.value == 'in_progress' %}border-info border-opacity-50{% elseif fr.status.value == 'declined' %}border-secondary border-opacity-25{% endif %}">
                    <div class="card-body {{ fr.status.value == 'declined' ? 'opacity-75' : '' }}">
                        <div class="d-flex align-items-start gap-3">
                            <div class="d-flex flex-column align-items-center flex-shrink-0" style="min-width: 52px;">
                                {% if not is_open %}
                                    <div class="btn btn-outline-secondary btn-sm d-flex flex-column align-items-center py-1 px-2" style="pointer-events: none; min-width: 44px;">
                                        <i class="bi bi-caret-up-fill" style="font-size: 1rem; line-height: 1;"></i>
                                        <span class="fw-bold" style="font-size: 0.95rem; line-height: 1.2;">{{ fr.voteCount }}</span>
                                    </div>
                                {% elseif logged_user.profile is not null and logged_user.profile.activeMembership %}
                                    {% if is_mine %}
                                        <div class="btn btn-outline-secondary btn-sm d-flex flex-column align-items-center py-1 px-2" style="pointer-events: none; min-width: 44px;">
                                            <i class="bi bi-caret-up-fill" style="font-size: 1rem; line-height: 1;"></i>
                                            <span class="fw-bold" style="font-size: 0.95rem; line-height: 1.2;">{{ fr.voteCount }}</span>
                                        </div>
                                    {% elseif this.votesUsedThisMonth < 3 %}
                                        <form method="post" action="{{ path('feature_request_vote', {'featureRequestId': fr.id}) }}" data-turbo="false">
                                            <button type="submit" class="btn btn-outline-primary btn-sm d-flex flex-column align-items-center py-1 px-2" style="min-width: 44px;">
                                                <i class="bi bi-caret-up-fill" style="font-size: 1rem; line-height: 1;"></i>
                                                <span class="fw-bold" style="font-size: 0.95rem; line-height: 1.2;">{{ fr.voteCount }}</span>
                                                <span style="font-size: 0.6rem; line-height: 1; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'feature_requests.vote_button'|trans }}</span>
                                            </button>
                                        </form>
                                    {% else %}
                                        <div class="btn btn-outline-secondary btn-sm d-flex flex-column align-items-center py-1 px-2 disabled" style="min-width: 44px;" title="{{ 'feature_requests.vote_limit_reached'|trans }}">
                                            <i class="bi bi-caret-up-fill" style="font-size: 1rem; line-height: 1;"></i>
                                            <span class="fw-bold" style="font-size: 0.95rem; line-height: 1.2;">{{ fr.voteCount }}</span>
                                        </div>
                                    {% endif %}
                                {% else %}
                                    <button class="btn btn-outline-secondary btn-sm d-flex flex-column align-items-center py-1 px-2" style="min-width: 44px;" data-bs-toggle="modal" data-bs-target="#membersExclusiveModal">
                                        <i class="bi bi-caret-up-fill" style="font-size: 1rem; line-height: 1;"></i>
                                        <span class="fw-bold" style="font-size: 0.95rem; line-height: 1.2;">{{ fr.voteCount }}</span>
                                        <span style="font-size: 0.6rem; line-height: 1; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'feature_requests.vote_button'|trans }}</span>
                                    </button>
                                {% endif %}
                            </div>

                            <div class="flex-grow-1 min-width-0">
                                <a href="{{ path('feature_request_detail', {'featureRequestId': fr.id}) }}" class="text-decoration-none text-body">
                                    <h5 class="mb-1">
                                        {{ fr.title }}
                                        {% if fr.status.value == 'in_progress' %}
                                            <span class="badge bg-info bg-opacity-10 text-info ms-1" style="font-size: 0.65rem; vertical-align: middle;">{{ 'feature_requests.status.in_progress'|trans }}</span>
                                        {% elseif fr.status.value == 'completed' %}
                                            <span class="badge bg-success bg-opacity-10 text-success ms-1" style="font-size: 0.65rem; vertical-align: middle;">{{ 'feature_requests.status.completed'|trans }}</span>
                                        {% elseif fr.status.value == 'declined' %}
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary ms-1" style="font-size: 0.65rem; vertical-align: middle;">{{ 'feature_requests.status.declined'|trans }}</span>
                                        {% endif %}
                                        {% if is_mine %}
                                            <span class="badge bg-primary bg-opacity-10 text-primary ms-1" style="font-size: 0.65rem; vertical-align: middle;">{{ 'feature_requests.yours'|trans }}</span>
                                        {% endif %}
                                    </h5>
                                    <p class="text-muted small mb-0">{{ fr.description|length > 200 ? fr.description|slice(0, 200) ~ '...' : fr.description }}</p>
                                </a>
                                {% if fr.adminComment %}
                                    <div class="small text-muted mt-1 fst-italic">
                                        <i class="bi bi-chat-square-text me-1"></i>{{ fr.adminComment|length > 100 ? fr.adminComment|slice(0, 100) ~ '...' : fr.adminComment }}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="d-flex align-items-center flex-wrap gap-2 small text-muted mt-2 pt-2 border-top">
                            {{ include('messaging/_avatar.html.twig', {avatar: fr.authorAvatar, size: 20}) }}
                            <span>{{ fr.authorName }}</span>
                            <span>&middot;</span>
                            <span>{{ fr.createdAt|ago }}</span>
                            <span>&middot;</span>
                            <span><i class="bi bi-chat-dots me-1"></i>{{ fr.commentCount }}</span>
                            {% if fr.githubUrl %}
                                <span>&middot;</span>
                                <a href="{{ fr.githubUrl }}" target="_blank" rel="noopener" class="text-muted"><i class="bi bi-github"></i></a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
