<div {{ attributes }}>
    {% if logged_user.profile is not null and logged_user.profile.activeMembership %}
        {% if eloRatings is not empty %}
            {% for pc, data in eloRatings %}
                <div class="d-flex align-items-center gap-2" style="line-height: 1.3;">
                    <span class="h5 mb-0 fw-bold" style="font-family: monospace;">#{{ data.rank }}</span>
                    <span class="text-muted">&middot;</span>
                    <span class="fw-bold" style="font-family: monospace;">{{ data.elo_rating }} ELO</span>
                    <small class="text-muted ms-1">{{ 'puzzle_intelligence.elo.ranked_out_of'|trans({'%total%': data.total}) }}</small>
                </div>
            {% endfor %}

        {% elseif isOwnProfile %}
            {# Own profile, not ranked — show progress #}
            <div class="text-muted fs-sm mb-2">{{ 'puzzle_intelligence.elo.not_ranked_yet'|trans }}</div>

            {% if eloProgress is not null %}
                <div class="card bg-light border-0">
                    <div class="card-body py-2">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span class="text-muted fs-sm" style="min-width: 110px;">{{ 'puzzle_intelligence.elo.progress_first_attempts'|trans }}</span>
                            <div class="progress flex-grow-1" style="height: 6px;">
                                {% set fa_pct = (eloProgress.first_attempts / 15 * 100) > 100 ? 100 : (eloProgress.first_attempts / 15 * 100) %}
                                <div class="progress-bar bg-info" style="width: {{ fa_pct }}%;"></div>
                            </div>
                            <small class="text-muted fw-medium">{{ eloProgress.first_attempts }}/15</small>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted fs-sm" style="min-width: 110px;">{{ 'puzzle_intelligence.elo.progress_total_solves'|trans }}</span>
                            <div class="progress flex-grow-1" style="height: 6px;">
                                {% set ts_pct = (eloProgress.total_solves / 50 * 100) > 100 ? 100 : (eloProgress.total_solves / 50 * 100) %}
                                <div class="progress-bar bg-primary" style="width: {{ ts_pct }}%;"></div>
                            </div>
                            <small class="text-muted fw-medium">{{ eloProgress.total_solves }}/50</small>
                        </div>
                    </div>
                </div>
            {% endif %}

        {% else %}
            <div class="text-muted fs-sm">{{ 'puzzle_intelligence.elo.not_ranked_yet'|trans }}</div>
        {% endif %}
    {% else %}
        {# Members-only CTA #}
        <div class="position-relative">
            <div class="text-muted fs-sm" style="filter: blur(4px);">
                <span class="badge badge-skill-expert me-1">500pc: 1247</span>
            </div>
            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background: rgba(255,255,255,0.8); border-radius: inherit;">
                <button
                    class="btn btn-outline-secondary bg-white btn-sm px-3 fs-sm shadow-custom"
                    data-bs-toggle="modal"
                    data-bs-target="#membersExclusiveModal"
                >
                    <svg class="rank-icon me-1" width="16" height="16" style="color: var(--rank-locked)"><use href="/rank-icons-sprite.svg#rank-locked"/></svg>
                    {{ 'puzzle_intelligence.difficulty.members_only'|trans }}
                </button>
            </div>
        </div>
    {% endif %}
</div>
