<div {{ attributes }}>
    {% if eloRatings is not empty %}
        {% for pc, data in eloRatings %}
            <div class="d-flex align-items-center gap-2" style="line-height: 1.3;">
                <small class="text-muted">{{ 'puzzle_intelligence.elo.profile_title'|trans }}</small>
                <span class="fw-bold" style="font-family: monospace;">#{{ data.rank }}</span>
                <span class="text-muted">&middot;</span>
                <span class="fw-bold" style="font-family: monospace;">{{ data.elo_rating }} ELO</span>
                <small class="text-muted">({{ 'puzzle_intelligence.elo.ranked_out_of'|trans({'%total%': data.total}) }})</small>
            </div>
        {% endfor %}
    {% elseif isOwnProfile %}
        <div class="text-muted fs-sm">{{ 'puzzle_intelligence.elo.not_ranked_yet'|trans }}</div>

        {% if eloProgress is not null %}
            <div class="d-flex align-items-center gap-2 mt-1 fs-sm">
                <span class="text-muted">{{ 'puzzle_intelligence.elo.progress_first_attempts'|trans }}</span>
                <small class="text-muted fw-medium">{{ eloProgress.first_attempts }}/15</small>
                <span class="text-muted ms-2">{{ 'puzzle_intelligence.elo.progress_total_solves'|trans }}</span>
                <small class="text-muted fw-medium">{{ eloProgress.total_solves }}/50</small>
            </div>
        {% endif %}
    {% endif %}
</div>
