{% from 'puzzle_intelligence/_macros.html.twig' import percentile_bar, skill_badge %}

<div {{ attributes }}>
    {% if logged_user.profile is not null and logged_user.profile.activeMembership %}
        {% if skills is not empty %}
            {% for skill in skills %}
                {% set t_name = skill.skillTier.name|lower %}
                {% set top_percentile = (100 - skill.skillPercentile)|number_format(1) %}

                <div class="card shadow-sm {{ not loop.first ? 'mt-2' : '' }}">
                    <div class="card-body py-2 px-3">
                        {# Header: icon + badge left, category right #}
                        <div class="d-flex align-items-center justify-content-between mb-1">
                            <div class="d-flex align-items-center gap-2">
                                <svg class="rank-icon flex-shrink-0" width="32" height="32" style="color: var(--rank-{{ t_name }})"><use href="/rank-icons-sprite.svg#rank-{{ t_name }}"/></svg>
                                {{ skill_badge(t_name, 'fs-6') }}
                            </div>
                            <small class="text-muted">{{ 'pieces_count'|trans({ '%count%': skill.piecesCount })|raw }}</small>
                        </div>

                        {# Percentile + bar #}
                        <div class="d-flex align-items-center justify-content-between mb-1">
                            <span class="fw-bold text-skill-{{ t_name }}">
                                {{ 'puzzle_intelligence.skill.percentile_label'|trans({'%percentile%': top_percentile}) }}
                            </span>
                            <small class="text-muted">
                                {{ 'puzzle_intelligence.skill.faster_than_label'|trans({'%percentile%': skill.skillPercentile|number_format(1)}) }}
                            </small>
                        </div>
                        {{ percentile_bar(skill.skillPercentile, t_name) }}

                        {# Next tier — single compact line #}
                        {% set next_tier = skill.skillTier.nextTier %}
                        {% if next_tier is not null %}
                            {% set next_name = next_tier.name|lower %}
                            {% set gap = ((next_tier.minimumPercentile - skill.skillPercentile)|round(1))|abs %}
                            <div class="d-flex align-items-center justify-content-between mt-1">
                                <small class="text-muted d-flex align-items-center gap-1">
                                    <i class="bi bi-arrow-up-circle"></i>
                                    {{ 'puzzle_intelligence.skill.next_tier'|trans }}
                                    <svg class="rank-icon" width="14" height="14" style="color: var(--rank-{{ next_name }})"><use href="/rank-icons-sprite.svg#rank-{{ next_name }}"/></svg>
                                    {{ ('puzzle_intelligence.skill.tiers.' ~ next_name)|trans }}
                                </small>
                                <small class="text-muted">{{ 'puzzle_intelligence.skill.next_tier_gap'|trans({'%gap%': gap|number_format(1)}) }}</small>
                            </div>
                        {% else %}
                            <div class="mt-1">
                                <small class="text-skill-legend d-flex align-items-center gap-1">
                                    <svg class="rank-icon" width="14" height="14" style="color: var(--rank-legend)"><use href="/rank-icons-sprite.svg#rank-legend"/></svg>
                                    {{ 'puzzle_intelligence.skill.highest_tier_reached'|trans }}
                                </small>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}

            {# Improvement chart #}
            {% if improvementChart is not null %}
                <h6 class="fs-sm text-muted mb-2 mt-3 d-flex align-items-center gap-1">
                    <i class="bi bi-graph-up" style="font-size: 1.1em;"></i>
                    {{ 'puzzle_intelligence.skill.improvement_title'|trans }}
                </h6>
                <div style="height: 220px;">
                    {{ render_chart(improvementChart) }}
                </div>
            {% endif %}
        {% else %}
            {# No skill tiers yet — show progress #}
            {% if progress is not empty %}
                <p class="text-muted fs-sm mb-2">{{ 'puzzle_intelligence.skill.not_enough_data'|trans({'%pieces%': selectedPiecesCount}) }}</p>
                {% for pc, data in progress %}
                    <div class="card bg-light border-0 mb-2">
                        <div class="card-body py-2">
                            <div class="fw-medium mb-1">{{ 'pieces_count'|trans({ '%count%': pc })|raw }}</div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="text-muted fs-sm" style="min-width: 140px;">{{ 'puzzle_intelligence.prediction.not_available'|trans({'%count%': (5 - data.baseline_solves) > 0 ? (5 - data.baseline_solves) : 0, '%pieces%': pc}) }}</span>
                                <div class="progress flex-grow-1" style="height: 6px;">
                                    {% set baseline_pct = (data.baseline_solves / 5 * 100) > 100 ? 100 : (data.baseline_solves / 5 * 100) %}
                                    <div class="progress-bar bg-info" style="width: {{ baseline_pct }}%;"></div>
                                </div>
                                <small class="text-muted">{{ data.baseline_solves }}/5</small>
                            </div>
                            {% if data.baseline_solves >= 5 %}
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-muted fs-sm" style="min-width: 140px;">{{ 'puzzle_intelligence.skill.need_more_puzzles'|trans({'%count%': (10 - data.qualifying_puzzles) > 0 ? (10 - data.qualifying_puzzles) : 0}) }}</span>
                                    <div class="progress flex-grow-1" style="height: 6px;">
                                        {% set qual_pct = (data.qualifying_puzzles / 10 * 100) > 100 ? 100 : (data.qualifying_puzzles / 10 * 100) %}
                                        <div class="progress-bar bg-primary" style="width: {{ qual_pct }}%;"></div>
                                    </div>
                                    <small class="text-muted">{{ data.qualifying_puzzles }}/10</small>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div class="text-muted fs-sm">
                    {{ 'puzzle_intelligence.skill.not_enough_data'|trans({'%pieces%': selectedPiecesCount}) }}
                </div>
            {% endif %}
        {% endif %}
    {% endif %}
</div>
