{% from 'puzzle_intelligence/_macros.html.twig' import skill_icon %}
<div {{ attributes }} data-loading="addClass(opacity-50)">
    <div class="puzzle-category-types mt-3 my-2">
        <button
            class="btn {{ this.category == 'solo' ? 'active' }} {{ this.soloTimesCount == 0 ? 'disabled'}}"
            data-action="live#action"
            data-live-action-param="changeResultsCategory"
            data-live-category-param="solo"
        >
            <span class="users-icons"><i class="ci-user"></i></span>
            {{ 'ladder.solo'|trans }} ({{ this.soloTimesCount }})
        </button>

        <button
            class="btn {{ this.category == 'duo' ? 'active' }} {{ this.duoTimesCount == 0 ? 'disabled'}}"
            data-action="live#action"
            data-live-action-param="changeResultsCategory"
            data-live-category-param="duo"
        >
            <span class="users-icons duo"><i class="ci-user"></i><i class="ci-user"></i></span>
            {{ 'ladder.duo'|trans }} ({{ this.duoTimesCount }})
        </button>

        <button
            class="btn {{ this.category == 'group' ? 'active' }} {{ this.groupTimesCount == 0 ? 'disabled'}}"
            data-action="live#action"
            data-live-action-param="changeResultsCategory"
            data-live-category-param="group"
        >
            <span class="users-icons team"><i class="ci-user"></i><i class="ci-user"></i><i class="ci-user"></i><i class="ci-user"></i></span>
            {{ 'ladder.team'|trans }} ({{ this.groupTimesCount }})
        </button>
    </div>

    {% if logged_user.profile is not null and this.myAttempts|length > 0 %}
        {% set myLast = this.myLastAttempt %}
        {% set myBest = this.myFastestAttempt %}
        {% set attemptsCount = this.myAttempts|length %}
        {% set isNewPb = attemptsCount > 1 and myLast.time == myBest.time %}
        {% set collapseId = 'my-attempts-collapse-' ~ this.category %}

        <div class="card border-0 shadow-sm mt-3 mb-2">
            <div class="card-body py-2 px-3 fs-sm">
                {% if attemptsCount == 1 %}
                    <div>
                        <span class="text-muted">{{ 'puzzle_times.my_attempts.my_time'|trans }}</span>
                        <span class="font-monospace">{{ myLast.time|puzzlingTime }}</span>
                        {{ include('_edit_time_button.html.twig', {timeId: myLast.timeId, context: 'puzzle-detail'}) }}
                    </div>
                {% else %}
                    <div>
                        <span class="text-muted">{{ 'puzzle_times.my_attempts.latest_time'|trans }}</span>
                        <span class="font-monospace">{{ myLast.time|puzzlingTime }}</span>
                        {% if myLast.finishedAt is not null %}
                            <span class="text-muted">({{ myLast.finishedAt|date('d.m.Y') }})</span>
                        {% endif %}
                    </div>
                    {% if isNewPb %}
                        <div class="text-success">
                            <i class="bi bi-star-fill text-warning me-1"></i>
                            {{ 'puzzle_times.my_attempts.latest_is_fastest_note'|trans }}
                        </div>
                    {% else %}
                        <div>
                            <span class="text-muted">{{ 'puzzle_times.my_attempts.fastest_time'|trans }}</span>
                            <span class="font-monospace">{{ myBest.time|puzzlingTime }}</span>
                            {% if myBest.finishedAt is not null %}
                                <span class="text-muted">({{ myBest.finishedAt|date('d.m.Y') }})</span>
                            {% endif %}
                            <i class="bi bi-star-fill text-warning ms-1"></i>
                        </div>
                    {% endif %}
                {% endif %}

                {% if this.myRank %}
                    <div class="text-muted mt-1">
                        {{ 'puzzle_times.my_attempts.rank'|trans({'%rank%': this.myRank, '%total%': this.times|length}) }}
                    </div>
                {% endif %}

                {% if attemptsCount >= 2 %}
                    <div class="text-center mt-2">
                        <button
                            class="btn btn-link btn-sm p-0 fs-sm text-decoration-none collapsed my-attempts-toggle"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#{{ collapseId }}"
                            aria-expanded="false"
                            aria-controls="{{ collapseId }}"
                        >
                            {{ 'puzzle_times.my_attempts.show_all'|trans({'%count%': attemptsCount}) }}
                            <i class="bi bi-chevron-down ms-1 collapse-chevron"></i>
                        </button>
                    </div>

                    <div class="collapse mt-2" id="{{ collapseId }}">
                        <div class="attempts-history-list">
                            {% for row in this.myAttemptsWithContext %}
                                <div class="attempts-history-entry {% if not loop.first %}border-top pt-2 mt-2{% endif %}">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>
                                            <i class="bi bi-calendar3 text-muted me-1"></i>
                                            {% if row.attempt.finishedAt is not null %}
                                                <span class="font-monospace">{{ row.attempt.finishedAt|date('d.m.Y') }}</span>
                                            {% else %}
                                                <span class="text-muted">&mdash;</span>
                                            {% endif %}
                                        </span>
                                        <span>
                                            {% if row.isBest %}
                                                <i class="bi bi-star-fill text-warning me-1" style="font-size: 0.75rem;"></i>
                                            {% endif %}
                                            <i class="bi bi-stopwatch text-muted me-1"></i>
                                            <span class="font-monospace">{{ row.attempt.time|puzzlingTime }}</span>
                                            {{ include('_edit_time_button.html.twig', {timeId: row.attempt.timeId, context: 'puzzle-detail'}) }}
                                        </span>
                                    </div>

                                    {% set showPrevDelta = row.prevTime is not null %}
                                    {% set showBestDelta = not row.isBest and myBest.time is not null and row.attempt.time is not null %}

                                    {% if showPrevDelta or showBestDelta %}
                                        <div class="fs-xs text-end mt-1" style="padding-right: 28px;">
                                            {% if showPrevDelta %}
                                                {% set delta = row.attempt.time - row.prevTime %}
                                                <div>
                                                    <i class="bi bi-arrow-return-left text-muted me-1"></i>
                                                    {% if delta < 0 %}
                                                        <span class="text-success font-monospace">-{{ (delta|abs)|puzzlingTime }}</span>
                                                    {% elseif delta > 0 %}
                                                        <span class="text-danger font-monospace">+{{ delta|puzzlingTime }}</span>
                                                    {% else %}
                                                        <span class="text-muted font-monospace">+00:00:00</span>
                                                    {% endif %}
                                                </div>
                                            {% endif %}

                                            {% if showBestDelta %}
                                                {% set delta_best = row.attempt.time - myBest.time %}
                                                <div>
                                                    <i class="bi bi-star text-muted me-1" style="font-size: 0.7rem;"></i>
                                                    <span class="text-danger font-monospace">+{{ delta_best|puzzlingTime }}</span>
                                                </div>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>

                        {% if logged_user.profile.activeMembership %}
                            <twig:Chart:PlayerPuzzleTimesChart :results="this.myAttempts" bare="true" />
                        {% else %}
                            <div class="player-chart-placeholder text-center mt-3">
                                <button
                                    class="btn btn-outline-secondary bg-white btn-sm px-3 fs-sm mt-5 shadow-custom"
                                    data-bs-toggle="modal"
                                    data-bs-target="#membersExclusiveModal"
                                >
                                    <i class="ci-locked me-1"></i>
                                    {{ 'membership.members_exclusive_button'|trans }}
                                </button>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

    {% endif %}

    <div class="d-flex align-content-between justify-content-between mt-3">
        <div class="fs-sm">
            {% if this.times|length > 1 %}
                {% if this.medianTime %}
                    <span class="d-inline-flex align-items-center gap-1">
                        <svg class="stat-icon" width="18" height="18"><use href="/stat-icons-sprite.svg#stat-med"/></svg>
                        {{ 'median_time'|trans }}
                        <span class="font-monospace">{{ this.medianTime|puzzlingTime }}</span>
                    </span>
                {% endif %}

                {% if this.averageTime %}
                    <br>
                    <span class="d-inline-flex align-items-center gap-1">
                        <svg class="stat-icon" width="18" height="18"><use href="/stat-icons-sprite.svg#stat-avg"/></svg>
                        {{ 'average_time'|trans }}
                        <span class="font-monospace">{{ this.averageTime|puzzlingTime }}</span>
                    </span>
                {% endif %}
            {% endif %}

            {% set categoryRelaxCount = this.category == 'solo' ? this.soloRelaxCount : (this.category == 'duo' ? this.duoRelaxCount : this.groupRelaxCount) %}
            {% if categoryRelaxCount > 0 %}
                <br><small class="text-muted">
                    <i class="bi bi-cup-hot"></i> {{ 'puzzle.relax_solvings_count'|trans({'%count%': categoryRelaxCount}) }}
                </small>
            {% endif %}
        </div>

        {% if this.activeFiltersCount > 0 or this.availableCountries|length > 1 or (this.category == 'solo' and this.times|length > 1) %}
            <div class="dropdown position-relative">
                {% if logged_user.profile is not null and logged_user.profile.activeMembership %}
                    <button
                        class="btn btn-outline-primary btn-sm dropdown-toggle"
                        type="button"
                        id="filtersDropdown"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                    >
                        <i class="bi-filter"></i>
                        {{ 'filters.button'|trans }}
                        {% if this.activeFiltersCount > 0 %}<sup>{{ this.activeFiltersCount }}</sup>{% endif%}
                    </button>

                    <div class="dropdown-menu dropdown-menu-end filters px-3 py-0" aria-labelledby="filtersDropdown">
                        {% if this.category == 'solo' and (this.times|length > 1 or this.onlyFirstTries or this.onlyUnboxed) %}
                            <div class="form-check form-switch my-3">
                                <input
                                    data-model="onlyFirstTries"
                                    type="checkbox"
                                    class="form-check-input"
                                    role="switch"
                                    id="only-first-attempt"
                                    {{ this.onlyFirstTries ? 'checked' }}>
                                <label for="only-first-attempt" class="form-check-label" onclick="arguments[0].stopPropagation()">{{ 'only_first_tries_filter'|trans }}</label>
                            </div>

                            <div class="form-check form-switch my-3">
                                <input
                                    data-model="onlyUnboxed"
                                    type="checkbox"
                                    class="form-check-input"
                                    role="switch"
                                    id="only-unboxed"
                                    {{ this.onlyUnboxed ? 'checked' }}>
                                <label for="only-unboxed" class="form-check-label" onclick="arguments[0].stopPropagation()">{{ 'only_unboxed_filter'|trans }}</label>
                            </div>
                        {% endif %}

                        {% if logged_user.profile.favoritePlayers|length > 0 %}
                            <div class="form-check form-switch my-3">
                                <input
                                    data-model="onlyFavoritePlayers"
                                    type="checkbox"
                                    class="form-check-input"
                                    role="switch"
                                    id="only-favorite-players"
                                    {{ this.onlyFavoritePlayers ? 'checked' }}>
                                <label for="only-favorite-players" class="form-check-label" onclick="arguments[0].stopPropagation()">{{ 'only_favorite_players_filter'|trans }}</label>
                            </div>
                        {% endif %}

                        {% if this.availableCountries|length > 1 %}
                            <div class="my-3">
                                <select
                                    data-model="country"
                                    class="form-select"
                                    data-controller="country-autocomplete symfony--ux-autocomplete--autocomplete">
                                    <option value="" data-icon="" {{ this.country == null ? 'selected' }}>{{ 'forms.country_all'|trans }}</option>
                                    {% for availableCountry in this.countries %}
                                        <option
                                            value="{{ availableCountry.countryCode.name }}"
                                            data-icon="fi fi-{{ availableCountry.countryCode.name|lower }}"
                                            {{ this.country == availableCountry.countryCode.name ? 'selected' }}>
                                            {{ availableCountry.countryCode.value }} ({{ availableCountry.playersCount }})
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    <button
                        class="btn btn-outline-primary btn-sm position-relative pe-4"
                        data-bs-toggle="modal"
                        data-bs-target="#membersExclusiveModal"
                    >
                        <i class="bi-filter"></i>
                        {{ 'filters.button'|trans }}
                        <i class="ci-locked position-absolute fs-sm" style="right: 4px;top: 7px;"></i>
                    </button>
                {% endif %}
            </div>
        {% endif %}
    </div>

    <div>

        {% if this.times|length > 0 %}
            <twig:Chart:PuzzleTimesChart
                results="{{ this.times }}"
                playerId="{{ logged_user.profile ? logged_user.profile.playerId : null }}"
                title=""
            />
        {% endif %}

        {% if logged_user.profile is not null and this.myRowKey is not null %}
            <div class="text-center fs-sm mt-4 mb-3">
                <a
                    href="#leaderboard-row-{{ this.myRowKey }}"
                    class="text-primary"
                    data-turbo="false"
                >
                    {{ 'puzzle_times.my_attempts.jump_to_me'|trans }} <i class="bi bi-arrow-down-short"></i>
                </a>
            </div>
        {% endif %}

        <div class="table-responsive custom-table-wrapper mt-2 mb-5" {{ stimulus_controller('toggle') }}>
            <table class="table custom-table table-striped table-hover mb-0">
                <thead>
                <tr>
                    <th></th>
                    <th>{{ 'puzzler_name'|trans }}</th>
                    <th class="text-end">{{ 'time'|trans }}</th>
                </tr>
                </thead>

                <tbody>
                {% set  previousTimeId = null %}
                {% for timeId, aggregated_solver in this.times %}
                    {% set is_own_row = logged_user.profile is not null and ((aggregated_solver[0].players is not defined and aggregated_solver[0].playerId is same as logged_user.profile.playerId) or (aggregated_solver[0].players is defined and aggregated_solver[0].containsPlayer(logged_user.profile.playerId))) %}
                    <tr
                        id="leaderboard-row-{{ timeId }}"
                        style="scroll-margin-top: 120px;"
                        class="{{ is_own_row ? 'table-active-player' }}"
                    >
                        <td class="rank">{{ previousTimeId and aggregated_solver[0].time == this.times[previousTimeId][0].time ? loop.index-1 : loop.index }}.</td>

                        <td class="player-name">
                            {% if aggregated_solver[0].players is defined %}
                                {% for puzzle_solver in aggregated_solver[0].players %}
                                    {% if not loop.first %}
                                        <br>

                                    {% endif %}
                                    {% if puzzle_solver.isPrivate and (logged_user.profile is null or puzzle_solver.playerId != logged_user.profile.playerId) %}
                                        <span class="player-name-item small text-muted">{{ 'secret_puzzler_name'|trans }}</span>
                                        <i class="bi bi-incognito text-muted"></i>
                                    {% elseif puzzle_solver.playerId is not null %}
                                        {% if logged_user.profile is not null and logged_user.profile.activeMembership and not puzzle_solver.rankingOptedOut %}
                                            {{ skill_icon(puzzle_solver.skillTierName ?? 'unknown', 16) }}
                                        {% else %}
                                            {{ skill_icon('locked', 16) }}
                                        {% endif %}
                                        <a class="player-name-item" href="{{ path('player_profile', {playerId: puzzle_solver.playerId}) }}">
                                            {% if logged_user.profile is not null and puzzle_solver.playerId in logged_user.profile.favoritePlayers %}
                                                <i class="ci-star-filled text-warning"></i>
                                            {% endif %}
                                            {{ puzzle_solver.playerName ?? ('#' ~ puzzle_solver.playerCode) }}
                                        </a>
                                        {% if puzzle_solver.playerCountry is not null %}
                                            <small class="shadow-custom fi fi-{{ puzzle_solver.playerCountry.name }}"></small>
                                        {% endif %}
                                    {% else %}
                                        <span class="player-name-item">{{ puzzle_solver.playerName ?? ('#' ~ puzzle_solver.playerCode) }}</span>
                                    {% endif %}
                                {% endfor %}
                            {% else %}
                                {% if aggregated_solver[0].isPrivate and (logged_user.profile is null or aggregated_solver[0].playerId != logged_user.profile.playerId) %}
                                    <span class="player-name-item small text-muted">{{ 'secret_puzzler_name'|trans }}</span>
                                    <i class="bi bi-incognito text-muted"></i>
                                {% else %}
                                    {% if logged_user.profile is not null and logged_user.profile.activeMembership and not aggregated_solver[0].rankingOptedOut %}
                                        {{ skill_icon(aggregated_solver[0].skillTierName ?? 'unknown', 16) }}
                                    {% else %}
                                        {{ skill_icon('locked', 16) }}
                                    {% endif %}
                                    <a href="{{ path('player_profile', {playerId: aggregated_solver[0].playerId}) }}">
                                        {% if logged_user.profile is not null and aggregated_solver[0].playerId in logged_user.profile.favoritePlayers %}
                                            <i class="ci-star-filled text-warning"></i>
                                        {% endif %}
                                        {{ aggregated_solver[0].playerName ?? ('#' ~ aggregated_solver[0].playerCode) }}</a>
                                    {% if aggregated_solver[0].playerCountry is not null %}
                                        <small class="shadow-custom fi fi-{{ aggregated_solver[0].playerCountry.name }}"></small>
                                    {% endif %}
                                {% endif %}
                            {% endif %}
                        </td>

                        <td class="text-end with-ppm">
                            {{ aggregated_solver[0].time|puzzlingTime }}
                            {% if is_own_row %}
                                {{ include('_edit_time_button.html.twig', {timeId: aggregated_solver[0].timeId, context: 'puzzle-detail'}) }}
                            {% endif %}
                            {% if aggregated_solver[0].finishedAt is not null %}
                                <br>
                                <small class="text-muted">{{ aggregated_solver[0].finishedAt|date('d.m.Y') }}</small>
                            {% endif %}
                            <br>
                            <small><span class="text-muted">PPM</span> {{ ppm(aggregated_solver[0].time, this.piecesCount) }}</small>

                            {% if aggregated_solver[0].firstAttempt %}
                                <br>
                                <span class="badge rounded-pill bg-info">{{ 'first_attempt'|trans }}</span>
                            {% endif %}

                            {% if aggregated_solver[0].unboxed %}
                                <br>
                                <span class="badge rounded-pill bg-warning"><i class="bi bi-eye-slash"></i> {{ 'unboxed'|trans }}</span>
                            {% endif %}

                            {% if aggregated_solver[0].competitionName %}
                                <br>
                                {% if aggregated_solver[0].competitionSlug %}
                                    <a href="{{ path('event_detail', {'slug': aggregated_solver[0].competitionSlug}) }}">
                                {% endif %}
                                <span class="badge rounded-pill bg-primary">
                                    <i class="bi bi-trophy-fill"></i>{{ aggregated_solver[0].competitionShortcut ?? aggregated_solver[0].competitionName }}
                                </span>
                                {% if aggregated_solver[0].competitionSlug %}
                                    </a>
                                {% endif %}
                            {% endif %}

                            {% if aggregated_solver|length > 1 %}
                                <br>
                                <a href="#" class="show-more-times" {{ stimulus_action('toggle', 'toggle', 'click', {target: 'row' ~ loop.index})}}>
                                            <span class="badge bg-dark badge-shadow rounded-pill">
                                                {{ 'show_more_solving_times'|trans({ '%count%': aggregated_solver|length-1 }) }}
                                            </span>
                                </a>

                                <div class="more-times hidden with-ppm" {{ stimulus_target('toggle', 'row' ~ loop.index) }}>
                                    {% for solving_time in aggregated_solver %}
                                        {% if not loop.first %}
                                            <span class="d-inline-block mt-1">
                                                        {{ solving_time.time|puzzlingTime }}
                                                        {% if is_own_row %}
                                                            {{ include('_edit_time_button.html.twig', {timeId: solving_time.timeId, context: 'puzzle-detail'}) }}
                                                        {% endif %}
                                                        {% if solving_time.finishedAt is not null %}
                                                            <br>
                                                            <small class="text-muted">{{ solving_time.finishedAt|date('d.m.Y') }}</small>
                                                        {% endif %}
                                                        <br>
                                                        <small>
                                                            <span class="text-muted">PPM</span> {{ ppm(solving_time.time, this.piecesCount) }}
                                                        </small>

                                                        {% if solving_time.firstAttempt %}
                                                            <br>
                                                            <span class="badge rounded-pill bg-info">{{ 'first_attempt'|trans }}</span>
                                                        {% endif %}

                                                        {% if solving_time.unboxed %}
                                                            <br>
                                                            <span class="badge rounded-pill bg-warning"><i class="bi bi-eye-slash"></i> {{ 'unboxed'|trans }}</span>
                                                        {% endif %}

                                                        {% if solving_time.competitionName %}
                                                            <br>
                                                            {% if solving_time.competitionSlug %}
                                                                <a href="{{ path('event_detail', {'slug': solving_time.competitionSlug}) }}">
                                                            {% endif %}
                                                            <span class="badge rounded-pill bg-primary"><i class="bi bi-trophy-fill"></i>{{ solving_time.competitionShortcut ?? aggregated_solver[0].competitionName }}</span>
                                                            {% if solving_time.competitionSlug %}
                                                                </a>
                                                            {% endif %}
                                                        {% endif %}
                                                    </span>

                                            {% if not loop.last %}
                                                <br>
                                            {% endif %}
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </td>
                    </tr>

                    {% set previousTimeId = timeId %}
                {% endfor %}

                {% if this.times|length < 1 %}
                    <tr>
                        <td colspan="3" class="text-center">{{ 'be_first_to_solve'|trans }}</td>
                    </tr>
                {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>
