<div {{ attributes }}>
    {% if this.validatedAffiliateName %}
        <div class="alert alert-success d-flex align-items-center mb-3 py-2">
            <i class="ci-check-circle fs-5 me-2"></i>
            <div>
                <small>{{ 'referral.crediting'|trans }}</small>
                <strong>{{ this.validatedAffiliateName }}</strong>
                <button class="btn btn-sm btn-link text-muted p-0 ms-2"
                        data-action="live#action"
                        data-live-action-param="clearCode">
                    <i class="ci-close"></i>
                </button>
            </div>
        </div>
    {% elseif not this.isExpanded %}
        <div class="text-center mb-3">
            <button class="btn btn-link btn-sm text-muted text-decoration-none"
                    data-action="live#action"
                    data-live-action-param="expand">
                <i class="ci-heart me-1"></i>
                {{ 'referral.know_someone'|trans }}
            </button>
        </div>
    {% else %}
        <div class="mb-3">
            <div class="card border-0 bg-light">
                <div class="card-body py-2 px-3">
                    <label class="form-label small text-muted mb-1">
                        {{ 'referral.enter_code_label'|trans }}
                    </label>
                    <div class="input-group input-group-sm">
                        <input type="text"
                               class="form-control {% if this.error %}is-invalid{% endif %}"
                               data-model="code"
                               placeholder="{{ 'referral.code_placeholder'|trans }}"
                               autocomplete="off">
                        <button class="btn btn-primary"
                                data-action="live#action"
                                data-live-action-param="validateCode">
                            {{ 'referral.apply_button'|trans }}
                        </button>
                    </div>
                    {% if this.error %}
                        <div class="invalid-feedback d-block">
                            {{ this.error|trans }}
                        </div>
                    {% endif %}
                    <div class="form-text mt-1">
                        {{ 'referral.code_help'|trans }}
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>
