<div{{ attributes }}>
    {% if this.rows|length == 0 %}
        <div class="text-center py-5">
            <p class="text-muted mb-3">{{ 'competition.tables.no_layout'|trans }}</p>
            <a href="{{ path('generate_table_layout', {'roundId': this.roundId}) }}" class="btn btn-primary">
                <i class="bi bi-grid-3x3 me-1"></i>{{ 'competition.tables.generate_layout'|trans }}
            </a>
        </div>
    {% else %}
        {% for row in this.rows %}
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>{{ row.label ?? 'Row ' ~ row.position }}</strong>
                    <div>
                        <button
                            class="btn btn-sm btn-outline-primary me-1"
                            data-action="live#action"
                            data-live-action-param="addTable"
                            data-live-row-id-param="{{ row.id }}"
                        >
                            <i class="bi bi-plus-lg me-1"></i>{{ 'competition.tables.add_table'|trans }}
                        </button>
                        <button
                            class="btn btn-sm btn-outline-danger"
                            data-action="live#action"
                            data-live-action-param="deleteRow"
                            data-live-row-id-param="{{ row.id }}"
                            onclick="return confirm('{{ 'competition.tables.confirm_delete_row'|trans }}')"
                        >
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-3">
                        {% for table in row.tables %}
                            <div class="card" style="min-width: 220px;">
                                <div class="card-header d-flex justify-content-between align-items-center py-2">
                                    <strong class="small">{{ table.label }}</strong>
                                    <button
                                        class="btn btn-sm btn-outline-danger py-0 px-1"
                                        data-action="live#action"
                                        data-live-action-param="deleteTable"
                                        data-live-table-id-param="{{ table.id }}"
                                        onclick="return confirm('{{ 'competition.tables.confirm_delete_table'|trans }}')"
                                    >
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                                <ul class="list-group list-group-flush">
                                    {% for spot in table.spots %}
                                        <li class="list-group-item py-2">
                                            {% if this.editingSpotId == spot.id %}
                                                <div>
                                                    <div class="input-group input-group-sm mb-1">
                                                        <input
                                                            type="text"
                                                            class="form-control"
                                                            data-model="debounce(200)|searchQuery"
                                                            placeholder="{{ 'competition.tables.search_player'|trans }}"
                                                            autofocus
                                                        >
                                                        <button
                                                            class="btn btn-outline-secondary"
                                                            data-action="live#action"
                                                            data-live-action-param="cancelEdit"
                                                        >
                                                            <i class="bi bi-x"></i>
                                                        </button>
                                                    </div>

                                                    {% if this.searchQuery|length >= 2 %}
                                                        {% set results = computed.searchResults %}
                                                        {% if results|length > 0 %}
                                                            <div class="list-group list-group-flush small">
                                                                {% for player in results %}
                                                                    <button
                                                                        type="button"
                                                                        class="list-group-item list-group-item-action py-1 px-2"
                                                                        data-action="live#action"
                                                                        data-live-action-param="assignPlayer"
                                                                        data-live-spot-id-param="{{ spot.id }}"
                                                                        data-live-player-id-param="{{ player.playerId }}"
                                                                    >
                                                                        {{ player.playerName }}
                                                                        {% if player.playerCode %}
                                                                            <code class="text-muted">#{{ player.playerCode|upper }}</code>
                                                                        {% endif %}
                                                                        {% if player.playerCountry is not null %}
                                                                            <small class="fi fi-{{ player.playerCountry.name }}"></small>
                                                                        {% endif %}
                                                                    </button>
                                                                {% endfor %}
                                                            </div>
                                                        {% else %}
                                                            <p class="text-muted small mb-1">{{ 'competition.tables.no_player_found'|trans }}</p>
                                                        {% endif %}

                                                        <button
                                                            type="button"
                                                            class="btn btn-sm btn-outline-secondary mt-1 w-100"
                                                            data-action="live#action"
                                                            data-live-action-param="assignManualName"
                                                            data-live-spot-id-param="{{ spot.id }}"
                                                            data-live-player-name-param="{{ this.searchQuery }}"
                                                        >
                                                            <i class="bi bi-pencil me-1"></i>{{ 'competition.tables.use_as_name'|trans({ '%name%': this.searchQuery }) }}
                                                        </button>
                                                    {% endif %}
                                                </div>
                                            {% elseif spot.isAssigned %}
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <span>
                                                        {% if spot.playerId %}
                                                            {{ spot.playerName }}
                                                            {% if spot.playerCode %}
                                                                <code class="text-muted">#{{ spot.playerCode|upper }}</code>
                                                            {% endif %}
                                                            {% if spot.playerCountry is not null %}
                                                                <small class="fi fi-{{ spot.playerCountry.name }}"></small>
                                                            {% endif %}
                                                        {% else %}
                                                            {{ spot.playerName }}
                                                            <span class="badge bg-secondary">{{ 'competition.tables.manual'|trans }}</span>
                                                        {% endif %}
                                                    </span>
                                                    <div>
                                                        <button
                                                            class="btn btn-sm btn-outline-secondary py-0 px-1"
                                                            data-action="live#action"
                                                            data-live-action-param="clearSpot"
                                                            data-live-spot-id-param="{{ spot.id }}"
                                                        >
                                                            <i class="bi bi-x"></i>
                                                        </button>
                                                        <button
                                                            class="btn btn-sm btn-outline-danger py-0 px-1"
                                                            data-action="live#action"
                                                            data-live-action-param="deleteSpot"
                                                            data-live-spot-id-param="{{ spot.id }}"
                                                        >
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            {% else %}
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <span class="text-muted small">{{ 'competition.tables.spot'|trans }} {{ spot.position }}</span>
                                                    <div>
                                                        <button
                                                            class="btn btn-sm btn-outline-primary py-0 px-1"
                                                            data-action="live#action"
                                                            data-live-action-param="startEditSpot"
                                                            data-live-spot-id-param="{{ spot.id }}"
                                                        >
                                                            <i class="bi bi-person-plus"></i>
                                                        </button>
                                                        <button
                                                            class="btn btn-sm btn-outline-danger py-0 px-1"
                                                            data-action="live#action"
                                                            data-live-action-param="deleteSpot"
                                                            data-live-spot-id-param="{{ spot.id }}"
                                                        >
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            {% endif %}
                                        </li>
                                    {% endfor %}
                                    <li class="list-group-item py-1 text-center">
                                        <button
                                            class="btn btn-sm btn-link text-decoration-none"
                                            data-action="live#action"
                                            data-live-action-param="addSpot"
                                            data-live-table-id-param="{{ table.id }}"
                                        >
                                            <i class="bi bi-plus-lg me-1"></i>{{ 'competition.tables.add_spot'|trans }}
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endfor %}

        <button
            class="btn btn-outline-primary"
            data-action="live#action"
            data-live-action-param="addRow"
        >
            <i class="bi bi-plus-lg me-1"></i>{{ 'competition.tables.add_row'|trans }}
        </button>
    {% endif %}
</div>
