<turbo-frame id="modal-frame">
    <div data-modal-size="modal-xl">
        <div class="modal-header">
            <h5 class="modal-title">{{ 'edit_time.title'|trans }}</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body">
            <div class="mb-3">
                <form action="{{ path('delete_time', {timeId: solved_puzzle.timeId}) }}"
                      method="post"
                      class="d-inline"
                      data-turbo-confirm="{{ 'edit_time.delete_modal_confirm'|trans }}">
                    {% if return_url %}
                        <input type="hidden" name="return_url" value="{{ return_url }}">
                    {% endif %}
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="ci-trash"></i> {{ 'edit_time.delete_button'|trans }}
                    </button>
                </form>
            </div>

            <div data-controller="puzzle-add-form" data-puzzle-add-form-mode-value="{{ initial_mode|default('speed_puzzling') }}">
                <div class="mb-4">
                    <div class="btn-group w-100" role="group" aria-label="Form mode selection">
                        <input type="radio" class="btn-check" name="form-mode" id="mode-speed-modal" autocomplete="off"
                               {{ initial_mode|default('speed_puzzling') == 'speed_puzzling' ? 'checked' : '' }}
                               value="speed_puzzling"
                               data-action="change->puzzle-add-form#switchMode">
                        <label class="btn btn-outline-primary py-2 px-2 d-flex flex-column align-items-center lh-sm text-wrap" for="mode-speed-modal">
                            <i class="bi bi-stopwatch-fill"></i>
                            <small>{{ 'puzzle_add.mode.speed_puzzling'|trans }}</small>
                        </label>

                        <input type="radio" class="btn-check" name="form-mode" id="mode-relax-modal" autocomplete="off"
                               {{ initial_mode|default('speed_puzzling') == 'relax' ? 'checked' : '' }}
                               value="relax"
                               data-action="change->puzzle-add-form#switchMode">
                        <label class="btn btn-outline-primary py-2 px-2 d-flex flex-column align-items-center lh-sm text-wrap" for="mode-relax-modal">
                            <i class="bi bi-cup-hot-fill"></i>
                            <small>{{ 'puzzle_add.mode.relax'|trans }}</small>
                        </label>
                    </div>
                </div>

                {{ include('_solving_time_form.html.twig') }}
            </div>
        </div>
    </div>
</turbo-frame>
