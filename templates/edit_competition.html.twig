{% extends 'base.html.twig' %}

{% block title %}{{ 'competition.edit_event'|trans }} - {{ competition.name }}{% endblock %}

{% block content %}
    {{ include('_breadcrumb.html.twig', {items: [
        {label: 'events.title'|trans, url: path('events')},
        {label: competition.name},
    ]}) }}
    {{ include('_return_back_button.html.twig', {fallbackUrl: path('events'), fallbackTitle: 'events.title'|trans}) }}

    <div class="pb-4">
        <div class="row gy-3 pb-3">
            <div class="col-lg-8">
                <h1 class="h2">{{ 'competition.edit_event'|trans }}: {{ competition.name }}</h1>

                {% if competition.seriesId is null %}
                    {% if competition.rejectedAt is not null %}
                        <div class="alert alert-danger">
                            <i class="bi bi-x-circle me-2"></i>{{ 'competition.rejected_info'|trans }}
                            <br><strong>{{ 'competition.rejection_reason'|trans }}:</strong> {{ competition.rejectionReason }}
                        </div>
                    {% elseif competition.approvedAt is null %}
                        <div class="alert alert-warning">
                            <i class="bi bi-clock me-2"></i>{{ 'competition.pending_approval_info'|trans }}
                        </div>
                    {% endif %}
                {% endif %}

                <div class="mb-3 d-flex flex-wrap gap-2">
                    <a href="{{ path('manage_competition_rounds', {'competitionId': competition.id, return: path('edit_competition', {competitionId: competition.id}), return_title: 'competition.edit_event'|trans}) }}" class="btn btn-outline-primary">
                        <i class="bi bi-list-ol me-1"></i>{{ 'competition.manage_rounds'|trans }}
                    </a>
                    <a href="{{ path('manage_competition_participants', {'competitionId': competition.id, return: path('edit_competition', {competitionId: competition.id}), return_title: 'competition.edit_event'|trans}) }}" class="btn btn-outline-primary">
                        <i class="bi bi-people me-1"></i>{{ 'competition.manage_participants'|trans }}
                    </a>
                    {% if is_granted(constant('SpeedPuzzling\\Web\\Security\\CompetitionDeleteVoter::COMPETITION_DELETE'), competition.id) %}
                        <button type="button" class="btn btn-outline-danger ms-auto" data-bs-toggle="modal" data-bs-target="#deleteCompetitionModal-{{ competition.id }}" title="{{ 'competition.delete.button'|trans }}">
                            <i class="bi bi-trash"></i>
                        </button>
                    {% endif %}
                </div>

                {% for flash_message in app.flashes('success') %}
                    <div class="alert alert-success">
                        <i class="ci-check-circle me-2"></i>
                        {{ flash_message }}
                    </div>
                {% endfor %}

                {% if competition.seriesId is null and competition.approvedAt is null and competition.rejectedAt is null %}
                    <div class="card shadow my-4 border-info">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-arrow-repeat me-2"></i>{{ 'competition.convert_to_series.title'|trans }}</h5>
                            <p class="card-text text-muted">{{ 'competition.convert_to_series.description'|trans }}</p>
                            <form method="post" action="{{ path('convert_competition_to_series', {'competitionId': competition.id}) }}" onsubmit="return confirm('{{ 'competition.convert_to_series.confirm'|trans }}')">
                                <button type="submit" class="btn btn-outline-info">
                                    <i class="bi bi-arrow-repeat me-1"></i>{{ 'competition.convert_to_series.button'|trans }}
                                </button>
                            </form>
                        </div>
                    </div>
                {% endif %}

                <div class="card shadow my-4">
                    <div class="card-body">
                        {{ form_start(form) }}
                        <div data-controller="competition-form">
                            <div class="required">{{ form_row(form.name) }}</div>
                            {{ form_row(form.shortcut) }}
                            {{ form_row(form.description) }}
                            <div class="required" data-action="change->competition-form#toggle">
                                {{ form_row(form.isOnline) }}
                            </div>

                            <div class="mb-3" data-competition-form-target="offlineFields">
                                {{ form_label(form.location, null, {label_attr: {class: 'form-label required'}}) }}
                                {{ form_widget(form.location) }}
                                {{ form_errors(form.location) }}
                            </div>
                            <div data-competition-form-target="typeSelectedFields" data-controller="country-autocomplete">
                                {{ form_row(form.locationCountryCode) }}
                            </div>

                            <div class="row" data-competition-form-target="dateFields">
                                <div class="col-6 mb-3">
                                    {{ form_label(form.dateFrom, null, {label_attr: {class: 'form-label required'}}) }}
                                    <div class="input-group">
                                        {{ form_widget(form.dateFrom, {'attr': {'class': 'form-control rounded date-picker pe-5', 'data-datepicker-options': '{"altInput": true, "altFormat": "d.m.Y", "dateFormat": "d.m.Y"}'}}) }}
                                        <i class="ci-calendar position-absolute top-50 end-0 translate-middle-y me-3" style="pointer-events: none;"></i>
                                    </div>
                                    {{ form_help(form.dateFrom) }}
                                    {{ form_errors(form.dateFrom) }}
                                </div>
                                <div class="col-6 mb-3">
                                    {{ form_label(form.dateTo, null, {label_attr: {class: 'form-label required'}}) }}
                                    <div class="input-group">
                                        {{ form_widget(form.dateTo, {'attr': {'class': 'form-control rounded date-picker pe-5', 'data-datepicker-options': '{"altInput": true, "altFormat": "d.m.Y", "dateFormat": "d.m.Y"}'}}) }}
                                        <i class="ci-calendar position-absolute top-50 end-0 translate-middle-y me-3" style="pointer-events: none;"></i>
                                    </div>
                                    {{ form_errors(form.dateTo) }}
                                </div>
                            </div>

                            {{ form_row(form.link) }}
                            {{ form_row(form.registrationLink) }}
                            {{ form_row(form.resultsLink) }}
                            {{ form_row(form.logo) }}
                            <div data-controller="player-search-autocomplete" data-player-search-autocomplete-url-value="{{ path('player_search_autocomplete') }}">
                                {{ form_row(form.maintainers) }}
                            </div>

                            <button type="submit" class="btn btn-primary mt-3">
                                {{ 'competition.save_changes'|trans }}
                            </button>
                        </div>
                        {% do form.isRecurring.setRendered %}
                        {{ form_end(form) }}
                    </div>
                </div>

                {% if is_granted(constant('SpeedPuzzling\\Web\\Security\\CompetitionDeleteVoter::COMPETITION_DELETE'), competition.id) %}
                    <div class="card shadow my-4 border-danger">
                        <div class="card-body">
                            <h5 class="card-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>{{ 'competition.delete.danger_zone_title'|trans }}</h5>
                            <p class="card-text text-muted">{{ 'competition.delete.description'|trans }}</p>
                            <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteCompetitionModal-{{ competition.id }}">
                                <i class="bi bi-trash me-1"></i>{{ 'competition.delete.button'|trans }}
                            </button>
                        </div>
                    </div>

                    {{ include('_competition_delete_modal.html.twig', {id: competition.id, name: competition.name}) }}
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
