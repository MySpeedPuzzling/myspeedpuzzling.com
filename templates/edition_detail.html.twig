{% extends 'base.html.twig' %}

{% block title %}{{ event.name }} - {{ series.name }}{% endblock %}

{% block content %}
    {% if series.slug %}
        {{ include('_return_back_button.html.twig', {fallbackUrl: path('competition_series_detail', {slug: series.slug}), fallbackTitle: series.name}) }}
    {% else %}
        {{ include('_return_back_button.html.twig', {fallbackUrl: path('events'), fallbackTitle: 'events.title'|trans}) }}
    {% endif %}

    <div class="d-flex">
        <div class="flex-fill">
            <h1 class="h4 mb-1">{{ event.name }}</h1>
            <p class="text-muted mb-2">
                {% if series.slug %}
                    <a href="{{ path('competition_series_detail', {slug: series.slug}) }}" class="text-decoration-underline">{{ series.name }}</a>
                {% else %}
                    {{ series.name }}
                {% endif %}
            </p>

            {% if event.dateFrom %}
                <div class="mb-2">
                    <i class="ci-calendar me-2 ps-1"></i>
                    {% if event.dateTo and event.dateFrom != event.dateTo %}
                        {{ event.dateFrom|date('d.') }}-{{ event.dateTo|date('d.m.Y') }}
                    {% else %}
                        {{ event.dateFrom|date('d.m.Y H:i') }}
                    {% endif %}
                    <small class="text-muted ps-1">({{ event.dateFrom|ago }})</small>
                </div>
            {% endif %}

            {% if not series.isOnline and event.location %}
                <div class="mb-2">
                    {% if event.locationCountryCode %}
                        <span class="shadow-custom fi fi-{{ event.locationCountryCode.name }} me-2"></span>
                    {% endif %}
                    {{ event.location }}
                </div>
            {% endif %}

            <div class="d-flex gap-2">
                {% if event.registrationLink %}
                    <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ event.registrationLink }}">
                        <i class="bi bi-person-plus me-1"></i>{{ 'events.registration_link'|trans }}
                    </a>
                {% endif %}
                {% if event.resultsLink %}
                    <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ event.resultsLink }}">
                        <i class="bi bi-trophy me-1"></i>{{ 'events.results_link'|trans }}
                    </a>
                {% endif %}
            </div>
        </div>

        <div class="ms-3 flex-shrink-0 event-image">
            {% if series.logo %}
                <img style="max-height: 84px;" src="{{ series.logo|thumbnail('puzzle_small') }}" alt="{{ series.name }} logo" class="img-fluid">
            {% endif %}
        </div>
    </div>

    {% if rounds|length > 0 %}
        {% for round in rounds %}
            <div class="mt-4">
                <h2 class="h5 mb-3">
                    {% if round.badgeBackgroundColor %}
                        <span class="badge me-2" style="background-color: {{ round.badgeBackgroundColor }}; color: {{ round.badgeTextColor ?? '#fff' }}">
                            {{ round.name }}
                        </span>
                    {% else %}
                        {{ round.name }}
                    {% endif %}

                    {% if round.category.value != 'solo' %}
                        <span class="badge bg-secondary ms-1">{{ ('competition.round.category.' ~ round.category.value)|trans }}</span>
                    {% endif %}
                </h2>

                <div class="text-muted small mb-3">
                    <i class="bi bi-calendar-event me-1"></i>{{ round.startsAt|date('d.m.Y H:i') }}
                    <span class="mx-1">&middot;</span>
                    <i class="bi bi-stopwatch me-1"></i>{{ round.minutesLimit }} min
                </div>

                {% if round.puzzles|length > 0 %}
                    <div class="row g-2 g-md-3">
                        {% for puzzle in round.puzzles %}
                            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                                <div class="card h-100 shadow-sm">
                                    {% if puzzle.puzzleImage %}
                                        <img src="{{ puzzle.puzzleImage|thumbnail('puzzle_small') }}" alt="{{ puzzle.puzzleName }}" class="card-img-top">
                                    {% else %}
                                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 120px;">
                                            <i class="bi bi-puzzle text-muted" style="font-size: 2rem;"></i>
                                        </div>
                                    {% endif %}
                                    <div class="card-body p-2">
                                        <p class="card-text small mb-0">{{ puzzle.puzzleName }}</p>
                                        <p class="card-text text-muted small">
                                            {{ puzzle.piecesCount }} {{ 'puzzle.pieces'|trans }}
                                            {% if puzzle.manufacturerName %}
                                                &middot; {{ puzzle.manufacturerName }}
                                            {% endif %}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    {% elseif puzzles|length > 0 %}
        <h2 class="h5 mt-4 mb-3">{{ 'events.competition_puzzles'|trans }}</h2>
        <div class="row g-2 g-md-3">
            {% for puzzle in puzzles %}
                {{ include('_puzzle_item.html.twig', {
                    'search': '',
                }) }}
            {% endfor %}
        </div>
    {% endif %}

    <twig:CompetitionParticipants competitionId="{{ event.id }}" eventSlug="{{ series.slug }}" />
{% endblock %}
