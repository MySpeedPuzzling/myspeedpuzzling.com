{% trans_default_domain 'emails' %}
{% apply inky_to_html|inline_css(source('@styles/foundation-emails.css')) %}
    <wrapper>
        <container>
            {{ include('emails/_header.html.twig') }}

            <row>
                <columns>
                    <spacer size-sm="24"></spacer>
                    <h3>{{ 'feature_request_status_changed.title'|trans }}</h3>
                    <spacer size-sm="8"></spacer>
                </columns>
            </row>

            <row>
                <columns>
                    {{ 'feature_request_status_changed.content'|trans({
                        '%featureRequestTitle%': featureRequestTitle,
                        '%oldStatus%': oldStatus,
                        '%newStatus%': newStatus,
                    })|raw }}
                </columns>
            </row>

            {% if adminComment is not null %}
                <row>
                    <columns>
                        {{ 'feature_request_status_changed.admin_comment'|trans({
                            '%adminComment%': adminComment,
                        })|raw }}
                    </columns>
                </row>
            {% endif %}

            {{ include('emails/_footer.html.twig') }}
        </container>
    </wrapper>
{% endapply %}
