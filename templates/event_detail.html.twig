{% extends 'base.html.twig' %}

{% block title %}
    {%- if event.name matches '/\\d{4}/' or event.dateFrom is null -%}
        {{- 'events.meta.event_detail_title_no_year'|trans({'%name%': event.name}) -}}
    {%- else -%}
        {{- 'events.meta.event_detail_title'|trans({'%name%': event.name, '%year%': event.dateFrom|date('Y')}) -}}
    {%- endif -%}
{% endblock %}

{% block robots %}
    {# Unapproved/rejected events are publicly reachable at their slug URL - keep them out of the index #}
    {% if event.approvedAt is null or event.rejectedAt is not null %}
        <meta name="robots" content="noindex, nofollow">
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block meta_description %}
    {%- if event.isOnline and event.dateFrom -%}
        {{- 'events.meta.event_detail_description_online'|trans({'%name%': event.name, '%date%': event.dateFrom|format_date('long')}) -}}
    {%- elseif event.isOnline -%}
        {{- 'events.meta.event_detail_description_online_no_date'|trans({'%name%': event.name}) -}}
    {%- elseif event.dateFrom and event.location -%}
        {{- 'events.meta.event_detail_description'|trans({'%name%': event.name, '%date%': event.dateFrom|format_date('long'), '%location%': event.location}) -}}
    {%- elseif event.location -%}
        {{- 'events.meta.event_detail_description_no_date'|trans({'%name%': event.name, '%location%': event.location}) -}}
    {%- elseif event.dateFrom -%}
        {{- 'events.meta.event_detail_description_no_location'|trans({'%name%': event.name, '%date%': event.dateFrom|format_date('long')}) -}}
    {%- else -%}
        {{- 'events.meta.event_detail_description_fallback'|trans({'%name%': event.name}) -}}
    {%- endif -%}
{% endblock %}

{% block json_ld %}
{{ parent() }}
{% if event.approvedAt is not null and event.rejectedAt is null and event.dateFrom is not null and event.slug is not null %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Event",
    "name": {{ event.name|json_encode|raw }},
    "url": {{ url('event_detail', {'slug': event.slug})|json_encode|raw }},
    "startDate": {{ event.dateFrom|date('Y-m-d')|json_encode|raw }},
    "eventStatus": "https://schema.org/EventScheduled",
    "eventAttendanceMode": {{ (event.isOnline ? 'https://schema.org/OnlineEventAttendanceMode' : 'https://schema.org/OfflineEventAttendanceMode')|json_encode|raw }}
    {%- if event.dateTo %},
    "endDate": {{ event.dateTo|date('Y-m-d')|json_encode|raw }}
    {%- endif %}
    {%- if event.isOnline %},
    "location": {
        "@type": "VirtualLocation",
        "url": {{ (event.registrationLink ?? event.resultsLink ?? url('event_detail', {'slug': event.slug}))|json_encode|raw }}
    }
    {%- elseif event.location %},
    "location": {
        "@type": "Place",
        "name": {{ event.location|json_encode|raw }},
        "address": {
            "@type": "PostalAddress",
            "addressLocality": {{ event.location|json_encode|raw }}
            {%- if event.locationCountryCode %},
            "addressCountry": {{ event.locationCountryCode.name|upper|json_encode|raw }}
            {%- endif %}
        }
    }
    {%- endif %}
    {%- if event.logo %},
    "image": {{ event.logo|thumbnail('puzzle_small')|json_encode|raw }}
    {%- endif %}
    {# description is a Google-recommended Event property - always emit,
       falling back to the same text as the meta description #}
    ,"description": {{ (event.description ? event.description|striptags : block('meta_description')|trim)|json_encode|raw }}
    {%- if event.addedByPlayerName %},
    "organizer": {
        "@type": "Person",
        "name": {{ event.addedByPlayerName|json_encode|raw }}
    }
    {%- endif %}
    {%- if event.registrationLink %},
    "offers": {
        "@type": "Offer",
        "url": {{ event.registrationLink|json_encode|raw }}
    }
    {%- endif %}
}
</script>
{% endif %}
{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig', {fallbackUrl: path('events'), fallbackTitle: 'events.title'|trans}) }}

    <div class="d-flex">
        <div class="flex-fill">
            <h1 class="h4 mb-2">
                {{ event.name }}
            </h1>

            <div class="row">
                <div class="col-sm-6">
                    {% if event.locationCountryCode %}
                        <span class="shadow-custom fi fi-{{ event.locationCountryCode.name }} me-2"></span>
                    {% endif %}

                    {{ event.location }}

                    {% if event.dateFrom %}
                        <div class="mt-1">
                            <i class="ci-calendar me-2 ps-1"></i>
                            {% if event.dateTo and event.dateFrom != event.dateTo %}
                                {{ event.dateFrom|date('d.') }}-{{ event.dateTo|date('d.m.') }}
                            {% else %}
                                {{ event.dateFrom|date('d.m.') }}
                            {% endif %}
                            <small class="text-muted ps-1">({{ event.dateFrom|ago }})</small>
                        </div>
                    {% endif %}
                </div>

                {% if event.link or event.registrationLink or event.resultsLink %}
                    <div class="col-sm-6 mt-2 mt-sm-0">
                        {% if event.link %}
                            <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ event.link }}">
                                <i class="bi bi-info-circle me-1"></i>{{ 'events.website_link'|trans }}
                            </a>
                        {% endif %}

                        {% if event.registrationLink %}
                            <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ event.registrationLink }}">
                                <i class="bi bi-person-plus me-1"></i>{{ 'events.registration_link'|trans }}
                            </a>
                        {% endif %}

                        {% if event.resultsLink %}
                            <a target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary" href="{{ event.resultsLink }}">
                                <i class="bi bi-trophy me-1"></i>{{ 'events.results_link'|trans }}
                            </a>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="ms-3 flex-shrink-0 event-image">
            {% if event.logo %}
                <img style="max-height: 84px;" src="{{ event.logo|thumbnail('puzzle_small') }}" alt="{{ event.name }} logo" class="img-fluid">
            {% endif %}
        </div>
    </div>

    <h2 class="h5 mt-4 mb-3">{{ 'events.competition_puzzles'|trans }}</h2>

    {% if puzzles|length > 0 %}
        <div class="row g-2 g-md-3">
            {% for puzzle in puzzles %}
                {{ include('_puzzle_item.html.twig', {
                    'search': '',
                }) }}
            {% endfor %}
        </div>
    {% else %}
        <p class="lead">{{ 'events.no_puzzle_text'|trans|raw }}</p>
    {% endif %}

    <div class="mt-4 mb-3">
        {% if is_going %}
            <span class="btn btn-sm btn-success disabled me-2">
                <i class="bi bi-check-lg me-1"></i>{{ 'competition.join.you_are_going'|trans }}
            </span>
            <a href="{{ path('join_competition', {'competitionId': event.id}) }}" class="btn btn-sm btn-outline-secondary me-1">
                {{ 'competition.join.change'|trans }}
            </a>
            <form method="post" action="{{ path('leave_competition', {'competitionId': event.id}) }}" class="d-inline">
                <button type="submit" class="btn btn-sm btn-outline-danger">
                    {{ 'competition.join.leave'|trans }}
                </button>
            </form>
        {% elseif logged_user.profile is not null %}
            <a href="{{ path('join_competition', {'competitionId': event.id}) }}" class="btn btn-sm btn-primary">
                <i class="bi bi-person-plus me-1"></i>{{ 'competition.join.im_going'|trans }}
            </a>
        {% else %}
            <a href="{{ path('join_competition', {'competitionId': event.id}) }}" class="btn btn-sm btn-primary">
                <i class="bi bi-person-plus me-1"></i>{{ 'competition.join.im_going'|trans }}
            </a>
        {% endif %}
    </div>

    <twig:CompetitionParticipants competitionId="{{ event.id }}" eventSlug="{{ event.slug }}" />

{% endblock %}
