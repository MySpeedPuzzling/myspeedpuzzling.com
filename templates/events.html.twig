{% extends 'base.html.twig' %}

{% block title %}{{ 'events.meta.title'|trans }}{% endblock %}

{% block json_ld %}
{{ parent() }}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "SportsEvent",
    "name": "Speed Puzzling Events",
    "description": "{{ 'events.meta.description'|trans }}",
    "url": "{{ url('events', {'_locale': app.request.locale}) }}",
    "sport": {
        "@type": "Thing",
        "name": "Speed Puzzling"
    },
    "organizer": {
        "@type": "Organization",
        "name": "MySpeedPuzzling"
    },
    "eventStatus": "https://schema.org/EventScheduled"
}
</script>
{% endblock %}

{% block content %}
    <div class="d-flex align-items-center mb-3">
        <h1 class="mb-0">{{ 'events.title'|trans }}</h1>
        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
            <a href="{{ path('add_competition', {return: path('events'), return_title: 'events.title'|trans}) }}" class="btn btn-primary ms-3">
                <i class="bi bi-plus-lg me-1"></i>{{ 'competition.add_event'|trans }}
            </a>
        {% endif %}
    </div>

    {% if player_competitions|length > 0 %}
        <h2 class="mt-4">{{ 'competition.my_competitions'|trans }}</h2>
        <div class="row">
            {% for event in player_competitions %}
                <div class="mb-3 mb-md-4 col-md-6">
                    <div class="card shadow position-relative">
                        <div class="card-body d-flex w-100 p-3">
                            <div class="flex-fill">
                                <h3 class="h5 mb-2">
                                    {{ event.name }}
                                    {% if event.rejectedAt is not null %}
                                        <span class="badge bg-danger ms-2">{{ 'competition.rejected'|trans }}</span>
                                    {% elseif event.approvedAt is null %}
                                        <span class="badge bg-warning text-dark ms-2">{{ 'competition.pending_approval'|trans }}</span>
                                    {% endif %}
                                    {% if event.isOnline %}
                                        <span class="badge bg-info text-dark ms-2">{{ 'competition.online'|trans }}</span>
                                    {% endif %}
                                    {% if event.isRecurring %}
                                        <span class="badge bg-secondary ms-2">{{ 'competition.recurring'|trans }}</span>
                                    {% endif %}
                                </h3>
                                <div>
                                    {% if event.locationCountryCode %}
                                        <span class="shadow-custom fi fi-{{ event.locationCountryCode.name }} me-2"></span>
                                    {% endif %}
                                    {{ event.location }}
                                </div>
                            </div>
                            <div class="ms-3 flex-shrink-0">
                                <a href="{{ path('edit_competition', {'competitionId': event.id, return: path('events'), return_title: 'events.title'|trans}) }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil me-1"></i>{{ 'competition.edit'|trans }}
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {% if live_events|length > 0 %}
        <div class="row">
            <h2 class="mt-4">{{ 'events.live'|trans }}</h2>

            {% for event in live_events %}
                {{ include('_competition_event.html.twig', {
                    'live': true,
                }) }}
            {% endfor %}
        </div>
    {% endif %}

    {% if upcoming_events|length > 0 %}
        <div class="row">
            {% if live_events|length > 0 %}
                <h2 class="mt-4">{{ 'events.upcoming'|trans }}</h2>
            {% endif %}

            {% for event in upcoming_events %}
                {{ include('_competition_event.html.twig') }}
            {% endfor %}
        </div>
    {% endif %}

    {% if recurring_events|length > 0 %}
        <h2 class="mt-4">{{ 'events.recurring'|trans }}</h2>

        <div class="row">
            {% for event in recurring_events %}
                {{ include('_competition_event.html.twig') }}
            {% endfor %}
        </div>
    {% endif %}

    {% if past_events|length > 0 %}
        <h2 class="mt-4">{{ 'events.past'|trans }}</h2>

        <div class="row">
            {% for event in past_events %}
                {{ include('_competition_event.html.twig') }}
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
