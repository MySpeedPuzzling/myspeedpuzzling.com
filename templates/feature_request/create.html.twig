{% extends 'base.html.twig' %}

{% block title %}{{ 'feature_requests.create_title'|trans }}{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig', {fallbackUrl: path('feature_requests'), fallbackTitle: 'feature_requests.title'|trans}) }}

    <h1 class="h3 mb-3">
        <i class="bi bi-lightbulb me-2"></i>{{ 'feature_requests.create_title'|trans }}
    </h1>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="alert alert-light border small mb-4">
                <i class="bi bi-info-circle me-1"></i>
                {{ 'feature_requests.create_help'|trans }}
            </div>

            {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_row(form.title) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.description) }}
                </div>
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i>{{ 'feature_requests.form.submit'|trans }}
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
