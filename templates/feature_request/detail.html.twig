{% extends 'base.html.twig' %}

{% block title %}{{ feature_request.title }} - {{ 'feature_requests.title'|trans }}{% endblock %}
{% block meta_description %}{{ feature_request.description|length > 160 ? feature_request.description|slice(0, 160) ~ '...' : feature_request.description }}{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig', {fallbackUrl: path('feature_requests'), fallbackTitle: 'feature_requests.title'|trans}) }}

    {% set is_mine = logged_user.profile is not null and logged_user.profile.playerId == feature_request.authorId %}
    <div class="card shadow-sm mb-4 {{ is_mine ? 'border-primary border-opacity-50' : '' }}">
        <div class="card-body">
            <div class="d-flex align-items-start gap-3">
                {# Vote column #}
                <div class="d-flex flex-column align-items-center flex-shrink-0" style="min-width: 56px;">
                    {% if logged_user.profile is not null and logged_user.profile.activeMembership %}
                        {% if has_voted %}
                            <div class="btn btn-primary d-flex flex-column align-items-center py-2 px-3" style="pointer-events: none; min-width: 50px;">
                                <i class="bi bi-caret-up-fill" style="font-size: 1.2rem; line-height: 1;"></i>
                                <span class="fw-bold" style="font-size: 1.2rem; line-height: 1.2;">{{ feature_request.voteCount }}</span>
                            </div>
                        {% elseif votes_used_this_month < 1 %}
                            <form method="post" action="{{ path('feature_request_vote', {'featureRequestId': feature_request.id}) }}">
                                <button type="submit" class="btn btn-outline-primary d-flex flex-column align-items-center py-2 px-3" style="min-width: 50px;">
                                    <i class="bi bi-caret-up-fill" style="font-size: 1.2rem; line-height: 1;"></i>
                                    <span class="fw-bold" style="font-size: 1.2rem; line-height: 1.2;">{{ feature_request.voteCount }}</span>
                                    <span style="font-size: 0.65rem; line-height: 1; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'feature_requests.vote_button'|trans }}</span>
                                </button>
                            </form>
                        {% else %}
                            <div class="btn btn-outline-secondary d-flex flex-column align-items-center py-2 px-3 disabled" style="min-width: 50px;" title="{{ 'feature_requests.vote_limit_reached'|trans }}">
                                <i class="bi bi-caret-up-fill" style="font-size: 1.2rem; line-height: 1;"></i>
                                <span class="fw-bold" style="font-size: 1.2rem; line-height: 1.2;">{{ feature_request.voteCount }}</span>
                            </div>
                        {% endif %}
                    {% else %}
                        <button class="btn btn-outline-secondary d-flex flex-column align-items-center py-2 px-3" style="min-width: 50px;" data-bs-toggle="modal" data-bs-target="#membersExclusiveModal">
                            <i class="bi bi-caret-up-fill" style="font-size: 1.2rem; line-height: 1;"></i>
                            <span class="fw-bold" style="font-size: 1.2rem; line-height: 1.2;">{{ feature_request.voteCount }}</span>
                            <span style="font-size: 0.65rem; line-height: 1; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'feature_requests.vote_button'|trans }}</span>
                        </button>
                    {% endif %}
                </div>

                <div class="flex-grow-1">
                    <h1 class="h4 mb-2">
                        {{ feature_request.title }}
                        {% if is_mine %}
                            <span class="badge bg-primary bg-opacity-10 text-primary ms-1" style="font-size: 0.65rem; vertical-align: middle;">{{ 'feature_requests.yours'|trans }}</span>
                        {% endif %}
                    </h1>
                    <div class="mb-0" style="white-space: pre-line;">{{ feature_request.description }}</div>

                </div>
            </div>

            <div class="d-flex align-items-center gap-2 small text-muted mt-3 pt-3 border-top">
                {{ include('messaging/_avatar.html.twig', {avatar: feature_request.authorAvatar, size: 24}) }}
                <span>{{ 'feature_requests.requested_by'|trans }} <strong>{{ feature_request.authorName }}</strong></span>
                <span>&middot;</span>
                <span>{{ feature_request.createdAt|ago }}</span>
            </div>

            {% if is_mine %}
                <div class="mt-3 pt-3 border-top">
                    {% if has_external_votes %}
                        <small class="text-muted"><i class="bi bi-lock me-1"></i>{{ 'feature_requests.cannot_edit_has_votes'|trans }}</small>
                    {% else %}
                        <div class="d-flex gap-2">
                            <a href="{{ path('feature_request_edit', {'featureRequestId': feature_request.id}) }}" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil me-1"></i>{{ 'feature_requests.edit_button'|trans }}
                            </a>
                            <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                <i class="bi bi-trash me-1"></i>{{ 'feature_requests.delete_button'|trans }}
                            </button>
                        </div>

                        {# Delete confirmation modal #}
                        <div class="modal fade" id="deleteModal" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">{{ 'feature_requests.delete_confirm_title'|trans }}</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p>{{ 'feature_requests.delete_confirm_message'|trans }}</p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">{{ 'feature_requests.report_cancel_button'|trans }}</button>
                                        <form method="post" action="{{ path('feature_request_delete', {'featureRequestId': feature_request.id}) }}">
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <i class="bi bi-trash me-1"></i>{{ 'feature_requests.delete_confirm_button'|trans }}
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

    {# Comments Section #}
    <h2 class="h5 mb-3">
        <i class="bi bi-chat-dots me-1"></i>{{ 'feature_requests.comments_title'|trans }}
        <small class="text-muted">({{ comments|length }})</small>
    </h2>

    {# Comment Form #}
    {% if logged_user.profile is not null and logged_user.profile.activeMembership and comment_form is not null %}
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                {{ form_start(comment_form) }}
                    <div class="mb-2">
                        {{ form_widget(comment_form.content) }}
                    </div>
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-send me-1"></i>{{ 'feature_requests.add_comment_button'|trans }}
                        </button>
                    </div>
                {{ form_end(comment_form) }}
            </div>
        </div>
    {% elseif logged_user.profile is null or not logged_user.profile.activeMembership %}
        <div class="card shadow-sm mb-3 position-relative">
            <div class="card-body">
                <textarea class="form-control mb-2" rows="3" disabled placeholder="{{ 'feature_requests.comment_placeholder'|trans }}"></textarea>
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background: rgba(255,255,255,0.8); border-radius: inherit;">
                    <button
                        class="btn btn-outline-secondary bg-white btn-sm px-3 fs-sm shadow-custom"
                        data-bs-toggle="modal"
                        data-bs-target="#membersExclusiveModal"
                    >
                        <i class="ci-locked me-1"></i>
                        {{ 'feature_requests.comment_members_only'|trans }}
                    </button>
                </div>
            </div>
        </div>
    {% endif %}

    {# Comments List #}
    {% if comments is empty %}
        <p class="text-muted small">{{ 'feature_requests.no_comments_yet'|trans }}</p>
    {% else %}
        <div class="d-flex flex-column gap-2">
            {% for comment in comments %}
                <div class="card shadow-sm">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex align-items-start gap-2">
                            {{ include('messaging/_avatar.html.twig', {avatar: comment.authorAvatar, size: 32}) }}
                            <div class="flex-grow-1 min-width-0">
                                <div class="d-flex align-items-center gap-2 small mb-1">
                                    <strong>{{ comment.authorName }}</strong>
                                    <span class="text-muted">&middot; {{ comment.createdAt|ago }}</span>

                                    {% if logged_user.profile is not null %}
                                        <button
                                            type="button"
                                            class="btn btn-link btn-sm text-muted p-0 ms-auto"
                                            data-bs-toggle="modal"
                                            data-bs-target="#reportModal{{ comment.id|slice(0, 8) }}"
                                            title="{{ 'feature_requests.report_button'|trans }}"
                                        >
                                            <i class="bi bi-flag" style="font-size: 0.75rem;"></i>
                                        </button>

                                        {# Report Modal #}
                                        <div class="modal fade" id="reportModal{{ comment.id|slice(0, 8) }}" tabindex="-1">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">{{ 'feature_requests.report_confirm_title'|trans }}</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <p>{{ 'feature_requests.report_confirm_message'|trans }}</p>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">{{ 'feature_requests.report_cancel_button'|trans }}</button>
                                                        <form method="post" action="{{ path('feature_request_report_comment', {'commentId': comment.id}) }}">
                                                            <button type="submit" class="btn btn-warning btn-sm">
                                                                <i class="bi bi-flag me-1"></i>{{ 'feature_requests.report_confirm_button'|trans }}
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="small" style="white-space: pre-line;">{{ comment.content }}</div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
