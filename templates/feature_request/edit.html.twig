{% extends 'base.html.twig' %}

{% block title %}{{ 'feature_requests.edit_title'|trans }} - {{ feature_request.title }}{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig', {fallbackUrl: path('feature_request_detail', {'featureRequestId': feature_request.id}), fallbackTitle: feature_request.title}) }}

    <h1 class="h3 mb-3">
        <i class="bi bi-pencil me-2"></i>{{ 'feature_requests.edit_title'|trans }}
    </h1>

    <div class="card shadow-sm">
        <div class="card-body">
            {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_row(form.title) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.description) }}
                </div>
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>{{ 'feature_requests.form.save'|trans }}
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
