{% extends 'base.html.twig' %}

{% block title %}{{ 'feature_requests.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'feature_requests.meta_description'|trans }}{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig') }}

    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
        <h1 class="h3 mb-0">
            <i class="bi bi-lightbulb me-2"></i>{{ 'feature_requests.title'|trans }}
        </h1>

        {% if logged_user.profile is not null and logged_user.profile.activeMembership %}
            {% if requests_created_this_month < 3 %}
                <a href="{{ path('feature_request_create') }}" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-lg me-1"></i>{{ 'feature_requests.create_button'|trans }}
                </a>
            {% else %}
                <button class="btn btn-outline-secondary btn-sm" disabled>
                    <i class="bi bi-plus-lg me-1"></i>{{ 'feature_requests.create_button'|trans }}
                    <small class="ms-1 text-muted">({{ 'feature_requests.limit_reached_short'|trans }})</small>
                </button>
            {% endif %}
        {% else %}
            <button
                class="btn btn-outline-secondary bg-white btn-sm px-3 fs-sm shadow-custom"
                data-bs-toggle="modal"
                data-bs-target="#membersExclusiveModal"
            >
                <i class="ci-locked me-1"></i>
                {{ 'feature_requests.create_button'|trans }}
            </button>
        {% endif %}
    </div>

    {% if not hint_dismissed %}
        <div class="alert alert-info small mb-3 d-flex align-items-start">
            <div class="flex-grow-1">
                <i class="bi bi-megaphone me-1"></i>
                {{ 'feature_requests.hint_banner'|trans }}
            </div>
            {% if logged_user.profile is not null %}
                <button type="button" class="btn-close ms-2 flex-shrink-0" aria-label="Close" onclick="fetch('{{ path('dismiss_hint') }}',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'type=feature_requests_intro'});this.closest('.alert').remove()"></button>
            {% endif %}
        </div>
    {% endif %}

    {% if logged_user.profile is not null and logged_user.profile.activeMembership %}
        <div class="small text-muted mb-3">
            {% if votes_used_this_month < 3 %}
                <i class="bi bi-check-circle text-success me-1"></i>
                {{ 'feature_requests.votes_remaining'|trans({'%count%': 3 - votes_used_this_month}) }}
            {% else %}
                <i class="bi bi-clock me-1"></i>
                {{ 'feature_requests.no_votes_remaining'|trans }}
            {% endif %}

            <span class="ms-1 text-muted">
                {{ 'feature_requests.requests_remaining'|trans({'%count%': 3 - requests_created_this_month}) }}
            </span>
        </div>
    {% endif %}

    <twig:FeatureRequestList :votesUsedThisMonth="votes_used_this_month" />
{% endblock %}
