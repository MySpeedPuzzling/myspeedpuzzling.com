{% extends 'base.html.twig' %}

{% block title %}{{ 'for_developers.meta.title'|trans }}{% endblock %}

{% block meta_description %}{{ 'for_developers.meta.description'|trans }}{% endblock %}

{% block content %}
    <div class="text-center mb-5">
        <h1 class="mb-3"><i class="bi bi-code-slash me-2"></i>For Developers</h1>
        <p class="lead text-muted col-lg-8 mx-auto">
            Build integrations with the MySpeedPuzzling platform.
            Access player results, statistics, collections, and more through our REST API.
        </p>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3">
                        <i class="bi bi-book fs-1 text-primary"></i>
                    </div>
                    <h5>API Documentation</h5>
                    <p class="text-muted mb-3">
                        Interactive Swagger UI with all available endpoints, request parameters, and response schemas.
                    </p>
                    <div class="mt-auto">
                        <a href="{{ path('api_doc', {_format: 'html'}) }}" class="btn btn-primary btn-shadow" target="_blank">
                            <i class="bi bi-box-arrow-up-right me-1"></i> Open API Docs
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3">
                        <i class="bi bi-play-circle fs-1 text-primary"></i>
                    </div>
                    <h5>Live Demo</h5>
                    <p class="text-muted mb-3">
                        See a working OAuth2 integration in action. Authenticate, fetch data, and explore the flow.
                    </p>
                    <div class="mt-auto">
                        <a href="https://oauth2-demo.myspeedpuzzling.com" class="btn btn-outline-primary" target="_blank" rel="noopener">
                            <i class="bi bi-box-arrow-up-right me-1"></i> Try the Demo
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3">
                        <i class="bi bi-github fs-1 text-primary"></i>
                    </div>
                    <h5>Source Code</h5>
                    <p class="text-muted mb-3">
                        Full PHP demo application showing OAuth2 authorization code flow. Clone it and start building.
                    </p>
                    <div class="mt-auto">
                        <a href="https://github.com/MySpeedPuzzling/oauth2-client-demo-application" class="btn btn-outline-primary" target="_blank" rel="noopener">
                            <i class="bi bi-github me-1"></i> View on GitHub
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h4 mb-3"><i class="bi bi-shield-lock me-2"></i>Authentication</h2>

    <p class="text-muted mb-4">
        Two ways to authenticate with the API, depending on your use case.
    </p>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-key fs-4 text-primary me-3"></i>
                        <h5 class="mb-0">Personal Access Token</h5>
                    </div>
                    <p class="text-muted mb-2">
                        Generate a token to access <strong>your own data</strong> programmatically.
                        Great for Home Assistant, personal scripts, and automations.
                    </p>
                    <p class="text-muted mb-0 fs-sm">
                        <code>Authorization: Token msp_pat_...</code>
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-person-badge fs-4 text-primary me-3"></i>
                        <h5 class="mb-0">OAuth2 &mdash; User Auth</h5>
                    </div>
                    <p class="text-muted mb-0">
                        Authorization code flow for third-party apps. Users authorize your app to access their data
                        with granular scopes. Supports read and write operations.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-hdd-network fs-4 text-primary me-3"></i>
                        <h5 class="mb-0">OAuth2 &mdash; Service</h5>
                    </div>
                    <p class="text-muted mb-0">
                        Client credentials flow for service-to-service communication.
                        Read-only access to any public player's data without user interaction.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h4 mb-3"><i class="bi bi-unlock me-2"></i>Available Scopes</h2>

    <div class="row g-3 mb-5">
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <code class="text-primary fw-bold">profile:read</code>
                    <span class="badge bg-success ms-2">default</span>
                    <p class="text-muted mb-0 mt-1 fs-sm">Read user profile data (name, avatar, country, bio)</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <code class="text-primary fw-bold">results:read</code>
                    <p class="text-muted mb-0 mt-1 fs-sm">Read puzzle solving results (times, puzzles, attempts)</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <code class="text-primary fw-bold">statistics:read</code>
                    <p class="text-muted mb-0 mt-1 fs-sm">Read player statistics (total times, pieces, counts)</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <code class="text-primary fw-bold">collections:read</code>
                    <p class="text-muted mb-0 mt-1 fs-sm">Read player puzzle collections and items</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <code class="text-warning fw-bold">solving-times:write</code>
                    <span class="badge bg-info ms-2">auth code only</span>
                    <p class="text-muted mb-0 mt-1 fs-sm">Create and edit puzzle solving times</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <code class="text-warning fw-bold">collections:write</code>
                    <span class="badge bg-info ms-2">auth code only</span>
                    <p class="text-muted mb-0 mt-1 fs-sm">Create, edit, delete collections and items</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-5">
        <div class="card-body d-flex align-items-center">
            <i class="bi bi-file-earmark-text fs-4 text-primary me-3"></i>
            <div>
                <h5 class="mb-1">Fair Use Policy</h5>
                <p class="text-muted mb-0">
                    Before generating tokens or requesting API access, please read and accept our
                    <a href="{{ path('fair_use_policy') }}">API Fair Use Policy</a>.
                </p>
            </div>
        </div>
    </div>

    <h2 class="h4 mb-3"><i class="bi bi-rocket-takeoff me-2"></i>Get Started</h2>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-key fs-4 text-primary me-3"></i>
                        <h5 class="mb-0">Personal Use</h5>
                    </div>
                    <p class="text-muted mb-3">
                        Want to access your own data? Generate a Personal Access Token instantly from your profile settings.
                        No approval needed.
                    </p>
                    {% if logged_user.profile is not null %}
                        <a href="{{ path('edit_profile') }}" class="btn btn-primary btn-sm">
                            <i class="bi bi-gear me-1"></i> Go to Settings
                        </a>
                    {% else %}
                        <a href="{{ path('my_profile') }}" class="btn btn-primary btn-sm">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-building fs-4 text-primary me-3"></i>
                        <h5 class="mb-0">Third-Party Application</h5>
                    </div>
                    <p class="text-muted mb-3">
                        Building an app that needs OAuth2 access? Submit a request and we'll review it.
                        You'll receive credentials once approved.
                    </p>
                    {% if logged_user.profile is not null %}
                        <a href="{{ path('request_api_access') }}" class="btn btn-primary btn-sm">
                            <i class="bi bi-send me-1"></i> Request API Access
                        </a>
                    {% else %}
                        <a href="{{ path('my_profile') }}" class="btn btn-primary btn-sm">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Sign In to Request
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="text-center text-muted mb-4">
        <p class="mb-0 fs-sm">
            Questions? Reach out at <a href="mailto:jan@myspeedpuzzling.com">jan@myspeedpuzzling.com</a>.
        </p>
    </div>
{% endblock %}
