{% extends 'base.html.twig' %}

{% block title %}{{ 'competition.manage_participants'|trans }} - {{ competition.name }}{% endblock %}

{% block content %}
    <div class="pb-4">
        <h1 class="h2">{{ competition.name }}</h1>

        <div class="mb-3">
            <a href="{{ path('edit_competition', {'competitionId': competition.id}) }}" class="btn btn-outline-secondary me-2">
                <i class="bi bi-arrow-left me-1"></i>{{ 'competition.back_to_edit'|trans }}
            </a>
        </div>

        <h2 class="h4 mt-4">{{ 'competition.manage_participants'|trans }}</h2>

        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>{{ 'competition.participants_coming_soon'|trans }}
        </div>
    </div>
{% endblock %}
