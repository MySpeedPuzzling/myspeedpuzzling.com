{% extends 'base.html.twig' %}

{% block title %}{{ 'puzzle_intelligence.methodology.title'|trans }}{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig') }}

    <h1 class="h2 mb-1">{{ 'puzzle_intelligence.methodology.title'|trans }}</h1>
    <p class="text-muted mb-4">{{ 'puzzle_intelligence.methodology.subtitle'|trans }}</p>

    {# Quick overview cards #}
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center">
                    <i class="bi bi-bar-chart fs-1 text-primary mb-2 d-block"></i>
                    <h6>{{ 'puzzle_intelligence.difficulty.title'|trans }}</h6>
                    <p class="text-muted fs-sm mb-0">How hard is each puzzle? We compare your time to your personal average to find out.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center">
                    <i class="bi bi-trophy fs-1 text-warning mb-2 d-block"></i>
                    <h6>{{ 'puzzle_intelligence.skill.title'|trans }}</h6>
                    <p class="text-muted fs-sm mb-0">How skilled are you? We rank you against other solvers on each puzzle, weighted by difficulty.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center">
                    <i class="bi bi-lightning fs-1 text-danger mb-2 d-block"></i>
                    <h6>{{ 'puzzle_intelligence.elo.title'|trans }}</h6>
                    <p class="text-muted fs-sm mb-0">Portfolio-based competitive rating. Your best results from the last 12 months, difficulty-weighted.</p>
                </div>
            </div>
        </div>
    </div>

    {# Section 1: Player Baseline #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">1</span>
                {{ 'puzzle_intelligence.methodology.section_baseline_title'|trans }}
            </h4>
            <p>{{ 'puzzle_intelligence.methodology.section_baseline_desc'|trans|raw }}</p>

            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2">
                    <div class="row align-items-center fs-sm">
                        <div class="col-md-6">
                            <div class="d-flex justify-content-between py-1">
                                <span>Yesterday</span>
                                <div>
                                    <div class="progress" style="width: 120px; height: 6px;">
                                        <div class="progress-bar bg-primary" style="width: 100%;"></div>
                                    </div>
                                    <small class="text-muted">100% weight</small>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between py-1">
                                <span>6 months ago</span>
                                <div>
                                    <div class="progress" style="width: 120px; height: 6px;">
                                        <div class="progress-bar bg-primary" style="width: 72%;"></div>
                                    </div>
                                    <small class="text-muted">72% weight</small>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between py-1">
                                <span>18 months ago</span>
                                <div>
                                    <div class="progress" style="width: 120px; height: 6px;">
                                        <div class="progress-bar bg-primary" style="width: 37%;"></div>
                                    </div>
                                    <small class="text-muted">37% weight</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-white rounded p-2 text-center">
                                <code class="fs-sm">weight = exp(-age_in_months / 18)</code>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_baseline_minimum'|trans|raw }}</p>

            {# Interpolated baselines #}
            <div class="card bg-light border-0 mt-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium"><i class="bi bi-diagram-3 me-1"></i> Exotic piece counts</p>
                    <p class="mb-0 text-muted">For puzzles with unusual piece counts (e.g. 631 pieces), most players won't have 5 solves at that exact count. We solve this by estimating their baseline from nearby piece counts they <em>do</em> have data for, using log-space interpolation. This means more puzzles get difficulty ratings.</p>
                </div>
            </div>
        </div>
    </div>

    {# Section 2: Puzzle Difficulty #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">2</span>
                {{ 'puzzle_intelligence.methodology.section_difficulty_title'|trans }}
            </h4>
            <p>{{ 'puzzle_intelligence.methodology.section_difficulty_desc'|trans|raw }}</p>

            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2">
                    <div class="row fs-sm">
                        <div class="col-md-6">
                            <p class="mb-1 fw-medium">Example:</p>
                            <p class="mb-1">Your baseline: <strong>55 min</strong></p>
                            <p class="mb-1">You solved this puzzle in: <strong>63 min</strong></p>
                            <p class="mb-1">Difficulty index: 63 / 55 = <strong>1.15</strong></p>
                            <p class="mb-0 text-muted">→ 15% harder than average for you</p>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-white rounded p-2 text-center">
                                <code class="fs-sm">difficulty_index = solve_time / player_baseline</code>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_difficulty_median'|trans|raw }}</p>
            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_difficulty_minimum'|trans|raw }}</p>

            <h6 class="mt-3 mb-2">{{ 'puzzle_intelligence.methodology.section_difficulty_tiers_title'|trans }}</h6>
            <div class="row g-2">
                {% set tiers = [
                    {score: '< 0.75', key: 'veryeasy', icon: 'diff-very-easy', meaning: '25%+ easier than typical'},
                    {score: '0.75 – 0.90', key: 'easy', icon: 'diff-easy', meaning: '10-25% easier'},
                    {score: '0.90 – 1.10', key: 'average', icon: 'diff-average', meaning: 'About typical'},
                    {score: '1.10 – 1.25', key: 'challenging', icon: 'diff-challenging', meaning: '10-25% harder'},
                    {score: '1.25 – 1.45', key: 'hard', icon: 'diff-hard', meaning: '25-45% harder'},
                    {score: '> 1.45', key: 'veryhard', icon: 'diff-very-hard', meaning: '45%+ harder'},
                ] %}
                {% for tier in tiers %}
                    <div class="col-6 col-md-3 col-lg">
                        <div class="text-center">
                            <span class="badge badge-tier-{{ tier.key }} w-100 py-2" style="font-size: 16px;">
                                <svg class="diff-icon" width="24" height="24" style="color: #fff"><use href="/difficulty-icons-sprite.svg#{{ tier.icon }}"/></svg>
                                {{ ('puzzle_intelligence.difficulty.tiers.' ~ tier.key)|trans }}
                            </span>
                            <div class="fs-sm text-muted mt-1">{{ tier.meaning }}</div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Section 3: Player Skill #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">3</span>
                {{ 'puzzle_intelligence.methodology.section_skill_title'|trans }}
            </h4>
            <p>{{ 'puzzle_intelligence.methodology.section_skill_desc'|trans|raw }}</p>

            {# Worked example #}
            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium">Example: How your skill score is calculated</p>
                    <p class="mb-1">You solved <strong>Puzzle X</strong> in 45 min.</p>
                    <p class="mb-1">Out of 50 first-attempt solvers, <strong>38 were slower</strong> → your percentile = <strong>0.78</strong></p>
                    <p class="mb-1">Puzzle X is <strong>Challenging</strong> (difficulty 1.18) → difficulty weight = <strong>1.09</strong></p>
                    <p class="mb-1">Weighted percentile: 0.78 × 1.09 = <strong>0.85</strong></p>
                    <p class="mb-0 text-muted">Your skill score = median of all such weighted percentiles across your qualifying puzzles.</p>
                </div>
            </div>

            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_skill_minimum'|trans|raw }}</p>

            {# Collapsible exact formula #}
            <button class="btn btn-outline-secondary btn-sm mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#skillFormula">
                <i class="bi bi-code me-1"></i> Show exact formula
            </button>
            <div class="collapse mb-3" id="skillFormula">
                <div class="card bg-light border-0">
                    <div class="card-body py-2">
<pre class="fs-sm mb-0"><code>For each puzzle with 20+ first-attempt solvers:
  percentile = (slower_count + tied_count / 2) / (total_solvers - 1)
  confidence = min(1.0, sample_size / 50)
  blend = 0.5 × confidence
  difficulty_weight = (1 - blend) + blend × puzzle_difficulty
  weighted_percentile = percentile × difficulty_weight

skill_score = median(all weighted_percentiles)

Tier = based on percentile rank among all players</code></pre>
                    </div>
                </div>
            </div>

            <h6 class="mt-3 mb-2">{{ 'puzzle_intelligence.methodology.section_skill_tiers_title'|trans }}</h6>
            <div class="row g-2 mb-2">
                {% set skill_tiers = [
                    {pct: 'Top 1%', key: 'legend'},
                    {pct: 'Top 5%', key: 'master'},
                    {pct: 'Top 15%', key: 'expert'},
                    {pct: 'Top 30%', key: 'advanced'},
                    {pct: 'Top 50%', key: 'proficient'},
                    {pct: 'Top 75%', key: 'enthusiast'},
                    {pct: 'Bottom 25%', key: 'casual'},
                ] %}
                {% for tier in skill_tiers %}
                    <div class="col-6 col-md-3 col-lg">
                        <div class="text-center">
                            <span class="badge badge-skill-{{ tier.key }} w-100 py-2" style="font-size: 16px;">
                                <svg class="rank-icon" width="24" height="24" style="color: #fff"><use href="/rank-icons-sprite.svg#rank-{{ tier.key }}"/></svg>
                                {{ ('puzzle_intelligence.skill.tiers.' ~ tier.key)|trans }}
                            </span>
                            <div class="fs-sm text-muted mt-1">{{ tier.pct }}</div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Section 4: MSP-ELO #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">4</span>
                {{ 'puzzle_intelligence.methodology.section_elo_title'|trans }}
            </h4>
            <p>{{ 'puzzle_intelligence.methodology.section_elo_desc'|trans }}</p>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <div class="card bg-light border-0 h-100">
                        <div class="card-body py-2 fs-sm">
                            <h6 class="fs-sm"><i class="bi bi-star me-1"></i> First attempts (75%)</h6>
                            <p class="mb-0 text-muted">Solving a puzzle cold carries the most weight — it's the purest measure of skill. Your top 100 first-attempt results are evaluated.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card bg-light border-0 h-100">
                        <div class="card-body py-2 fs-sm">
                            <h6 class="fs-sm"><i class="bi bi-arrow-repeat me-1"></i> Best times (25%)</h6>
                            <p class="mb-0 text-muted">Your fastest time on each puzzle counts too — genuine improvement through practice is rewarded, but at lower weight than cold solving.</p>
                        </div>
                    </div>
                </div>
            </div>

            {# Worked examples #}
            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium">Example: Cold Solver vs Grinder</p>
                    <p class="mb-1">Same <strong>Hard</strong> puzzle (difficulty 1.35, weight 1.175):</p>
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Player A:</strong> Strong first attempt (92nd percentile), never re-solves</p>
                            <p class="mb-0 text-muted">Score: 0.92 × 1.175 = <strong>1.08</strong></p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Player B:</strong> Weak first attempt (60th), grinds to 95th percentile best</p>
                            <p class="mb-0 text-muted">Score: 0.75 × 0.70 + 0.25 × 1.12 = <strong>0.81</strong></p>
                        </div>
                    </div>
                    <p class="mt-1 mb-0 text-muted">Player A wins decisively — raw cold-solving talent leads, but B gets partial credit for improvement.</p>
                </div>
            </div>

            {# Anti-gaming #}
            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium"><i class="bi bi-shield-check me-1"></i> Anti-gaming properties</p>
                    <ul class="mb-0 text-muted ps-3">
                        <li><strong>Grinding same puzzle:</strong> Only affects one best-time entry (25% weight). First-attempt score is locked.</li>
                        <li><strong>Volume accumulation:</strong> Cap of 100. After 100 puzzles, more solves only help if better than your weakest entry.</li>
                        <li><strong>Easy puzzle farming:</strong> Difficulty weighting makes hard puzzles worth more at the same percentile.</li>
                    </ul>
                </div>
            </div>

            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_elo_minimum'|trans|raw }}</p>

            {# Collapsible exact formula #}
            <button class="btn btn-outline-secondary btn-sm mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#eloFormula">
                <i class="bi bi-code me-1"></i> Show exact formula
            </button>
            <div class="collapse" id="eloFormula">
                <div class="card bg-light border-0">
                    <div class="card-body py-2">
<pre class="fs-sm mb-0"><code>For each puzzle in 12-month window (20+ public solvers):
  fa_percentile = rank among first-attempt solvers (0–1)
  bt_percentile = rank among all players' best times (0–1)
  difficulty_weight = (1 - 0.5 × confidence) + 0.5 × confidence × difficulty
  fa_points = fa_percentile × difficulty_weight
  bt_points = bt_percentile × difficulty_weight

First-attempt portfolio = mean(top 100 fa_points)
Best-time portfolio = mean(top 100 bt_points)
Rating = 0.75 × FA_portfolio + 0.25 × BT_portfolio

Display: rating × 1000 (e.g., 0.85 → 850)</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Section 5: Time Prediction #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">5</span>
                {{ 'puzzle_intelligence.methodology.section_prediction_title'|trans }}
            </h4>

            <div class="card bg-light border-0 mb-2">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium">Example:</p>
                    <p class="mb-1">Your 500pc baseline: <strong>55 min</strong></p>
                    <p class="mb-1">Puzzle difficulty: <strong>1.15</strong> (Challenging)</p>
                    <p class="mb-1">Predicted time: 55 × 1.15 = <strong>~63 min</strong></p>
                    <p class="mb-0 text-muted">Range: 57 – 70 min (bounded between 30% and 300% of predicted time)</p>
                </div>
            </div>

            <div class="bg-white rounded p-2 text-center mb-2">
                <code class="fs-sm">predicted_time = player_baseline × puzzle_difficulty</code>
            </div>
        </div>
    </div>

    {# Section 6: Puzzle Personality #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">6</span>
                {{ 'puzzle_intelligence.methodology.section_personality_title'|trans }}
            </h4>

            <div class="row g-3">
                {% set metrics = [
                    {icon: 'bi-arrow-repeat', name: 'puzzle_intelligence.personality.memorability', desc: 'puzzle_intelligence.personality.memorability_desc', detail: 'Measures how quickly players learn this puzzle across their first 3 attempts. Normalized against the average puzzle learning rate. Min: 8 players with 3+ attempts.'},
                    {icon: 'bi-speedometer2', name: 'puzzle_intelligence.personality.skill_sensitivity', desc: 'puzzle_intelligence.personality.skill_sensitivity_desc', detail: 'Ratio of 75th to 25th percentile difficulty indices. Higher = bigger gap between fast and slow solvers. Min: 20 qualifying indices.'},
                    {icon: 'bi-bullseye', name: 'puzzle_intelligence.personality.predictability', desc: 'puzzle_intelligence.personality.predictability_desc', detail: 'Score from 0 to 1 (bounded). Formula: 1 / (1 + coefficient of variation). Closer to 1 = more consistent difficulty experience. Min: 20 qualifying indices.'},
                    {icon: 'bi-box', name: 'puzzle_intelligence.personality.box_dependence', desc: 'puzzle_intelligence.personality.box_dependence_desc', detail: 'Ratio of unboxed to boxed difficulty. 1.0 = no difference, 2.0 = twice as hard without box. Min: 10 unboxed + 5 boxed solvers.'},
                    {icon: 'bi-graph-up-arrow', name: 'puzzle_intelligence.personality.improvement_ceiling', desc: 'puzzle_intelligence.personality.improvement_ceiling_desc', detail: 'Ratio of median first-attempt time to 10th percentile of all attempts. Higher means practice dramatically improves times. Min: 20 solvers.'},
                ] %}
                {% for metric in metrics %}
                    <div class="col-md-6">
                        <div class="card bg-light border-0 h-100">
                            <div class="card-body py-2">
                                <h6 class="fs-sm">
                                    <i class="{{ metric.icon }} me-1"></i>
                                    {{ metric.name|trans }}
                                </h6>
                                <p class="fs-sm text-muted mb-1">{{ metric.desc|trans }}</p>
                                <small class="text-muted fst-italic">{{ metric.detail }}</small>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Section 7: Confidence + Data Quality #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">7</span>
                {{ 'puzzle_intelligence.difficulty.confidence_label'|trans }} & {{ 'puzzle_intelligence.methodology.section_data_quality_title'|trans }}
            </h4>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <h6 class="fs-sm"><i class="bi bi-shield-check me-1"></i>{{ 'puzzle_intelligence.methodology.section_confidence_title'|trans }}</h6>
                    <p class="fs-sm text-muted mb-2">Every metric shows how confident we are, based on the amount of data:</p>
                    <div class="d-flex flex-column gap-2 fs-sm">
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-confidence-high"><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i></span>
                            <strong>{{ 'puzzle_intelligence.difficulty.confidence_levels.high'|trans }}</strong> — 20+ qualified solvers
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-confidence-medium"><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i><i class="bi bi-circle text-muted" style="font-size: 0.5rem;"></i></span>
                            <strong>{{ 'puzzle_intelligence.difficulty.confidence_levels.medium'|trans }}</strong> — 10-19 solvers
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-confidence-low"><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i><i class="bi bi-circle text-muted" style="font-size: 0.5rem;"></i><i class="bi bi-circle text-muted" style="font-size: 0.5rem;"></i></span>
                            <strong>{{ 'puzzle_intelligence.difficulty.confidence_levels.low'|trans }}</strong> — 5-9 solvers
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted"><i class="bi bi-circle" style="font-size: 0.5rem;"></i><i class="bi bi-circle" style="font-size: 0.5rem;"></i><i class="bi bi-circle" style="font-size: 0.5rem;"></i></span>
                            {{ 'puzzle_intelligence.difficulty.not_enough_data'|trans }} — fewer than 5 solvers
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <h6 class="fs-sm">{{ 'puzzle_intelligence.methodology.section_data_quality_title'|trans }}</h6>
                    <p class="fs-sm text-muted mb-2">To ensure accuracy, we only use:</p>
                    <ul class="fs-sm mb-0">
                        <li>{{ 'puzzle_intelligence.methodology.section_data_quality_solo'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.section_data_quality_first'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.section_data_quality_outlier'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.section_data_quality_suspicious'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.section_data_quality_recency'|trans|raw }}</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <p class="text-muted fs-sm text-center mt-4 mb-2" data-controller="next-hour-countdown">
        <i class="bi bi-clock me-1"></i>
        {{ 'puzzle_intelligence.methodology.section_recalculation_countdown'|trans }}
        <strong><span data-next-hour-countdown-target="display">--:--</span></strong>
    </p>
{% endblock %}
