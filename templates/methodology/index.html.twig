{% extends 'base.html.twig' %}

{% block title %}{{ 'puzzle_intelligence.methodology.title'|trans }}{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig') }}

    <h1 class="h2 mb-1">{{ 'puzzle_intelligence.methodology.title'|trans }}</h1>
    <p class="text-muted mb-4">{{ 'puzzle_intelligence.methodology.subtitle'|trans }}</p>

    {# Quick overview cards #}
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center">
                    <i class="bi bi-bar-chart fs-1 text-primary mb-2 d-block"></i>
                    <h6>{{ 'puzzle_intelligence.difficulty.title'|trans }}</h6>
                    <p class="text-muted fs-sm mb-0">{{ 'puzzle_intelligence.methodology.overview_difficulty_desc'|trans }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center">
                    <i class="bi bi-trophy fs-1 text-warning mb-2 d-block"></i>
                    <h6>{{ 'puzzle_intelligence.skill.title'|trans }}</h6>
                    <p class="text-muted fs-sm mb-0">{{ 'puzzle_intelligence.methodology.overview_skill_desc'|trans }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center">
                    <i class="bi bi-lightning fs-1 text-danger mb-2 d-block"></i>
                    <h6>{{ 'puzzle_intelligence.elo.title'|trans }}</h6>
                    <p class="text-muted fs-sm mb-0">{{ 'puzzle_intelligence.methodology.overview_elo_desc'|trans }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Section 1: Player Baseline #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">1</span>
                {{ 'puzzle_intelligence.methodology.section_baseline_title'|trans }}
            </h4>
            <p>{{ 'puzzle_intelligence.methodology.section_baseline_desc'|trans|raw }}</p>

            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2">
                    <div class="row align-items-center fs-sm">
                        <div class="col-md-6">
                            <p class="mb-2 fw-medium">{{ 'puzzle_intelligence.methodology.baseline_decay_title'|trans }}</p>
                            <p class="mb-2 text-muted">{{ 'puzzle_intelligence.methodology.baseline_decay_desc'|trans }}</p>
                            {% set baseline_decay = [
                                {label: '0 – 3 months', pct: 100, weight: '100%'},
                                {label: '6 months', pct: 80, weight: '80%'},
                                {label: '12 months', pct: 51, weight: '51%'},
                                {label: '18 months', pct: 33, weight: '33%'},
                                {label: '24 months', pct: 21, weight: '21%'},
                            ] %}
                            {% for item in baseline_decay %}
                                <div class="d-flex justify-content-between py-1">
                                    <span>{{ item.label }}</span>
                                    <div>
                                        <div class="progress" style="width: 120px; height: 6px;">
                                            <div class="progress-bar bg-primary" style="width: {{ item.pct }}%;"></div>
                                        </div>
                                        <small class="text-muted">{{ item.weight }} weight</small>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <div class="col-md-6">
                            <div class="bg-white rounded p-2 text-center mb-2">
                                <code class="fs-sm">effective_age = max(0, age_in_months - 3)</code><br>
                                <code class="fs-sm">weight = exp(-effective_age / 13.5)</code>
                            </div>
                            <p class="mb-0 text-muted fs-sm">{{ 'puzzle_intelligence.methodology.baseline_decay_formula_note'|trans|raw }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_baseline_minimum'|trans|raw }}</p>

            <div class="card bg-light border-0 mt-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium"><i class="bi bi-diagram-3 me-1"></i> {{ 'puzzle_intelligence.methodology.baseline_exotic_title'|trans }}</p>
                    <p class="mb-0 text-muted">{{ 'puzzle_intelligence.methodology.baseline_exotic_desc'|trans|raw }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Section 2: Puzzle Difficulty #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">2</span>
                {{ 'puzzle_intelligence.methodology.section_difficulty_title'|trans }}
            </h4>
            <p>{{ 'puzzle_intelligence.methodology.section_difficulty_desc'|trans|raw }}</p>

            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2">
                    <div class="row fs-sm">
                        <div class="col-md-6">
                            <p class="mb-1 fw-medium">{{ 'puzzle_intelligence.methodology.difficulty_example_baseline'|trans }} <strong>55 min</strong></p>
                            <p class="mb-1">{{ 'puzzle_intelligence.methodology.difficulty_example_time'|trans }} <strong>63 min</strong></p>
                            <p class="mb-1">{{ 'puzzle_intelligence.methodology.difficulty_example_index'|trans }} 63 / 55 = <strong>1.15</strong></p>
                            <p class="mb-0 text-muted">&rarr; {{ 'puzzle_intelligence.methodology.difficulty_example_meaning'|trans }}</p>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-white rounded p-2 text-center mb-2">
                                <code class="fs-sm">difficulty_index = solve_time / player_baseline</code>
                            </div>
                            <div class="bg-white rounded p-2 text-center">
                                <code class="fs-sm">puzzle_difficulty = median(all player indices)</code>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_difficulty_median'|trans|raw }}</p>
            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_difficulty_minimum'|trans|raw }}</p>

            <button class="btn btn-outline-secondary btn-sm mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#difficultyFormula">
                <i class="bi bi-code me-1"></i> {{ 'puzzle_intelligence.methodology.show_formula'|trans }}
            </button>
            <div class="collapse mb-3" id="difficultyFormula">
                <div class="card bg-light border-0">
                    <div class="card-body py-2">
<pre class="fs-sm mb-0"><code>For each player with a baseline at this piece count:
  difficulty_index = seconds_to_solve / player_baseline

  Qualification:
  - First attempt only (one per player per puzzle)
  - Solo, non-suspicious, completed
  - Index must be &lt;= 5.0 (outlier ceiling)

puzzle_difficulty = median(all qualifying indices)
Minimum: 5 indices from different players</code></pre>
                    </div>
                </div>
            </div>

            <h6 class="mt-3 mb-2">{{ 'puzzle_intelligence.methodology.section_difficulty_tiers_title'|trans }}</h6>
            <div class="row g-2">
                {% set tiers = [
                    {score: '< 0.75', key: 'veryeasy', icon: 'diff-very-easy', meaning: '25%+ easier than typical'},
                    {score: '0.75 – 0.90', key: 'easy', icon: 'diff-easy', meaning: '10-25% easier'},
                    {score: '0.90 – 1.10', key: 'average', icon: 'diff-average', meaning: 'About typical'},
                    {score: '1.10 – 1.25', key: 'challenging', icon: 'diff-challenging', meaning: '10-25% harder'},
                    {score: '1.25 – 1.45', key: 'hard', icon: 'diff-hard', meaning: '25-45% harder'},
                    {score: '> 1.45', key: 'veryhard', icon: 'diff-very-hard', meaning: '45%+ harder'},
                ] %}
                {% for tier in tiers %}
                    <div class="col-6 col-md-3 col-lg">
                        <div class="text-center">
                            <span class="badge badge-tier-{{ tier.key }} w-100 py-2" style="font-size: 16px;">
                                <svg class="diff-icon" width="24" height="24" style="color: #fff"><use href="/difficulty-icons-sprite.svg#{{ tier.icon }}"/></svg>
                                {{ ('puzzle_intelligence.difficulty.tiers.' ~ tier.key)|trans }}
                            </span>
                            <div class="fs-sm text-muted mt-1">{{ tier.meaning }}</div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Section 3: Player Skill #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">3</span>
                {{ 'puzzle_intelligence.methodology.section_skill_title'|trans }}
            </h4>
            <p>{{ 'puzzle_intelligence.methodology.section_skill_desc'|trans|raw }}</p>

            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium">{{ 'puzzle_intelligence.methodology.skill_example_title'|trans }}</p>
                    <p class="mb-1">{{ 'puzzle_intelligence.methodology.skill_example_desc'|trans|raw }}</p>
                    <p class="mb-1">{{ 'puzzle_intelligence.methodology.skill_example_slower'|trans|raw }}</p>
                    <p class="mb-1">{{ 'puzzle_intelligence.methodology.skill_example_difficulty'|trans|raw }}</p>
                    <p class="mb-1">{{ 'puzzle_intelligence.methodology.skill_example_weighted'|trans|raw }}</p>
                    <p class="mb-1">{{ 'puzzle_intelligence.methodology.skill_example_age'|trans|raw }}</p>
                    <p class="mb-0 text-muted">{{ 'puzzle_intelligence.methodology.skill_example_result'|trans }}</p>
                </div>
            </div>

            {# Skill recency weighting with progress bars #}
            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium"><i class="bi bi-clock-history me-1"></i> {{ 'puzzle_intelligence.methodology.skill_decay_title'|trans }}</p>
                    <p class="mb-2 text-muted">{{ 'puzzle_intelligence.methodology.skill_decay_desc'|trans }}</p>
                    <div class="row">
                        <div class="col-md-6">
                            {% set skill_decay = [
                                {label: '0 – 6 months', pct: 100, weight: '100%'},
                                {label: '12 months', pct: 78, weight: '78%'},
                                {label: '18 months', pct: 61, weight: '61%'},
                                {label: '24 months', pct: 47, weight: '47%'},
                                {label: '36 months', pct: 29, weight: '29%'},
                            ] %}
                            {% for item in skill_decay %}
                                <div class="d-flex justify-content-between py-1">
                                    <span>{{ item.label }}</span>
                                    <div>
                                        <div class="progress" style="width: 120px; height: 6px;">
                                            <div class="progress-bar bg-warning" style="width: {{ item.pct }}%;"></div>
                                        </div>
                                        <small class="text-muted">{{ item.weight }} weight</small>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <div class="col-md-6">
                            <div class="bg-white rounded p-2 text-center">
                                <code class="fs-sm">effective_age = max(0, age_months - 6)</code><br>
                                <code class="fs-sm">age_weight = exp(-effective_age / 24)</code>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_skill_minimum'|trans|raw }}</p>

            <button class="btn btn-outline-secondary btn-sm mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#skillFormula">
                <i class="bi bi-code me-1"></i> {{ 'puzzle_intelligence.methodology.show_formula'|trans }}
            </button>
            <div class="collapse mb-3" id="skillFormula">
                <div class="card bg-light border-0">
                    <div class="card-body py-2">
<pre class="fs-sm mb-0"><code>For each puzzle with 20+ first-attempt solvers:
  percentile = (slower_count + tied_count / 2) / (total_solvers - 1)
  confidence = min(1.0, sample_size / 50)
  blend = 0.5 &times; confidence
  difficulty_weight = (1 - blend) + blend &times; puzzle_difficulty
  weighted_percentile = percentile &times; difficulty_weight

  effective_age = max(0, age_in_months - 6)
  age_weight = exp(-effective_age / 24)

skill_score = weighted_median(weighted_percentiles, age_weights)

Tier = based on percentile rank among all players</code></pre>
                    </div>
                </div>
            </div>

            <h6 class="mt-3 mb-2">{{ 'puzzle_intelligence.methodology.section_skill_tiers_title'|trans }}</h6>
            <div class="row g-2 mb-2">
                {% set skill_tiers = [
                    {pct: 'Bottom 25%', key: 'enthusiast'},
                    {pct: 'Top 75%', key: 'apprentice'},
                    {pct: 'Top 50%', key: 'proficient'},
                    {pct: 'Top 30%', key: 'advanced'},
                    {pct: 'Top 15%', key: 'expert'},
                    {pct: 'Top 5%', key: 'master'},
                    {pct: 'Top 1%', key: 'legend'},
                ] %}
                {% for tier in skill_tiers %}
                    <div class="col-6 col-md-3 col-lg">
                        <div class="text-center">
                            <span class="badge badge-skill-{{ tier.key }} w-100 py-2" style="font-size: 16px;">
                                <svg class="rank-icon" width="24" height="24" style="color: #fff"><use href="/rank-icons-sprite.svg#rank-{{ tier.key }}"/></svg>
                                {{ ('puzzle_intelligence.skill.tiers.' ~ tier.key)|trans }}
                            </span>
                            <div class="fs-sm text-muted mt-1">{{ tier.pct }}</div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Section 4: MSP Rating #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">4</span>
                {{ 'puzzle_intelligence.methodology.section_elo_title'|trans }}
            </h4>
            <p>{{ 'puzzle_intelligence.methodology.section_elo_desc'|trans|raw }}</p>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <div class="card bg-light border-0 h-100">
                        <div class="card-body py-2 fs-sm">
                            <h6 class="fs-sm"><i class="bi bi-star me-1"></i> {{ 'puzzle_intelligence.methodology.elo_fa_title'|trans }}</h6>
                            <p class="mb-0 text-muted">{{ 'puzzle_intelligence.methodology.elo_fa_desc'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card bg-light border-0 h-100">
                        <div class="card-body py-2 fs-sm">
                            <h6 class="fs-sm"><i class="bi bi-arrow-repeat me-1"></i> {{ 'puzzle_intelligence.methodology.elo_bt_title'|trans }}</h6>
                            <p class="mb-0 text-muted">{{ 'puzzle_intelligence.methodology.elo_bt_desc'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>

            {# Rating recency weighting with progress bars #}
            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium"><i class="bi bi-clock-history me-1"></i> {{ 'puzzle_intelligence.methodology.elo_decay_title'|trans }}</p>
                    <p class="mb-2 text-muted">{{ 'puzzle_intelligence.methodology.elo_decay_desc'|trans }}</p>
                    <div class="row">
                        <div class="col-md-6">
                            {% set rating_decay = [
                                {label: '0 – 3 months', pct: 100, weight: '100%'},
                                {label: '6 months', pct: 90, weight: '90%'},
                                {label: '12 months', pct: 74, weight: '74%'},
                                {label: '18 months', pct: 61, weight: '61%'},
                                {label: '24 months', pct: 50, weight: '50%'},
                            ] %}
                            {% for item in rating_decay %}
                                <div class="d-flex justify-content-between py-1">
                                    <span>{{ item.label }}</span>
                                    <div>
                                        <div class="progress" style="width: 120px; height: 6px;">
                                            <div class="progress-bar bg-danger" style="width: {{ item.pct }}%;"></div>
                                        </div>
                                        <small class="text-muted">{{ item.weight }} weight</small>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <div class="col-md-6">
                            <div class="bg-white rounded p-2 text-center">
                                <code class="fs-sm">effective_age = max(0, age_months - 3)</code><br>
                                <code class="fs-sm">decay = exp(-effective_age / 30)</code><br>
                                <code class="fs-sm">decayed_points = points &times; decay</code>
                            </div>
                            <p class="mt-2 mb-0 text-muted">{{ 'puzzle_intelligence.methodology.elo_decay_cutoff'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium">{{ 'puzzle_intelligence.methodology.elo_example_title'|trans }}</p>
                    <p class="mb-1">{{ 'puzzle_intelligence.methodology.elo_example_desc'|trans|raw }}</p>
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-1">{{ 'puzzle_intelligence.methodology.elo_example_player_a'|trans|raw }}</p>
                            <p class="mb-0 text-muted">{{ 'puzzle_intelligence.methodology.elo_example_player_a_score'|trans|raw }}</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1">{{ 'puzzle_intelligence.methodology.elo_example_player_b'|trans|raw }}</p>
                            <p class="mb-0 text-muted">{{ 'puzzle_intelligence.methodology.elo_example_player_b_score'|trans|raw }}</p>
                        </div>
                    </div>
                    <p class="mt-1 mb-0 text-muted">{{ 'puzzle_intelligence.methodology.elo_example_conclusion'|trans }}</p>
                </div>
            </div>

            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium"><i class="bi bi-shield-check me-1"></i> {{ 'puzzle_intelligence.methodology.elo_antigaming_title'|trans }}</p>
                    <ul class="mb-0 text-muted ps-3">
                        <li>{{ 'puzzle_intelligence.methodology.elo_antigaming_grinding'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.elo_antigaming_volume'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.elo_antigaming_easy'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.elo_antigaming_inactivity'|trans|raw }}</li>
                    </ul>
                </div>
            </div>

            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_elo_minimum'|trans|raw }}</p>

            <button class="btn btn-outline-secondary btn-sm mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#eloFormula">
                <i class="bi bi-code me-1"></i> {{ 'puzzle_intelligence.methodology.show_formula'|trans }}
            </button>
            <div class="collapse" id="eloFormula">
                <div class="card bg-light border-0">
                    <div class="card-body py-2">
<pre class="fs-sm mb-0"><code>Rolling window: 24 months. Decay: 3-month plateau.

For each puzzle in window (20+ public solvers):
  fa_percentile = rank among first-attempt solvers (0&ndash;1)
  bt_percentile = rank among all players' best times (0&ndash;1)

  confidence = min(1.0, sample_size / 50)
  blend = 0.5 &times; confidence
  difficulty_weight = (1 - blend) + blend &times; difficulty

  effective_age = max(0, age_months - 3)
  decay = exp(-effective_age / 30)

  fa_points = fa_percentile &times; difficulty_weight &times; decay
  bt_points = bt_percentile &times; difficulty_weight &times; decay

First-attempt portfolio = mean(top 100 fa_points)
Best-time portfolio = mean(top 100 bt_points)
Rating = 0.75 &times; FA_portfolio + 0.25 &times; BT_portfolio

Entry: 20 first attempts + 50 total solves within window
Display: rating &times; 1000 (e.g., 0.85 &rarr; 850)</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Section 5: Time Prediction #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">5</span>
                {{ 'puzzle_intelligence.methodology.section_prediction_title'|trans }}
            </h4>

            <p class="fs-sm mb-3">{{ 'puzzle_intelligence.methodology.prediction_intro'|trans|raw }}</p>

            {# Improvement Ratios #}
            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium"><i class="bi bi-graph-down me-1"></i> {{ 'puzzle_intelligence.methodology.prediction_ratios_title'|trans }}</p>
                    <p class="mb-1 text-muted">{{ 'puzzle_intelligence.methodology.prediction_ratios_desc'|trans|raw }}</p>
                    <div class="bg-white rounded p-2 mt-2 mb-2">
<pre class="fs-sm mb-0"><code>{{ 'puzzle_intelligence.methodology.prediction_ratios_formula'|trans|raw }}</code></pre>
                    </div>
                    <p class="mb-1 text-muted">{{ 'puzzle_intelligence.methodology.prediction_ratios_gap_desc'|trans|raw }}</p>
                    <div class="table-responsive mt-2">
                        <table class="table table-sm table-bordered fs-sm mb-0">
                            <thead><tr><th>{{ 'puzzle_intelligence.methodology.prediction_ratios_gap_header'|trans }}</th><th>{{ 'puzzle_intelligence.methodology.prediction_ratios_gap_range'|trans }}</th></tr></thead>
                            <tbody>
                                <tr><td>lt30d</td><td>&lt; 30 days</td></tr>
                                <tr><td>1_3m</td><td>30&ndash;89 days</td></tr>
                                <tr><td>3_12m</td><td>90&ndash;364 days</td></tr>
                                <tr><td>gt12m</td><td>365+ days</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            {# Personal Prediction with Blending #}
            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium"><i class="bi bi-person me-1"></i> {{ 'puzzle_intelligence.methodology.prediction_personal_title'|trans }}</p>
                    <p class="mb-1 text-muted">{{ 'puzzle_intelligence.methodology.prediction_personal_desc'|trans|raw }}</p>
                    <div class="bg-white rounded p-2 mt-2">
<pre class="fs-sm mb-0"><code>{{ 'puzzle_intelligence.methodology.prediction_personal_formula'|trans|raw }}</code></pre>
                    </div>
                    <p class="mt-2 mb-0 text-muted">{{ 'puzzle_intelligence.methodology.prediction_personal_dampening'|trans }}</p>
                </div>
            </div>

            {# Statistical Prediction #}
            <div class="card bg-light border-0 mb-3">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-1 fw-medium"><i class="bi bi-calculator me-1"></i> {{ 'puzzle_intelligence.methodology.prediction_statistical_title'|trans }}</p>
                    <p class="mb-1 text-muted">{{ 'puzzle_intelligence.methodology.prediction_statistical_desc'|trans }}</p>
                    <div class="bg-white rounded p-2 text-center mt-2 mb-2">
                        <code class="fs-sm">predicted_time = player_baseline &times; puzzle_difficulty</code>
                    </div>
                    <p class="mb-1">{{ 'puzzle_intelligence.methodology.prediction_statistical_example_baseline'|trans }} <strong>55 min</strong></p>
                    <p class="mb-1">{{ 'puzzle_intelligence.methodology.prediction_statistical_example_difficulty'|trans }} <strong>1.15</strong> ({{ 'puzzle_intelligence.difficulty.tiers.challenging'|trans }})</p>
                    <p class="mb-1">{{ 'puzzle_intelligence.methodology.prediction_statistical_example_predicted'|trans }} 55 &times; 1.15 = <strong>~63 min</strong></p>
                    <p class="mb-0 text-muted">{{ 'puzzle_intelligence.methodology.prediction_statistical_range'|trans }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Section 6: Puzzle Personality #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">6</span>
                {{ 'puzzle_intelligence.methodology.section_personality_title'|trans }}
            </h4>

            <div class="row g-3">
                {% set metrics = [
                    {icon: 'bi-arrow-repeat', name: 'puzzle_intelligence.personality.memorability', desc: 'puzzle_intelligence.personality.memorability_desc', detail: 'puzzle_intelligence.methodology.personality_memorability_detail', formula: 'learning_rate = (attempt_1 - attempt_3) / attempt_1\nmemorability = puzzle_learning_rate / global_learning_rate'},
                    {icon: 'bi-speedometer2', name: 'puzzle_intelligence.personality.skill_sensitivity', desc: 'puzzle_intelligence.personality.skill_sensitivity_desc', detail: 'puzzle_intelligence.methodology.personality_skill_sensitivity_detail', formula: 'skill_sensitivity = P75(indices) / P25(indices)'},
                    {icon: 'bi-bullseye', name: 'puzzle_intelligence.personality.predictability', desc: 'puzzle_intelligence.personality.predictability_desc', detail: 'puzzle_intelligence.methodology.personality_predictability_detail', formula: 'CV = std_dev(indices) / mean(indices)\npredictability = 1 / (1 + CV)'},
                    {icon: 'bi-box', name: 'puzzle_intelligence.personality.box_dependence', desc: 'puzzle_intelligence.personality.box_dependence_desc', detail: 'puzzle_intelligence.methodology.personality_box_dependence_detail', formula: 'box_dependence = median(unboxed_indices) / median(boxed_indices)'},
                    {icon: 'bi-graph-up-arrow', name: 'puzzle_intelligence.personality.improvement_ceiling', desc: 'puzzle_intelligence.personality.improvement_ceiling_desc', detail: 'puzzle_intelligence.methodology.personality_improvement_ceiling_detail', formula: 'improvement_ceiling = P50(first_attempts) / P10(all_attempts)'},
                ] %}
                {% for metric in metrics %}
                    <div class="col-md-6">
                        <div class="card bg-light border-0 h-100">
                            <div class="card-body py-2">
                                <h6 class="fs-sm">
                                    <i class="{{ metric.icon }} me-1"></i>
                                    {{ metric.name|trans }}
                                </h6>
                                <p class="fs-sm text-muted mb-1">{{ metric.desc|trans }}</p>
                                <small class="text-muted fst-italic">{{ metric.detail|trans }}</small>
                                <div class="bg-white rounded p-1 mt-2">
                                    <pre class="fs-sm mb-0 text-center"><code>{{ metric.formula }}</code></pre>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Section 7: Confidence + Data Quality #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">7</span>
                {{ 'puzzle_intelligence.difficulty.confidence_label'|trans }} & {{ 'puzzle_intelligence.methodology.section_data_quality_title'|trans }}
            </h4>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <h6 class="fs-sm"><i class="bi bi-shield-check me-1"></i>{{ 'puzzle_intelligence.methodology.section_confidence_title'|trans }}</h6>
                    <div class="d-flex flex-column gap-2 fs-sm">
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-confidence-high"><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i></span>
                            <strong>{{ 'puzzle_intelligence.difficulty.confidence_levels.high'|trans }}</strong> &mdash; 20+ qualified solvers
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-confidence-medium"><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i><i class="bi bi-circle text-muted" style="font-size: 0.5rem;"></i></span>
                            <strong>{{ 'puzzle_intelligence.difficulty.confidence_levels.medium'|trans }}</strong> &mdash; 10-19 solvers
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-confidence-low"><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i><i class="bi bi-circle text-muted" style="font-size: 0.5rem;"></i><i class="bi bi-circle text-muted" style="font-size: 0.5rem;"></i></span>
                            <strong>{{ 'puzzle_intelligence.difficulty.confidence_levels.low'|trans }}</strong> &mdash; 5-9 solvers
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted"><i class="bi bi-circle" style="font-size: 0.5rem;"></i><i class="bi bi-circle" style="font-size: 0.5rem;"></i><i class="bi bi-circle" style="font-size: 0.5rem;"></i></span>
                            {{ 'puzzle_intelligence.difficulty.not_enough_data'|trans }} &mdash; < 5 solvers
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <h6 class="fs-sm">{{ 'puzzle_intelligence.methodology.section_data_quality_title'|trans }}</h6>
                    <ul class="fs-sm mb-0 ps-3">
                        <li>{{ 'puzzle_intelligence.methodology.section_data_quality_solo'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.section_data_quality_first'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.section_data_quality_outlier'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.section_data_quality_suspicious'|trans|raw }}</li>
                        <li>{{ 'puzzle_intelligence.methodology.section_data_quality_recency'|trans|raw }}</li>
                    </ul>
                </div>
            </div>

            <div class="card bg-light border-0">
                <div class="card-body py-2 fs-sm">
                    <p class="mb-2 fw-medium">{{ 'puzzle_intelligence.methodology.thresholds_title'|trans }}</p>
                    <div class="table-responsive">
                        <table class="table table-sm table-borderless mb-0 fs-sm">
                            <tbody>
                                <tr><td>{{ 'puzzle_intelligence.methodology.section_baseline_title'|trans }}</td><td class="text-muted">{{ 'puzzle_intelligence.methodology.threshold_baseline'|trans }}</td></tr>
                                <tr><td>{{ 'puzzle_intelligence.methodology.section_difficulty_title'|trans }}</td><td class="text-muted">{{ 'puzzle_intelligence.methodology.threshold_difficulty'|trans }}</td></tr>
                                <tr><td>{{ 'puzzle_intelligence.methodology.section_skill_title'|trans }}</td><td class="text-muted">{{ 'puzzle_intelligence.methodology.threshold_skill'|trans }}</td></tr>
                                <tr><td>{{ 'puzzle_intelligence.methodology.section_elo_title'|trans }}</td><td class="text-muted">{{ 'puzzle_intelligence.methodology.threshold_elo'|trans }}</td></tr>
                                <tr><td>{{ 'puzzle_intelligence.personality.memorability'|trans }}</td><td class="text-muted">{{ 'puzzle_intelligence.methodology.threshold_memorability'|trans }}</td></tr>
                                <tr><td>{{ 'puzzle_intelligence.personality.skill_sensitivity'|trans }} / {{ 'puzzle_intelligence.personality.predictability'|trans }}</td><td class="text-muted">{{ 'puzzle_intelligence.methodology.threshold_sensitivity_predictability'|trans }}</td></tr>
                                <tr><td>{{ 'puzzle_intelligence.personality.box_dependence'|trans }}</td><td class="text-muted">{{ 'puzzle_intelligence.methodology.threshold_box_dependence'|trans }}</td></tr>
                                <tr><td>{{ 'puzzle_intelligence.personality.improvement_ceiling'|trans }}</td><td class="text-muted">{{ 'puzzle_intelligence.methodology.threshold_improvement_ceiling'|trans }}</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Section 8: Opting Out #}
    <div class="card shadow-sm mb-3 border-0">
        <div class="card-body">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 22px;">8</span>
                {{ 'puzzle_intelligence.methodology.section_opt_out_title'|trans }}
            </h4>
            <p class="fs-sm">{{ 'puzzle_intelligence.methodology.section_opt_out_desc'|trans({'%url%': path('edit_profile')})|raw }}</p>
        </div>
    </div>

    <p class="text-muted fs-sm text-center mt-4 mb-2" data-controller="next-quarter-countdown">
        <i class="bi bi-clock me-1"></i>
        {{ 'puzzle_intelligence.methodology.section_recalculation_countdown'|trans }}
        <strong><span data-next-quarter-countdown-target="display">--:--</span></strong>
    </p>
{% endblock %}
