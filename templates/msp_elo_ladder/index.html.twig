{% extends 'base.html.twig' %}

{% block title %}{{ 'puzzle_intelligence.elo.title'|trans }}{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig') }}

    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
        <div>
            <div class="d-flex align-items-center mb-1">
                <h1 class="h2 mb-0">{{ 'puzzle_intelligence.elo.title'|trans }}</h1>
                <span class="badge bg-info ms-2">{{ 'puzzle_intelligence.elo.beta_badge'|trans }}</span>
            </div>
            <p class="text-muted mb-0 fs-sm">
                {{ 'puzzle_intelligence.elo.subtitle'|trans }}
                <a href="{{ path('methodology') }}" class="ms-1">{{ 'puzzle_intelligence.elo.how_it_works'|trans }}</a>
            </p>
        </div>

        {% if player_position is not null and player_elo_rating is not null %}
            {# Ranked banner — inline with header on desktop #}
            {% if player_elo_rating >= 1400 %}
                {% set my_rank_tier = 'legend' %}
            {% elseif player_elo_rating >= 1200 %}
                {% set my_rank_tier = 'expert' %}
            {% elseif player_elo_rating >= 1000 %}
                {% set my_rank_tier = 'proficient' %}
            {% elseif player_elo_rating >= 800 %}
                {% set my_rank_tier = 'enthusiast' %}
            {% else %}
                {% set my_rank_tier = 'casual' %}
            {% endif %}
            <div class="card shadow-custom flex-shrink-0">
                <div class="card-body py-2 px-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="text-center flex-shrink-0">
                            <svg class="rank-icon" width="36" height="36" style="color: var(--rank-{{ my_rank_tier }})"><use href="/rank-icons-sprite.svg#rank-{{ my_rank_tier }}"/></svg>
                            <div style="font-size: 0.7rem; color: var(--rank-{{ my_rank_tier }})" class="fw-medium">{{ ('puzzle_intelligence.skill.tiers.' ~ my_rank_tier)|trans }}</div>
                        </div>
                        <div class="flex-grow-1" style="line-height: 1.3;">
                            <small class="text-muted" style="font-size: 0.7rem;">{{ 'puzzle_intelligence.elo.your_ranking_among'|trans({'%total%': total_count}) }}</small>
                            <div class="d-flex align-items-center gap-2">
                                <span class="h5 mb-0 fw-bold">#{{ player_position }}</span>
                                <span class="text-muted">&middot;</span>
                                <span class="fw-bold">{{ player_elo_rating }} ELO</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>

    {# Qualification banner — full width below header #}
    {% if player_position is null and logged_player is not null and elo_progress is not null %}
        {# Not yet qualified — show progress toward qualification #}
        {% set fa_done = elo_progress.first_attempts >= min_first_attempts %}
        {% set ts_done = elo_progress.total_solves >= min_total_solves %}
        <div class="card shadow-custom mb-3">
            <div class="card-body py-3">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <svg class="rank-icon flex-shrink-0" width="32" height="32" style="color: var(--rank-unknown)"><use href="/rank-icons-sprite.svg#rank-unknown"/></svg>
                    <div>
                        <h6 class="mb-0">{{ 'puzzle_intelligence.elo.qualification_title'|trans }}</h6>
                        <small class="text-muted">{{ 'puzzle_intelligence.elo.qualification_desc'|trans }}</small>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2 mb-2">
                    <small class="text-muted" style="min-width: 110px;">
                        <i class="bi bi-{{ fa_done ? 'check-circle-fill text-success' : 'x-circle text-muted' }} me-1"></i>
                        {{ 'puzzle_intelligence.elo.progress_first_attempts'|trans }}
                    </small>
                    <div class="progress flex-grow-1" style="height: 6px;">
                        {% set fa_pct = (elo_progress.first_attempts / min_first_attempts * 100) > 100 ? 100 : (elo_progress.first_attempts / min_first_attempts * 100) %}
                        <div class="progress-bar {{ fa_done ? 'bg-success' : 'bg-primary' }}" style="width: {{ fa_pct }}%;"></div>
                    </div>
                    <small class="text-muted fw-medium" style="min-width: 45px;">{{ elo_progress.first_attempts }}/{{ min_first_attempts }}</small>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <small class="text-muted" style="min-width: 110px;">
                        <i class="bi bi-{{ ts_done ? 'check-circle-fill text-success' : 'x-circle text-muted' }} me-1"></i>
                        {{ 'puzzle_intelligence.elo.progress_total_solves'|trans }}
                    </small>
                    <div class="progress flex-grow-1" style="height: 6px;">
                        {% set ts_pct = (elo_progress.total_solves / min_total_solves * 100) > 100 ? 100 : (elo_progress.total_solves / min_total_solves * 100) %}
                        <div class="progress-bar {{ ts_done ? 'bg-success' : 'bg-primary' }}" style="width: {{ ts_pct }}%;"></div>
                    </div>
                    <small class="text-muted fw-medium" style="min-width: 45px;">{{ elo_progress.total_solves }}/{{ min_total_solves }}</small>
                </div>
            </div>
        </div>
    {% endif %}

    {# Ladder table #}
    {% if entries|length > 0 %}
        <div class="table-responsive custom-table-wrapper">
            <table class="table custom-table table-striped table-hover mb-0 align-middle">
                <tbody>
                    {% for entry in entries %}
                        {% set is_current_player = logged_player is not null and entry.playerId == logged_player.playerId %}
                        <tr class="{{ is_current_player ? 'table-active-player' }}">
                            <td class="text-center text-muted" style="font-family: monospace; width: 1%; white-space: nowrap; padding-right: 0;">
                                <small>{{ entry.rank }}</small>
                            </td>
                            <td>
                                <a href="{{ path('player_profile', {playerId: entry.playerId}) }}" class="text-decoration-none d-flex align-items-center gap-2">
                                    {% if entry.playerAvatar %}
                                        <img src="{{ entry.playerAvatar|thumbnail('puzzle_small') }}" alt="" class="rounded-circle flex-shrink-0" style="width: 28px; height: 28px; min-width: 28px; object-fit: cover;">
                                    {% else %}
                                        <span class="rounded-circle bg-light d-flex align-items-center justify-content-center flex-shrink-0" style="width: 28px; height: 28px; min-width: 28px;">
                                            <i class="bi bi-person text-muted"></i>
                                        </span>
                                    {% endif %}
                                    {% if entry.eloRating >= 1400 %}
                                        {% set row_rank = 'legend' %}
                                    {% elseif entry.eloRating >= 1200 %}
                                        {% set row_rank = 'expert' %}
                                    {% elseif entry.eloRating >= 1000 %}
                                        {% set row_rank = 'proficient' %}
                                    {% elseif entry.eloRating >= 800 %}
                                        {% set row_rank = 'enthusiast' %}
                                    {% else %}
                                        {% set row_rank = 'casual' %}
                                    {% endif %}
                                    <svg class="rank-icon flex-shrink-0" width="20" height="20" style="color: var(--rank-{{ row_rank }})"><use href="/rank-icons-sprite.svg#rank-{{ row_rank }}"/></svg>
                                    <div>
                                        <small>{{ entry.playerName ?? ('#' ~ entry.playerCode) }}</small>
                                        {% if entry.playerCountry %}
                                            <small class="shadow-custom fi fi-{{ entry.playerCountry }} ms-1"></small>
                                        {% endif %}
                                    </div>
                                </a>
                            </td>
                            <td class="text-end text-nowrap">
                                <small style="font-family: monospace;">{{ entry.eloRating }}</small>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {# Pagination #}
        {% if total_pages > 1 %}
            <nav>
                <ul class="pagination justify-content-center mt-3 mb-0">
                    <li class="page-item {{ current_page <= 1 ? 'disabled' : '' }}">
                        <a class="page-link" href="{{ path('msp_elo_ladder', {page: current_page - 1}) }}">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    {% for p in 1..total_pages %}
                        <li class="page-item {{ p == current_page ? 'active' : '' }}">
                            <a class="page-link" href="{{ path('msp_elo_ladder', {page: p}) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item {{ current_page >= total_pages ? 'disabled' : '' }}">
                        <a class="page-link" href="{{ path('msp_elo_ladder', {page: current_page + 1}) }}">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% else %}
        <div class="text-muted text-center py-4">
            <i class="bi bi-trophy fs-1 d-block mb-2 opacity-25"></i>
            {{ 'puzzle_intelligence.elo.no_entries'|trans }}
        </div>
    {% endif %}
{% endblock %}
