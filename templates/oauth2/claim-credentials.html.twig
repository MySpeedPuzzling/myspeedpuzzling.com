{% extends 'base.html.twig' %}

{% block title %}Claim OAuth2 Credentials{% endblock %}

{% block content %}
    <div class="col-lg-8 mx-auto">
        <h1 class="mb-4">OAuth2 Credentials for {{ client_name }}</h1>

        <div class="alert alert-warning">
            <strong>Important:</strong> These credentials will only be shown once. Save them in a secure location now.
        </div>

        <div class="card card-body shadow-sm mb-4">
            <div class="mb-3">
                <label class="form-label fw-bold">Client ID</label>
                <code class="user-select-all d-block p-2 bg-light rounded">{{ client_identifier }}</code>
            </div>

            {% if client_secret is not null %}
                <div class="mb-3">
                    <label class="form-label fw-bold">Client Secret</label>
                    <code class="user-select-all d-block p-2 bg-light rounded">{{ client_secret }}</code>
                </div>
            {% else %}
                <div class="mb-3">
                    <label class="form-label fw-bold">Client Type</label>
                    <p>Public client (no secret — PKCE is required)</p>
                </div>
            {% endif %}

            <div class="mb-0">
                <label class="form-label fw-bold">Application Type</label>
                <p class="mb-0">{{ application_type|capitalize }}</p>
            </div>
        </div>

        <a href="{{ path('edit_profile') }}" class="btn btn-secondary">Back to Settings</a>
    </div>
{% endblock %}
