{% extends 'base.html.twig' %}

{% block title %}{{ player.playerName ?? ('#' ~ player.code) }} - {{ 'menu.profile'|trans }}{% endblock %}
{% block og_type %}profile{% endblock %}
{% block og_image %}{% if player.avatar is not null %}{{ absolute_url(player.avatar|thumbnail('puzzle_medium')) }}{% else %}{{ parent() }}{% endif %}{% endblock %}

{% block content %}
    {{ include('_return_back_button.html.twig') }}
    <h1 class="visually-hidden">{{ player.playerName ?? ('#' ~ player.code) }}</h1>
    <twig:PlayerHeader player="{{ player }}" />

    <div class="row mb-3">
        {% if player.activeMembership %}
            <p class="col-sm">
                <a href="{{ path('membership') }}" class="badge bg-primary py-1 px-2 text-light">
                    <i class="ci ci-heart-filled"></i>
                    {{ 'active_membership'|trans }}
                </a>
            </p>
        {% endif %}

        {% if can_message %}
            <p class="col-sm">
                <a href="{{ path('start_conversation', {recipientId: player.playerId}) }}" class="btn btn-sm btn-outline-primary" data-turbo="true" data-turbo-frame="modal-frame">
                    <i class="bi bi-envelope me-1"></i> {{ 'messaging.send_message'|trans }}
                </a>
            </p>
        {% endif %}

        {% if logged_user.profile is not null and logged_user.profile.playerId is same as player.playerId %}
            <div class="col-sm" style="max-width: 366px;" data-controller="clipboard">
                <div class="share-profile-link">
                    <small>Share your profile (<span class="text-muted">{{ 'my_profile.share_mention_myspeedpuzzling'|trans|raw }}</span>)</small>
                    <div class="input-group input-group-sm">
                        <input
                            data-action="click->clipboard#selectInputContent dblclick->clipboard#selectInputContent focus->clipboard#selectInputContent"
                            {{ stimulus_target('clipboard', 'input')}}
                            value="{{ url('player_profile', {playerId: player.playerId}) }}"
                            class="form-control form-control-sm"
                            type="text"
                            readonly
                        >
                        <button {{ stimulus_action('clipboard', 'copyToClipboard', 'click')}} id="share-profile-link-button" class="btn btn-sm btn-icon btn-primary" type="button">
                            <i {{ stimulus_target('clipboard', 'buttonIcon')}} class="ci-share"></i>
                        </button>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>

    {% if player.isPrivate and (logged_user.profile is null or logged_user.profile.playerId is not same as player.playerId) %}
        <div class="alert alert-secondary d-flex align-items-start gap-3 p-3 rounded-3 shadow-sm">
            <i class="bi bi-incognito fs-2 text-muted flex-shrink-0"></i>
            <div class="small lh-sm">
                <p class="mb-1">
                    <strong>{{ 'secret_puzzler_name'|trans }}!</strong> {{ 'profile.private_profile_info_1'|trans }}
                </p>
                <p class="mb-0">
                    {{ 'profile.private_profile_info_2'|trans }}
                </p>
            </div>

        </div>
    {% else %}
        {% set is_own_profile = logged_user.profile is not null and logged_user.profile.playerId is same as player.playerId %}

            {# Ranking opted-out player viewing own profile #}
            {% if player.rankingOptedOut and is_own_profile %}
                <div class="d-flex flex-column flex-md-row align-items-md-stretch gap-2 mb-2 w-100">
                    <div class="card shadow-sm flex-grow-1">
                        <div class="card-body py-2 px-3 d-flex flex-column">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <i class="bi bi-eye-slash text-muted" style="font-size: 1.2rem;"></i>
                                <small class="fw-medium">{{ 'puzzle_intelligence.skill.title'|trans }}</small>
                            </div>
                            <small class="text-muted">
                                {{ 'puzzle_intelligence.skill.ranking_opted_out'|trans }}
                                <a href="{{ path('edit_profile') }}">{{ 'statistics.change_in_settings'|trans }}</a>
                            </small>
                        </div>
                    </div>
                    <div class="card shadow-sm flex-shrink-0 flex-grow-0">
                        <div class="card-body py-2 px-3 d-flex flex-column">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <i class="bi bi-eye-slash text-muted" style="font-size: 1.2rem;"></i>
                                <small class="fw-medium">{{ 'puzzle_intelligence.elo.qualification_title'|trans }}</small>
                            </div>
                            <small class="text-muted">
                                {{ 'puzzle_intelligence.elo.ranking_opted_out'|trans }}
                                <a href="{{ path('edit_profile') }}">{{ 'statistics.change_in_settings'|trans }}</a>
                            </small>
                        </div>
                    </div>
                </div>

            {# Ranking opted-out player viewed by others — hide entirely #}
            {% elseif player.rankingOptedOut %}

            {# Private player viewing own profile — explain why no rankings #}
            {% elseif player.isPrivate and is_own_profile %}
                <div class="d-flex flex-column flex-md-row align-items-md-stretch gap-2 mb-2 w-100">
                    <div class="card shadow-sm flex-grow-1">
                        <div class="card-body py-2 px-3 d-flex flex-column">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <i class="bi bi-incognito text-muted" style="font-size: 1.2rem;"></i>
                                <small class="fw-medium">{{ 'puzzle_intelligence.skill.title'|trans }}</small>
                            </div>
                            <small class="text-muted">{{ 'puzzle_intelligence.skill.private_profile_explanation'|trans }}</small>
                        </div>
                    </div>
                    <div class="card shadow-sm flex-shrink-0 flex-grow-0">
                        <div class="card-body py-2 px-3 d-flex flex-column">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <i class="bi bi-incognito text-muted" style="font-size: 1.2rem;"></i>
                                <small class="fw-medium">{{ 'puzzle_intelligence.elo.qualification_title'|trans }}</small>
                            </div>
                            <small class="text-muted">{{ 'puzzle_intelligence.elo.private_profile_explanation'|trans }}</small>
                        </div>
                    </div>
                </div>

            {# Normal member view #}
            {% elseif logged_user.profile is not null and logged_user.profile.activeMembership %}
                <div class="d-flex flex-column flex-md-row align-items-md-stretch gap-2 mb-2 w-100">
                    <twig:PlayerSkillProfile playerId="{{ player.playerId }}" />
                    <twig:PlayerRatingProfile
                        playerId="{{ player.playerId }}"
                        :isOwnProfile="is_own_profile"
                    />
                </div>
            {% else %}
                <div class="d-flex flex-column flex-md-row align-items-md-stretch gap-2 mb-2 w-100">
                    <twig:PlayerRatingProfile
                        playerId="{{ player.playerId }}"
                        :isOwnProfile="false"
                    />
                    <button
                        class="btn btn-outline-primary btn-sm d-flex align-items-center justify-content-center gap-1 flex-grow-1"
                        data-bs-toggle="modal"
                        data-bs-target="#membersExclusiveModal"
                    >
                        <svg class="rank-icon" width="16" height="16" style="color: var(--rank-locked)"><use href="/rank-icons-sprite.svg#rank-locked"/></svg>
                        {{ 'puzzle_intelligence.player_insights.title'|trans }}
                    </button>
                </div>
            {% endif %}

        <div class="my-4">
            <twig:Chart:PlayerAverageTimeChart playerId="{{ player.playerId }}" />
        </div>

        <ul class="nav nav-fill nav-tabs mt-2" role="tablist" {{ stimulus_controller('tabs') }}>
            <li class="nav-item">
                <a class="nav-link active" href="#recent-activity" data-bs-toggle="tab" role="tab" {{ stimulus_action('tabs', 'showTab') }}>
                    <div class="text-center">
                        <h6 class="media-tab-title text-nowrap pt-2 mb-0">{{ 'profile.recent_activity'|trans|raw }}</h6>
                    </div>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="#info" data-bs-toggle="tab" role="tab" {{ stimulus_action('tabs', 'showTab') }}>
                    <div class="text-center">
                        <h6 class="media-tab-title text-nowrap pt-2 mb-0">{{ 'profile.personal_info'|trans|raw }}</h6>
                    </div>
                </a>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="recent-activity" role="tabpanel">
                <twig:RecentActivity :playerId="player.playerId" limit="20" :showLimit="3" :isOnProfile="true" />
            </div>

            <div class="tab-pane fade" id="info" role="tabpanel">
                <div class="shadow-lg p-3 mt-3">
                    <div class="row">
                        <div class="col-sm">
                            <p>
                                <b>{{ 'profile.avatar'|trans }}:</b><br>
                                {% if player.avatar is null %}
                                    {{ 'profile.not_filled'|trans }}
                                {% else %}
                                    <img class="rounded-2" style="max-width: 150px;max-height: 150px;" alt="Avatar" src="{{ player.avatar|thumbnail('puzzle_small') }}">
                                {% endif %}
                            </p>

                            <p class="mb-0">
                                <b>{{ 'profile.about_me'|trans }}:</b><br>
                                {% if player.bio is null %}
                                    {{ 'profile.not_filled'|trans }}
                                {% else %}
                                    {{ player.bio|nl2br }}
                                {% endif %}<br>
                            </p>
                        </div>

                        <div class="col-sm">
                            <p>
                                <b>{{ 'profile.location'|trans }}:</b><br>
                                {% if player.city is null %}
                                    {{ 'profile.not_filled'|trans }}
                                {% else %}
                                    {{ player.city }}
                                {% endif %}
                            </p>

                            <p>
                                <b>{{ 'profile.nationality'|trans }}:</b><br>
                                {% if player.countryCode is null %}
                                    {{ 'profile.not_filled'|trans }}
                                {% else %}
                                    {{ player.countryCode.value }}
                                    <span class="shadow-custom fi fi-{{ player.countryCode.name }}"></span>
                                {% endif %}
                            </p>

                            <p>
                                <b>Facebook:</b><br>
                                {% if player.facebook is null %}
                                    {{ 'profile.not_filled'|trans }}
                                {% else %}
                                    {{ player.facebook|facebook }}
                                {% endif %}<br>
                            </p>

                            <p>
                                <b>Instagram:</b><br>
                                {% if player.instagram is null %}
                                    {{ 'profile.not_filled'|trans }}
                                {% else %}
                                    {{ player.instagram|instagram }}
                                {% endif %}<br>
                            </p>

                            {% if player.twitch is not null %}
                                <p class="mb-0">
                                    <b>Twitch:</b><br>
                                    {{ player.twitch|twitch }}<br>
                                </p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {% if badges is not empty %}
            <div class="mt-4">
                <h3>{{ 'badges.title'|trans }}</h3>

                {% for badge in badges %}
                    <span class="d-inline-block text-center small">
                    <img alt="{{ ('badges.badge.' ~ badge.value)|trans }}" src="{{ asset('img/badges/' ~ badge.value ~ '.png') }}" style="width: 80px;"><br>
                    {{ ('badges.badge.' ~ badge.value)|trans }}
                </span>
                {% endfor %}
            </div>
        {% endif %}

        {% if affiliate_supporters is not null %}
            <div class="mt-4">
                <h3>
                    <i class="ci-heart me-1"></i>
                    {{ 'referral.supporters.title'|trans }}
                    {% if affiliate_supporters.total_count > 0 %}
                        <span class="badge bg-primary ms-1 align-middle fs-sm">{{ affiliate_supporters.total_count }}</span>
                    {% endif %}
                </h3>

                {% if logged_user.profile is not null and logged_user.profile.playerId is same as player.playerId %}
                    <div class="mb-3" style="max-width: 450px;" data-controller="clipboard">
                        <small class="text-muted">{{ 'referral.profile.share_link'|trans }}</small>
                        <div class="input-group input-group-sm">
                            <input
                                data-action="click->clipboard#selectInputContent dblclick->clipboard#selectInputContent focus->clipboard#selectInputContent"
                                {{ stimulus_target('clipboard', 'input') }}
                                value="{{ url('homepage_crossroads', {ref: player.code}) }}"
                                class="form-control form-control-sm"
                                type="text"
                                readonly
                            >
                            <button {{ stimulus_action('clipboard', 'copyToClipboard', 'click') }} class="btn btn-sm btn-icon btn-primary" type="button">
                                <i {{ stimulus_target('clipboard', 'buttonIcon') }} class="ci-share"></i>
                            </button>
                        </div>
                    </div>
                {% endif %}

                {% if affiliate_supporters.total_count > 0 %}
                    {% if affiliate_supporters.public_supporters|length < affiliate_supporters.total_count %}
                        <p class="text-muted small">
                            {{ 'referral.supporters.privacy_note'|trans({'%total%': affiliate_supporters.total_count, '%shown%': affiliate_supporters.public_supporters|length}) }}
                        </p>
                    {% endif %}

                    <div class="d-flex flex-wrap gap-2">
                        {% for supporter in affiliate_supporters.public_supporters %}
                            <a href="{{ path('player_profile', {playerId: supporter.player_id}) }}"
                               class="d-flex align-items-center gap-2 text-decoration-none bg-light rounded-pill px-3 py-1">
                                {% if supporter.player_avatar %}
                                    <img src="{{ supporter.player_avatar|thumbnail('avatar_small') }}"
                                         class="rounded-circle"
                                         width="24" height="24"
                                         alt="">
                                {% else %}
                                    <i class="ci-user text-muted"></i>
                                {% endif %}
                                <small class="text-body">{{ supporter.player_name ?? 'Secret Puzzler' }}</small>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endif %}

        <div>
            <h2 class="h4 mt-3">{{ 'profile.solved_puzzles'|trans }}</h2>

            <twig:PlayerSolvedPuzzles playerId="{{ player.playerId }}" />
        </div>
    {% endif %}
{% endblock %}
