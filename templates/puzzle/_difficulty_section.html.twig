{% from 'puzzle_intelligence/_macros.html.twig' import confidence_dots, human_difficulty, personality_metric, difficulty_badge %}

{% if puzzle_difficulty is not null and puzzle_difficulty.difficultyScore is not null %}
    {% if logged_user.profile is not null and logged_user.profile.activeMembership %}
        {% set tier_name = puzzle_difficulty.difficultyTier.name|lower %}
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                {# Header with tier badge and human-readable description #}
                <div class="d-flex align-items-start justify-content-between mb-2">
                    <div>
                        <h6 class="card-title mb-1">
                            <i class="bi bi-bar-chart me-1"></i>
                            {{ 'puzzle_intelligence.difficulty.title'|trans }}
                        </h6>
                        {{ difficulty_badge(tier_name, 'fs-6 me-2') }}
                        <span class="fs-sm">
                            {{ human_difficulty(puzzle_difficulty.difficultyScore) }}
                        </span>
                    </div>
                    <div class="text-end">
                        {{ confidence_dots(puzzle_difficulty.confidence.value, puzzle_difficulty.sampleSize) }}
                    </div>
                </div>

                {# Difficulty score for data geeks #}
                <small class="text-muted d-block mb-2">
                    {{ 'puzzle_intelligence.difficulty.score_label'|trans }}: {{ puzzle_difficulty.difficultyScore|number_format(2) }}
                    &middot; {{ 'puzzle_intelligence.difficulty.sample_size_label'|trans({'%count%': puzzle_difficulty.sampleSize}) }}
                </small>

                {# Puzzle Personality Traits #}
                {% if puzzle_difficulty.memorabilityScore is not null
                    or puzzle_difficulty.skillSensitivityScore is not null
                    or puzzle_difficulty.predictabilityScore is not null
                    or puzzle_difficulty.boxDependenceScore is not null %}
                    <hr class="my-2">
                    <h6 class="fs-sm text-muted mb-1">{{ 'puzzle_intelligence.personality.title'|trans }}</h6>

                    {% if puzzle_difficulty.memorabilityScore is not null %}
                        {{ personality_metric(
                            'puzzle_intelligence.personality.memorability',
                            'puzzle_intelligence.info.memorability',
                            puzzle_difficulty.memorabilityScore,
                            'memorability'
                        ) }}
                    {% endif %}
                    {% if puzzle_difficulty.skillSensitivityScore is not null %}
                        {{ personality_metric(
                            'puzzle_intelligence.personality.skill_sensitivity',
                            'puzzle_intelligence.info.skill_sensitivity',
                            puzzle_difficulty.skillSensitivityScore,
                            'sensitivity'
                        ) }}
                    {% endif %}
                    {% if puzzle_difficulty.predictabilityScore is not null %}
                        {{ personality_metric(
                            'puzzle_intelligence.personality.predictability',
                            'puzzle_intelligence.info.predictability',
                            puzzle_difficulty.predictabilityScore,
                            'predictability'
                        ) }}
                    {% endif %}
                    {% if puzzle_difficulty.boxDependenceScore is not null %}
                        {{ personality_metric(
                            'puzzle_intelligence.personality.box_dependence',
                            'puzzle_intelligence.info.box_dependence',
                            puzzle_difficulty.boxDependenceScore,
                            'box_dependence'
                        ) }}
                    {% endif %}
                {% endif %}

                {# Time Prediction #}
                {% if time_prediction is not null %}
                    <hr class="my-2">
                    <h6 class="fs-sm text-muted mb-1">
                        {{ 'puzzle_intelligence.prediction.title'|trans }}
                    </h6>
                    <div class="d-flex align-items-center gap-2">
                        <span class="fw-bold">~{{ (time_prediction.predictedSeconds / 60)|round }}min</span>
                        <small class="text-muted">
                            {{ 'puzzle_intelligence.prediction.range'|trans({
                                '%low%': (time_prediction.rangeLowSeconds / 60)|round ~ 'min',
                                '%high%': (time_prediction.rangeHighSeconds / 60)|round ~ 'min',
                            }) }}
                        </small>
                    </div>
                {% endif %}
            </div>
        </div>
    {% else %}
        {# Members-only CTA #}
        <div class="card shadow-sm mb-3 position-relative">
            <div class="card-body">
                <h6 class="card-title mb-2 text-muted">
                    <i class="bi bi-bar-chart me-1"></i>
                    {{ 'puzzle_intelligence.difficulty.title'|trans }}
                </h6>
                <div class="text-muted fs-sm" style="filter: blur(4px);">
                    {% set tier_name = puzzle_difficulty.difficultyTier.name|lower %}
                    {{ difficulty_badge(tier_name, 'me-2') }}
                    <small>{{ human_difficulty(puzzle_difficulty.difficultyScore) }}</small>
                </div>
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background: rgba(255,255,255,0.8); border-radius: inherit;">
                    <button
                        class="btn btn-outline-secondary bg-white btn-sm px-3 fs-sm shadow-custom"
                        data-bs-toggle="modal"
                        data-bs-target="#membersExclusiveModal"
                    >
                        <i class="ci-locked me-1"></i>
                        {{ 'puzzle_intelligence.difficulty.members_only'|trans }}
                    </button>
                </div>
            </div>
        </div>
    {% endif %}
{% elseif puzzle_difficulty is not null and puzzle_difficulty.difficultyScore is null and puzzle_difficulty.sampleSize > 0 %}
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <h6 class="card-title mb-1 text-muted">
                <i class="bi bi-bar-chart me-1"></i>
                {{ 'puzzle_intelligence.difficulty.title'|trans }}
            </h6>
            <small class="text-muted">
                {{ 'puzzle_intelligence.difficulty.need_more_solvers'|trans({'%count%': (5 - puzzle_difficulty.sampleSize)}) }}
            </small>
        </div>
    </div>
{% endif %}
