{% extends 'base.html.twig' %}

{% set brand_meta_description = 'brand_hub.meta.description'|trans({
    '%brand%': stats.brandName,
    '%count%': stats.puzzlesCount,
}) %}

{% block title %}{{ 'brand_hub.meta.title'|trans({'%brand%': stats.brandName}) }}{% endblock %}
{% block meta_description %}{{ brand_meta_description }}{% endblock %}
{% block robots %}
    {% if stats.indexable %}
        <meta name="robots" content="index, follow">
    {% else %}
        {# Thin-page guardrail: too few puzzles or no recorded solves #}
        <meta name="robots" content="noindex, follow">
    {% endif %}
{% endblock %}

{% block json_ld %}
    {{ parent() }}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": {{ 'puzzle_detail.breadcrumb.database'|trans|json_encode|raw }},
                "item": {{ url('puzzles')|json_encode|raw }}
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": {{ stats.brandName|json_encode|raw }}
            }
        ]
    }
    </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": {{ 'brand_hub.meta.title'|trans({'%brand%': stats.brandName})|json_encode|raw }},
        "description": {{ brand_meta_description|json_encode|raw }},
        "url": {{ url('brand_puzzles', {slug: stats.slug})|json_encode|raw }},
        "about": {
            "@type": "Brand",
            "name": {{ stats.brandName|json_encode|raw }}
        }
    }
    </script>
{% endblock %}

{% block content %}
    <h1 class="mb-2">{{ 'brand_hub.title'|trans({'%brand%': stats.brandName}) }}</h1>

    <div class="row g-2 mb-2">
        <div class="col-4">
            <div class="card card-body shadow p-2 text-center h-100">
                <div class="fs-4 fw-bold">{{ stats.puzzlesCount }}</div>
                <small class="text-muted">{{ 'brand_hub.stats.puzzles'|trans }}</small>
            </div>
        </div>
        <div class="col-4">
            <div class="card card-body shadow p-2 text-center h-100">
                <div class="fs-4 fw-bold">{{ stats.solvesCount }}</div>
                <small class="text-muted">{{ 'brand_hub.stats.solves'|trans }}</small>
            </div>
        </div>
        <div class="col-4">
            <div class="card card-body shadow p-2 text-center h-100">
                <div class="fs-4 fw-bold">{{ stats.medianSeconds is not null ? stats.medianSeconds|compactTime : '–' }}</div>
                <small class="text-muted">{{ 'brand_hub.stats.median_time'|trans }}</small>
            </div>
        </div>
    </div>

    <p class="text-muted small mb-3">{{ 'brand_hub.stats.provenance'|trans({'%solves%': stats.solvesCount}) }}</p>

    {% if stats.piecesMedians|length > 0 %}
        <h2 class="h5">{{ 'brand_hub.median_by_pieces'|trans }}</h2>
        <ul class="list-unstyled mb-3">
            {% for bucket in stats.piecesMedians %}
                <li>
                    {% if bucket.piecesCount in allowed_pieces %}
                        <a href="{{ path('pieces_puzzles', {pieces: bucket.piecesCount}) }}">{{ 'brand_hub.pieces_link'|trans({'%pieces%': bucket.piecesCount}) }}</a>:
                    {% else %}
                        {{ 'brand_hub.pieces_link'|trans({'%pieces%': bucket.piecesCount}) }}:
                    {% endif %}
                    <strong>{{ bucket.medianSeconds|compactTime }}</strong>
                    <small class="text-muted">({{ 'brand_hub.stats.provenance'|trans({'%solves%': bucket.solvesCount}) }})</small>
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    {% if puzzles|length > 0 %}
        <h2 class="h5">{{ 'brand_hub.most_solved'|trans({'%brand%': stats.brandName}) }}</h2>
        <div class="row g-2 g-md-3">
            {{ include('puzzle/_search_result_items.html.twig', {
                'puzzles': puzzles,
                'search': null,
                'puzzle_statuses': puzzle_statuses,
                'ranking': ranking,
                'tags': tags,
                'difficulty_data': difficulty_data,
                'offer_counts': offer_counts,
            }) }}
        </div>
    {% endif %}

    <p class="mt-3">
        <a class="btn btn-outline-primary btn-sm" href="{{ path('puzzles', {brand: stats.brandId}) }}">
            {{ 'brand_hub.view_all'|trans({'%brand%': stats.brandName}) }}
        </a>
    </p>
{% endblock %}
