{% extends 'base.html.twig' %}

{% set pieces_meta_description = stats.medianSeconds is not null
    ? 'pieces_hub.meta.description'|trans({
        '%pieces%': stats.piecesCount,
        '%median%': stats.medianSeconds|compactTime,
        '%solves%': stats.solvesCount,
        '%count%': stats.puzzlesCount,
    })
    : 'pieces_hub.meta.description_no_median'|trans({
        '%pieces%': stats.piecesCount,
        '%count%': stats.puzzlesCount,
    })
%}

{% block title %}{{ 'pieces_hub.meta.title'|trans({'%pieces%': stats.piecesCount}) }}{% endblock %}
{% block meta_description %}{{ pieces_meta_description }}{% endblock %}

{% block json_ld %}
    {{ parent() }}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": {{ 'puzzle_detail.breadcrumb.database'|trans|json_encode|raw }},
                "item": {{ url('puzzles')|json_encode|raw }}
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": {{ 'pieces_hub.title'|trans({'%pieces%': stats.piecesCount})|json_encode|raw }}
            }
        ]
    }
    </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": {{ 'pieces_hub.meta.title'|trans({'%pieces%': stats.piecesCount})|json_encode|raw }},
        "description": {{ pieces_meta_description|json_encode|raw }},
        "url": {{ url('pieces_puzzles', {pieces: stats.piecesCount})|json_encode|raw }}
    }
    </script>
{% endblock %}

{% block content %}
    <h1 class="mb-2">{{ 'pieces_hub.title'|trans({'%pieces%': stats.piecesCount}) }}</h1>

    <div class="row g-2 mb-2">
        <div class="col-4">
            <div class="card card-body shadow p-2 text-center h-100">
                <div class="fs-4 fw-bold">{{ stats.puzzlesCount }}</div>
                <small class="text-muted">{{ 'brand_hub.stats.puzzles'|trans }}</small>
            </div>
        </div>
        <div class="col-4">
            <div class="card card-body shadow p-2 text-center h-100">
                <div class="fs-4 fw-bold">{{ stats.solvesCount }}</div>
                <small class="text-muted">{{ 'brand_hub.stats.solves'|trans }}</small>
            </div>
        </div>
        <div class="col-4">
            <div class="card card-body shadow p-2 text-center h-100">
                <div class="fs-4 fw-bold">{{ stats.medianSeconds is not null ? stats.medianSeconds|compactTime : '–' }}</div>
                <small class="text-muted">{{ 'brand_hub.stats.median_time'|trans }}</small>
            </div>
        </div>
    </div>

    <p class="text-muted small mb-3">{{ 'brand_hub.stats.provenance'|trans({'%solves%': stats.solvesCount}) }}</p>

    {% if stats.topBrands|length > 0 %}
        <h2 class="h5">{{ 'pieces_hub.top_brands'|trans({'%pieces%': stats.piecesCount}) }}</h2>
        <p class="mb-3">
            {% for brand in stats.topBrands %}
                <a class="badge bg-primary badge-shadow rounded-pill text-white link-light" href="{{ path('brand_puzzles', {slug: brand.slug}) }}">{{ brand.brandName }}</a>
            {% endfor %}
        </p>
    {% endif %}

    {% if puzzles|length > 0 %}
        <h2 class="h5">{{ 'pieces_hub.most_solved'|trans({'%pieces%': stats.piecesCount}) }}</h2>
        <div class="row g-2 g-md-3">
            {{ include('puzzle/_search_result_items.html.twig', {
                'puzzles': puzzles,
                'search': null,
                'puzzle_statuses': puzzle_statuses,
                'ranking': ranking,
                'tags': tags,
                'difficulty_data': difficulty_data,
                'offer_counts': offer_counts,
            }) }}
        </div>
    {% endif %}

    <p class="mt-3">
        <a class="btn btn-outline-primary btn-sm" href="{{ path('puzzles', {pieces: listing_pieces_param}) }}">
            {{ 'pieces_hub.view_all'|trans({'%pieces%': stats.piecesCount}) }}
        </a>
    </p>
{% endblock %}
