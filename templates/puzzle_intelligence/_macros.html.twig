{# Reusable macros for Puzzle Intelligence UI components #}

{# Confidence indicator — visual dots with custom colors #}
{% macro confidence_dots(confidence_value, sample_size) %}
    {% set levels = {'low': 1, 'medium': 2, 'high': 3} %}
    {% set level = levels[confidence_value] ?? 0 %}
    <span class="text-confidence-{{ confidence_value }}" title="{{ ('puzzle_intelligence.info.confidence')|trans }}">
        {% for i in 1..3 %}
            {% if i <= level %}
                <i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i>
            {% else %}
                <i class="bi bi-circle text-muted" style="font-size: 0.5rem;"></i>
            {% endif %}
        {% endfor %}
        <small class="text-muted ms-1">{{ sample_size }}</small>
    </span>
{% endmacro %}

{# Human-readable difficulty description #}
{% macro human_difficulty(score) %}
    {% set deviation = ((score - 1.0) * 100)|round %}
    {% if deviation > 3 %}
        <span>{{ 'puzzle_intelligence.human.harder_than_avg'|trans({'%percent%': deviation|abs}) }}</span>
    {% elseif deviation < -3 %}
        <span>{{ 'puzzle_intelligence.human.easier_than_avg'|trans({'%percent%': deviation|abs}) }}</span>
    {% else %}
        <span>{{ 'puzzle_intelligence.human.about_average'|trans }}</span>
    {% endif %}
{% endmacro %}

{# Difficulty tier badge with custom color #}
{% macro difficulty_badge(tier_name, extra_class) %}
    <span class="badge badge-tier-{{ tier_name }} {{ extra_class ?? '' }}">
        {{ ('puzzle_intelligence.difficulty.tiers.' ~ tier_name)|trans }}
    </span>
{% endmacro %}

{# Skill tier badge with custom color #}
{% macro skill_badge(tier_name, extra_class) %}
    <span class="badge badge-skill-{{ tier_name }} {{ extra_class ?? '' }}">
        {{ ('puzzle_intelligence.skill.tiers.' ~ tier_name)|trans }}
    </span>
{% endmacro %}

{# Human-readable personality metric with color indicator #}
{% macro personality_metric(label_key, info_key, value, metric_type) %}
    {% if metric_type == 'memorability' %}
        {% if value >= 1.4 %}
            {% set descriptor = 'puzzle_intelligence.human.memorability_high' %}
            {% set color = 'badge-tier-easy' %}
        {% elseif value >= 1.15 %}
            {% set descriptor = 'puzzle_intelligence.human.memorability_medium' %}
            {% set color = 'badge-tier-veryeasy' %}
        {% else %}
            {% set descriptor = 'puzzle_intelligence.human.memorability_low' %}
            {% set color = 'badge-tier-average' %}
        {% endif %}
    {% elseif metric_type == 'sensitivity' %}
        {% if value >= 1.8 %}
            {% set descriptor = 'puzzle_intelligence.human.sensitivity_high' %}
            {% set color = 'badge-tier-challenging' %}
        {% elseif value >= 1.3 %}
            {% set descriptor = 'puzzle_intelligence.human.sensitivity_medium' %}
            {% set color = 'badge-tier-veryeasy' %}
        {% else %}
            {% set descriptor = 'puzzle_intelligence.human.sensitivity_low' %}
            {% set color = 'badge-tier-average' %}
        {% endif %}
    {% elseif metric_type == 'predictability' %}
        {% if value >= 5.0 %}
            {% set descriptor = 'puzzle_intelligence.human.predictability_high' %}
            {% set color = 'badge-tier-easy' %}
        {% elseif value >= 2.5 %}
            {% set descriptor = 'puzzle_intelligence.human.predictability_medium' %}
            {% set color = 'badge-tier-veryeasy' %}
        {% else %}
            {% set descriptor = 'puzzle_intelligence.human.predictability_low' %}
            {% set color = 'badge-tier-challenging' %}
        {% endif %}
    {% elseif metric_type == 'box_dependence' %}
        {% if value >= 1.4 %}
            {% set descriptor = 'puzzle_intelligence.human.box_dep_high' %}
            {% set color = 'badge-tier-challenging' %}
        {% elseif value >= 1.15 %}
            {% set descriptor = 'puzzle_intelligence.human.box_dep_medium' %}
            {% set color = 'badge-tier-veryeasy' %}
        {% else %}
            {% set descriptor = 'puzzle_intelligence.human.box_dep_low' %}
            {% set color = 'badge-tier-average' %}
        {% endif %}
    {% endif %}

    <div class="d-flex align-items-center justify-content-between py-1">
        <div>
            <span class="text-muted">{{ label_key|trans }}</span>
            <i class="bi bi-info-circle text-muted" style="font-size: 0.7rem;" data-bs-toggle="tooltip" title="{{ info_key|trans }}"></i>
        </div>
        <div class="text-end">
            <span class="badge {{ color ?? 'badge-tier-average' }}" style="font-weight: 500;">{{ descriptor|trans }}</span>
            <small class="text-muted ms-1">{{ value|number_format(1) }}{% if metric_type != 'predictability' %}x{% endif %}</small>
        </div>
    </div>
{% endmacro %}

{# Percentile progress bar with custom skill color #}
{% macro percentile_bar(percentile, tier_name) %}
    <div class="progress" style="height: 8px;">
        <div class="progress-bar progress-bar-skill-{{ tier_name }}"
             role="progressbar"
             style="width: {{ percentile }}%;"
             aria-valuenow="{{ percentile }}"
             aria-valuemin="0"
             aria-valuemax="100">
        </div>
    </div>
{% endmacro %}

{# Next tier milestone — shows progress toward the next skill tier #}
{# tier_thresholds: ordered from highest to lowest percentile requirement #}
{% macro next_tier_milestone(current_percentile, current_tier_name) %}
    {% set tiers_ascending = [
        {name: 'casual',       min: 0,    next_min: 25},
        {name: 'enthusiast',   min: 25,   next_min: 50},
        {name: 'proficient',   min: 50,   next_min: 70},
        {name: 'advanced',     min: 70,   next_min: 85},
        {name: 'expert',       min: 85,   next_min: 95},
        {name: 'master',       min: 95,   next_min: 99},
        {name: 'grandmaster',  min: 99,   next_min: null},
    ] %}

    {% set current = null %}
    {% set next = null %}
    {% for i, tier in tiers_ascending %}
        {% if tier.name == current_tier_name %}
            {% set current = tier %}
            {% if tier.next_min is not null %}
                {# find the next tier by name #}
                {% for t in tiers_ascending %}
                    {% if t.min == tier.next_min %}
                        {% set next = t %}
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endif %}
    {% endfor %}

    {% if next is not null and current is not null %}
        {% set gap = (next.min - current_percentile)|round(1) %}
        {% set tier_range = next.min - current.min %}
        {% set progress_in_tier = tier_range > 0 ? ((current_percentile - current.min) / tier_range * 100) : 0 %}

        <div class="d-flex align-items-center gap-2 mt-2">
            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <small class="text-muted">
                        <i class="bi bi-arrow-up-circle me-1"></i>
                        {{ 'puzzle_intelligence.skill.next_tier'|trans }}
                        <span class="badge badge-skill-{{ next.name }}">{{ ('puzzle_intelligence.skill.tiers.' ~ next.name)|trans }}</span>
                        <span class="text-muted">({{ 'puzzle_intelligence.skill.next_tier_threshold'|trans({'%threshold%': next.min}) }})</span>
                    </small>
                    <small class="fw-medium text-skill-{{ next.name }}">
                        {{ 'puzzle_intelligence.skill.next_tier_gap'|trans({'%gap%': gap|abs|number_format(1)}) }}
                    </small>
                </div>
                {% set clamped_progress = progress_in_tier < 0 ? 0 : (progress_in_tier > 100 ? 100 : progress_in_tier) %}
                <div class="progress" style="height: 6px;">
                    <div class="progress-bar progress-bar-skill-{{ next.name }}"
                         style="width: {{ clamped_progress }}%;">
                    </div>
                </div>
            </div>
        </div>
    {% elseif current is not null and current.next_min is null %}
        <div class="mt-2">
            <small class="text-skill-grandmaster">
                <i class="bi bi-star-fill me-1"></i>
                {{ 'puzzle_intelligence.skill.highest_tier_reached'|trans }}
            </small>
        </div>
    {% endif %}
{% endmacro %}
