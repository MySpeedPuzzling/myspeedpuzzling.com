{% extends 'base.html.twig' %}

{% block robots %}
    {# Only a text search de-indexes the page.
       The canonical (unfiltered route URL) already de-duplicates brand/tag/pieces filtered views.
       Note: the <head> renders once on full page load, so live filter changes do not re-render this meta. #}
    {% if app.request.query.has('search') %}
        <meta name="robots" content="noindex, nofollow">
    {% else %}
        <meta name="robots" content="index, follow">
    {% endif %}
{% endblock %}

{% block title %}{{ 'puzzle_overview.meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'puzzle_overview.meta.description'|trans }}{% endblock %}

{% block content %}
    <h1 class="mb-2">{{ 'puzzle_overview.title'|trans }}</h1>

    {# Default view renders server-side: page one comes from the app cache
       (initial_puzzles_v2), so the synchronous render is cheap and ships
       crawlable puzzle links + content in the initial HTML. Filtered/search
       deep links keep loading="defer" for a fast first paint - those states
       are noindexed or canonicalized to the clean URL anyway. #}
    {% if app.request.query.count > 0 %}
        <twig:PuzzleSearch loading="defer" />
    {% else %}
        <twig:PuzzleSearch />
    {% endif %}

{% endblock %}
