{% extends 'base.html.twig' %}

{% block title %}{{ 'competition.stopwatch.title'|trans }} - {{ round.name }} - {{ competition.name }}{% endblock %}

{% block full_content %}
    <div class="d-flex flex-column align-items-center justify-content-center py-5"
         data-controller="round-stopwatch"
         data-round-stopwatch-status-value="{{ round.stopwatchStatus ?? '' }}"
         data-round-stopwatch-started-at-value="{{ round.stopwatchStartedAt ? round.stopwatchStartedAt.format('c') : '' }}"
         data-round-stopwatch-minutes-limit-value="{{ round.minutesLimit }}"
         data-round-stopwatch-server-now-value="{{ serverNow }}"
         data-round-stopwatch-mercure-url-value="{{ mercure_public_url }}"
         data-round-stopwatch-topic-value="/round-stopwatch/{{ round.id }}"
    >
        <h1 class="h4 text-center mb-1">{{ competition.name }}</h1>
        <h2 class="h5 text-muted text-center mb-4">{{ round.name }}</h2>

        <div class="d-flex align-items-center justify-content-center mb-3" style="font-size: 6rem; font-family: monospace; font-weight: bold; line-height: 1;">
            <span data-round-stopwatch-target="hours">00</span>
            <span class="mx-2">:</span>
            <span data-round-stopwatch-target="minutes">00</span>
            <span class="mx-2">:</span>
            <span data-round-stopwatch-target="seconds">00</span>
        </div>

        <div class="fs-4 mb-4"
             data-round-stopwatch-target="status"
             data-label-not-started="{{ 'competition.stopwatch.not_started'|trans }}"
             data-label-running="{{ 'competition.stopwatch.running'|trans }}"
             data-label-stopped="{{ 'competition.stopwatch.stopped'|trans }}"
             data-label-times-up="{{ 'competition.stopwatch.times_up'|trans }}"
        >
            {% if round.stopwatchStatus == 'running' %}
                <span class="text-success">{{ 'competition.stopwatch.running'|trans }}</span>
            {% elseif round.stopwatchStatus == 'stopped' %}
                <span class="text-warning">{{ 'competition.stopwatch.stopped'|trans }}</span>
            {% else %}
                <span class="text-muted">{{ 'competition.stopwatch.not_started'|trans }}</span>
            {% endif %}
        </div>

        {% if canManage and round.stopwatchStatus != 'running' %}
            <form method="post" action="{{ path('start_round_stopwatch', {'roundId': round.id}) }}" class="mb-3">
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-play-fill me-1"></i>{{ 'competition.stopwatch.start'|trans }}
                </button>
            </form>
        {% endif %}

        {% if canManage %}
            <a href="{{ path('manage_round_stopwatch', {'roundId': round.id}) }}" class="btn btn-outline-secondary">
                <i class="bi bi-gear me-1"></i>{{ 'competition.stopwatch.manage'|trans }}
            </a>
        {% endif %}
    </div>
{% endblock %}
